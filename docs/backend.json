{
  "entities": {
    "Store": {
      "title": "Store",
      "description": "Represents a single store or tenant in the SaaS platform.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the store." },
        "description": { "type": "string", "description": "Public description of the store." },
        "ownerId": { "type": "string", "description": "The UID of the user who owns this store." },
        "logoUrl": { "type": "string", "format": "uri" }
      },
      "required": ["name", "ownerId"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's public profile and role information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["customer", "storeAdmin", "superAdmin"] },
        "storeId": { "type": "string", "description": "The ID of the store this user manages, if they are a storeAdmin." }
      },
      "required": ["displayName", "email", "role"]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product in the inventory. This can be in a specific store's collection or in the public-facing aggregated collection.",
      "properties": {
        "name": { "type": "string", "description": "Name of the product." },
        "description": { "type": "string", "description": "Detailed description of the product." },
        "price": { "type": "number", "description": "Price of the product." },
        "wholesalePrice": { "type": "number", "description": "Wholesale price of the product." },
        "cost": { "type": "number", "description": "Cost of the product." },
        "stock": { "type": "number", "description": "Available stock quantity." },
        "sku": { "type": "string", "description": "Stock Keeping Unit." },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "Status of the product." },
        "tax1": { "type": "boolean" },
        "tax2": { "type": "boolean" },
        "unit": { "type": "string" },
        "family": { "type": "string" },
        "warehouse": { "type": "string" },
        "imageUrl": { "type": "string", "description": "URL of the product image.", "format": "uri" },
        "imageHint": { "type": "string" },
        "storeId": { "type": "string", "description": "The ID of the store this product belongs to." },
        "storeName": { "type": "string", "description": "The name of the store for public display." }
      },
      "required": ["name", "price", "stock", "sku", "status", "storeId", "storeName"]
    },
    "Sale": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Sale",
      "type": "object",
      "description": "Represents a sale transaction within a specific store.",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "saleDate": { "type": "string", "format": "date-time" },
        "totalAmount": { "type": "number" }
      },
      "required": ["id", "customerId", "saleDate", "totalAmount"]
    },
    "SaleItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SaleItem",
      "type": "object",
      "description": "Represents an item within a sale transaction.",
      "properties": {
        "id": { "type": "string" },
        "saleId": { "type": "string" },
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" }
      },
      "required": ["id", "saleId", "productId", "quantity", "unitPrice"]
    },
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer of a specific store.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Represents a chat room.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the chat room." },
        "lastMessage": { "type": "string" },
        "lastMessageTimestamp": { "type": "string", "format": "date-time" }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Represents a single message in a chat.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderName", "text", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com"]
  },
  "firestore": {
    "/stores": {
      "schema": { "$ref": "#/entities/Store" },
      "description": "Collection of all stores (tenants) in the platform."
    },
    "/stores/{storeId}/products": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Collection of products specific to a single store."
    },
    "/stores/{storeId}/sales": {
      "schema": { "$ref": "#/entities/Sale" },
      "description": "Collection of sales specific to a single store."
    },
    "/stores/{storeId}/customers": {
      "schema": { "$ref": "#/entities/Customer" },
      "description": "Collection of customers specific to a single store."
    },
    "/products": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Aggregated, public-facing collection of products from all stores for the marketplace view."
    },
    "/users": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Collection of all user profiles, including their roles."
    },
    "/chats": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Collection of all chat rooms."
    },
    "/chats/{chatId}/messages": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Sub-collection of messages for a specific chat."
    }
  }
}
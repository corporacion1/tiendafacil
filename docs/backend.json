
{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product in the inventory system.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the Product entity." },
        "name": { "type": "string", "description": "Name of the product." },
        "description": { "type": "string", "description": "Detailed description of the product." },
        "sku": { "type": "string", "description": "Stock keeping unit; a unique identifier for inventory tracking." },
        "price": { "type": "number", "description": "Selling price of the product." },
        "wholesalePrice": { "type": "number", "description": "Wholesale price of the product." },
        "cost": { "type": "number", "description": "Cost price of the product." },
        "quantity": { "type": "number", "description": "Current quantity of the product in stock." },
        "tax1": { "type": "boolean" },
        "tax2": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "inactive", "promotion"] },
        "unit": { "type": "string" },
        "family": { "type": "string" },
        "warehouse": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "imageHint": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "storeId": { "type": "string" }
      },
      "required": ["id", "name", "price", "cost", "quantity", "status", "storeId", "createdAt"]
    },
    "InventoryMovement": {
      "title": "InventoryMovement", "type": "object", "description": "Represents a movement of inventory, such as a sale, purchase, or adjustment.",
      "properties": {
        "id": { "type": "string" },
        "productName": { "type": "string" },
        "type": { "type": "string", "enum": ["sale", "purchase", "adjustment"] },
        "quantity": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "responsible": { "type": "string" },
        "storeId": { "type": "string" }
      },
      "required": ["id", "productName", "type", "quantity", "date", "storeId"]
    },
    "Sale": {
      "title": "Sale", "type": "object", "description": "Represents a sale transaction.",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            },
            "required": ["productId", "productName", "quantity", "price"]
          }
        },
        "total": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "transactionType": { "type": "string", "enum": ["contado", "credito"] },
        "status": { "type": "string", "enum": ["paid", "unpaid"] },
        "paidAmount": { "type": "number" },
        "payments": {
            "type": "array",
            "items": { "$ref": "#/entities/Payment" }
        },
        "storeId": { "type": "string" }
      },
      "required": ["id", "customerId", "customerName", "items", "total", "date", "transactionType", "status", "storeId"]
    },
    "Purchase": {
      "title": "Purchase", "type": "object", "description": "Represents a purchase order for restocking inventory.",
      "properties": {
        "id": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "cost": { "type": "number" }
            },
            "required": ["productId", "productName", "quantity", "cost"]
          }
        },
        "total": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "documentNumber": { "type": "string" },
        "responsible": { "type": "string" },
        "storeId": { "type": "string" }
      },
      "required": ["id", "supplierId", "supplierName", "items", "total", "date", "responsible", "storeId"]
    },
    "Customer": {
      "title": "Customer", "type": "object", "description": "Represents a customer.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "storeId": { "type": "string" }
      },
      "required": ["id", "name", "storeId"]
    },
    "Supplier": {
      "title": "Supplier", "type": "object", "description": "Represents a supplier of products.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "storeId": { "type": "string" }
      },
      "required": ["id", "name", "storeId"]
    },
    "Unit": { 
      "title": "Unit", "type": "object", 
      "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "storeId": { "type": "string" } }, 
      "required": ["id", "name", "storeId"] 
    },
    "Family": { 
      "title": "Family", "type": "object", 
      "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "storeId": { "type": "string" } }, 
      "required": ["id", "name", "storeId"] 
    },
    "Warehouse": { 
      "title": "Warehouse", "type": "object", 
      "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "storeId": { "type": "string" } }, 
      "required": ["id", "name", "storeId"] 
    },
    "Store": {
      "title": "Store", "type": "object", "description": "Represents configuration settings for the application.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "The name of the commerce or business." },
        "ownerId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "slogan": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "whatsapp": { "type": "string" },
        "tiktok": { "type": "string" },
        "meta": { "type": "string" },
        "saleSeries": { "type": "string" },
        "saleCorrelative": { "type": "number" },
        "primaryCurrencyName": { "type": "string" },
        "primaryCurrencySymbol": { "type": "string" },
        "secondaryCurrencyName": { "type": "string" },
        "secondaryCurrencySymbol": { "type": "string" },
        "tax1": { "type": "number" },
        "tax2": { "type": "number" },
        "businessType": { "type": "string" }
      },
      "required": ["id", "name", "ownerId"]
    },
    "UserProfile": {
        "title": "UserProfile", "type": "object", "description": "Represents a user profile.",
        "properties": {
            "uid": {"type": "string"},
            "email": {"type": "string", "format": "email"},
            "displayName": {"type": "string"},
            "photoURL": {"type": "string", "format": "uri"},
            "role": {"type": "string", "enum": ["superAdmin", "admin", "user"]},
            "status": {"type": "string", "enum": ["active", "disabled"]},
            "storeId": {"type": "string"},
            "storeRequest": {"type": "boolean"},
            "createdAt": {"type": "string", "format": "date-time"}
        },
        "required": ["uid", "email"]
    },
    "Ad": {
        "title": "Ad", "type": "object", "description": "Represents a marketing advertisement.",
        "properties": {
            "id": {"type": "string"},
            "sku": {"type": "string"},
            "name": {"type": "string"},
            "description": {"type": "string"},
            "price": {"type": "number"},
            "imageUrl": {"type": "string", "format": "uri"},
            "imageHint": {"type": "string"},
            "views": {"type": "number"},
            "status": {"type": "string", "enum": ["active", "inactive"]},
            "targetBusinessTypes": {"type": "array", "items": {"type": "string"}},
            "expiryDate": {"type": "string", "format": "date-time"},
            "createdAt": {"type": "string", "format": "date-time"}
        },
        "required": ["id", "name", "sku", "price", "status", "imageUrl", "views", "targetBusinessTypes", "createdAt"]
    },
    "Payment": {
        "title": "Payment", "type": "object", "description": "Represents a payment made for a sale.",
        "properties": {
            "id": {"type": "string"},
            "amount": {"type": "number"},
            "date": {"type": "string", "format": "date-time"},
            "method": {"type": "string"},
            "reference": {"type": "string"}
        },
        "required": ["id", "amount", "date", "method"]
    },
    "PendingOrder": {
        "title": "PendingOrder", "type": "object", "description": "An order created from the public catalog, awaiting processing.",
        "properties": {
            "id": {"type": "string"},
            "date": {"type": "string", "format": "date-time"},
            "customerName": {"type": "string"},
            "customerPhone": {"type": "string"},
            "customerEmail": {"type": "string", "format": "email"},
            "storeId": {"type": "string"},
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "productId": { "type": "string" },
                  "productName": { "type": "string" },
                  "quantity": { "type": "number" },
                  "price": { "type": "number" }
                },
                "required": ["productId", "productName", "quantity", "price"]
              }
            },
            "total": {"type": "number"}
        },
        "required": ["id", "date", "customerName", "customerPhone", "items", "total", "storeId"]
    },
    "CurrencyRate": {
      "title": "CurrencyRate", "type": "object", "description": "Represents an exchange rate at a specific point in time.",
      "properties": {
        "id": { "type": "string" },
        "rate": { "type": "number", "description": "The exchange rate value." },
        "date": { "type": "string", "format": "date-time", "description": "The date and time when the rate was set." }
      },
      "required": ["id", "rate", "date"]
    }
  },
  "auth": { "providers": ["password", "anonymous"] },
  "firestore": {
    "/products/{productId}": { "schema": { "$ref": "#/entities/Product" }, "description": "Stores product information." },
    "/inventory_movements/{movementId}": { "schema": { "$ref": "#/entities/InventoryMovement" }, "description": "Stores inventory movement records." },
    "/sales/{saleId}": { "schema": { "$ref": "#/entities/Sale" }, "description": "Stores sales transaction records." },
    "/purchases/{purchaseId}": { "schema": { "$ref": "#/entities/Purchase" }, "description": "Stores purchase order records." },
    "/customers/{customerId}": { "schema": { "$ref": "#/entities/Customer" }, "description": "Stores customer information." },
    "/suppliers/{supplierId}": { "schema": { "$ref": "#/entities/Supplier" }, "description": "Stores supplier information." },
    "/units/{unitId}": { "schema": { "$ref": "#/entities/Unit" }, "description": "Stores units of measure." },
    "/families/{familyId}": { "schema": { "$ref": "#/entities/Family" }, "description": "Stores product families/categories." },
    "/warehouses/{warehouseId}": { "schema": { "$ref": "#/entities/Warehouse" }, "description": "Stores warehouse information." },
    "/stores/{storeId}": { "schema": { "$ref": "#/entities/Store" }, "description": "Stores application configuration settings for each store." },
    "/users/{userId}": { "schema": { "$ref": "#/entities/UserProfile" }, "description": "Stores user profiles." },
    "/ads/{adId}": { "schema": { "$ref": "#/entities/Ad" }, "description": "Stores marketing advertisements." },
    "/pendingOrders/{orderId}": { "schema": { "$ref": "#/entities/PendingOrder" }, "description": "Stores orders from the public catalog." },
    "/stores/{storeId}/currencyRates/{rateId}": { "schema": { "$ref": "#/entities/CurrencyRate" }, "description": "Stores historical currency exchange rates for a specific store." }
  }
}

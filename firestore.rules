/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for stores and their associated data,
 *              with the goal of isolating data between different tenant stores.
 *
 * Data Structure:
 * - /users/{userId}: Stores global user profiles, accessible only to the owning user.
 * - /stores/{storeId}: Root collection for tenant stores.  Each store is owned by a specific user (ownerId).
 * - /stores/{storeId}/...: All subcollections under a store are considered private to that store and its owner.
 *
 * Key Security Decisions:
 * - **Strict Ownership**: Only the owner of a store can read or write data within that store's data tree.
 * - **User Listing Disabled**: Listing all users is explicitly denied.
 * - **Prototyping Mode**: Data schema validation is minimized to facilitate rapid prototyping.  Only authorization-critical
 *   fields are validated.
 *
 * Denormalization for Authorization:
 * - Each `Store` document contains an `ownerId` field. This is **critical** for authorization.
 * - Subcollections under `/stores/{storeId}` inherit ownership from the parent `Store` document, allowing simple
 *   rules without additional reads.
 *
 * Structural Segregation:
 * - User profiles and store data are stored in separate top-level collections to maintain clear ownership boundaries.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the current user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the current user is the owner of the specified resource (identified by userId).
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the current user is the existing owner of the resource.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Defines the rules for user profiles.
     * @path /users/{userId}
     * @allow (create) - User 'abc' can create their own profile if request.auth.uid == 'abc'.
     * @allow (get) - User 'abc' can read their own profile if request.auth.uid == 'abc'.
     * @allow (update) - User 'abc' can update their own profile if request.auth.uid == 'abc'.
     * @allow (delete) - User 'abc' can delete their own profile if request.auth.uid == 'abc'.
     * @deny (create) - User 'def' cannot create a profile for user 'abc'.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow get: if isOwner(userId);
      allow list: if false;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Defines the rules for stores.
     * @path /stores/{storeId}
     * @allow (create) - User 'abc' can create a store if request.auth.uid == request.resource.data.ownerId.
     * @allow (get) - User 'abc' can read a store if request.auth.uid == resource.data.ownerId.
     * @allow (update) - User 'abc' can update a store if request.auth.uid == resource.data.ownerId.
     * @allow (delete) - User 'abc' can delete a store if request.auth.uid == resource.data.ownerId.
     * @deny (create) - User 'def' cannot create a store owned by user 'abc'.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId} {
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow list: if false;
      allow update: if isExistingOwner(resource.data.ownerId);
      allow delete: if isExistingOwner(resource.data.ownerId);
    }

    /**
     * @description Defines the rules for products within a store.
     * @path /stores/{storeId}/products/{productId}
     * @allow (create) - User 'abc' can create a product in their store.
     * @allow (get) - User 'abc' can read a product in their store.
     * @allow (update) - User 'abc' can update a product in their store.
     * @allow (delete) - User 'abc' can delete a product in their store.
     * @deny (create) - User 'def' cannot create a product in store owned by user 'abc'.
     * @principle Enforces store ownership for product management.
     */
    match /stores/{storeId}/products/{productId} {
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
    }

    /**
     * @description Defines the rules for units within a store.
     * @path /stores/{storeId}/units/{unitId}
     * @allow (create) - User 'abc' can create a unit in their store.
     * @allow (get) - User 'abc' can read a unit in their store.
     * @allow (update) - User 'abc' can update a unit in their store.
     * @allow (delete) - User 'abc' can delete a unit in their store.
     * @deny (create) - User 'def' cannot create a unit in store owned by user 'abc'.
     * @principle Enforces store ownership for unit management.
     */
    match /stores/{storeId}/units/{unitId} {
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
    }

    /**
     * @description Defines the rules for families within a store.
     * @path /stores/{storeId}/families/{familyId}
     * @allow (create) - User 'abc' can create a family in their store.
     * @allow (get) - User 'abc' can read a family in their store.
     * @allow (update) - User 'abc' can update a family in their store.
     * @allow (delete) - User 'abc' can delete a family in their store.
     * @deny (create) - User 'def' cannot create a family in store owned by user 'abc'.
     * @principle Enforces store ownership for family management.
     */
    match /stores/{storeId}/families/{familyId} {
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
    }

    /**
     * @description Defines the rules for warehouses within a store.
     * @path /stores/{storeId}/warehouses/{warehouseId}
     * @allow (create) - User 'abc' can create a warehouse in their store.
     * @allow (get) - User 'abc' can read a warehouse in their store.
     * @allow (update) - User 'abc' can update a warehouse in their store.
     * @allow (delete) - User 'abc' can delete a warehouse in their store.
     * @deny (create) - User 'def' cannot create a warehouse in store owned by user 'abc'.
     * @principle Enforces store ownership for warehouse management.
     */
    match /stores/{storeId}/warehouses/{warehouseId} {
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
    }

    /**
     * @description Defines the rules for tax types within a store.
     * @path /stores/{storeId}/tax_types/{taxTypeId}
     * @allow (create) - User 'abc' can create a tax type in their store.
     * @allow (get) - User 'abc' can read a tax type in their store.
     * @allow (update) - User 'abc' can update a tax type in their store.
     * @allow (delete) - User 'abc' can delete a tax type in their store.
     * @deny (create) - User 'def' cannot create a tax type in store owned by user 'abc'.
     * @principle Enforces store ownership for tax type management.
     */
    match /stores/{storeId}/tax_types/{taxTypeId} {
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
    }

    /**
     * @description Defines the rules for inventory movements within a store.
     * @path /stores/{storeId}/inventory_movements/{inventoryMovementId}
     * @allow (create) - User 'abc' can create an inventory movement in their store.
     * @allow (get) - User 'abc' can read an inventory movement in their store.
     * @allow (update) - User 'abc' can update an inventory movement in their store.
     * @allow (delete) - User 'abc' can delete an inventory movement in their store.
     * @deny (create) - User 'def' cannot create an inventory movement in store owned by user 'abc'.
     * @principle Enforces store ownership for inventory movement management.
     */
    match /stores/{storeId}/inventory_movements/{inventoryMovementId} {
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
    }

    /**
     * @description Defines the rules for sales within a store.
     * @path /stores/{storeId}/sales/{saleId}
     * @allow (create) - User 'abc' can create a sale in their store.
     * @allow (get) - User 'abc' can read a sale in their store.
     * @allow (update) - User 'abc' can update a sale in their store.
     * @allow (delete) - User 'abc' can delete a sale in their store.
     * @deny (create) - User 'def' cannot create a sale in store owned by user 'abc'.
     * @principle Enforces store ownership for sale management.
     */
    match /stores/{storeId}/sales/{saleId} {
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
    }

    /**
     * @description Defines the rules for sale items within a sale.
     * @path /stores/{storeId}/sales/{saleId}/sale_items/{saleItemId}
     * @allow (create) - User 'abc' can create a sale item in their store.
     * @allow (get) - User 'abc' can read a sale item in their store.
     * @allow (update) - User 'abc' can update a sale item in their store.
     * @allow (delete) - User 'abc' can delete a sale item in their store.
     * @deny (create) - User 'def' cannot create a sale item in store owned by user 'abc'.
     * @principle Enforces store ownership for sale item management.
     */
    match /stores/{storeId}/sales/{saleId}/sale_items/{saleItemId} {
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
    }

    /**
     * @description Defines the rules for purchases within a store.
     * @path /stores/{storeId}/purchases/{purchaseId}
     * @allow (create) - User 'abc' can create a purchase in their store.
     * @allow (get) - User 'abc' can read a purchase in their store.
     * @allow (update) - User 'abc' can update a purchase in their store.
     * @allow (delete) - User 'abc' can delete a purchase in their store.
     * @deny (create) - User 'def' cannot create a purchase in store owned by user 'abc'.
     * @principle Enforces store ownership for purchase management.
     */
    match /stores/{storeId}/purchases/{purchaseId} {
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
    }

    /**
     * @description Defines the rules for purchase items within a purchase.
     * @path /stores/{storeId}/purchases/{purchaseId}/purchase_items/{purchaseItemId}
     * @allow (create) - User 'abc' can create a purchase item in their store.
     * @allow (get) - User 'abc' can read a purchase item in their store.
     * @allow (update) - User 'abc' can update a purchase item in their store.
     * @allow (delete) - User 'abc' can delete a purchase item in their store.
     * @deny (create) - User 'def' cannot create a purchase item in store owned by user 'abc'.
     * @principle Enforces store ownership for purchase item management.
     */
    match /stores/{storeId}/purchases/{purchaseId}/purchase_items/{purchaseItemId} {
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
    }

    /**
     * @description Defines the rules for suppliers within a store.
     * @path /stores/{storeId}/suppliers/{supplierId}
     * @allow (create) - User 'abc' can create a supplier in their store.
     * @allow (get) - User 'abc' can read a supplier in their store.
     * @allow (update) - User 'abc' can update a supplier in their store.
     * @allow (delete) - User 'abc' can delete a supplier in their store.
     * @deny (create) - User 'def' cannot create a supplier in store owned by user 'abc'.
     * @principle Enforces store ownership for supplier management.
     */
    match /stores/{storeId}/suppliers/{supplierId} {
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
    }

    /**
     * @description Defines the rules for customers within a store.
     * @path /stores/{storeId}/customers/{customerId}
     * @allow (create) - User 'abc' can create a customer in their store.
     * @allow (get) - User 'abc' can read a customer in their store.
     * @allow (update) - User 'abc' can update a customer in their store.
     * @allow (delete) - User 'abc' can delete a customer in their store.
     * @deny (create) - User 'def' cannot create a customer in store owned by user 'abc'.
     * @principle Enforces store ownership for customer management.
     */
    match /stores/{storeId}/customers/{customerId} {
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
    }

    /**
     * @description Defines the rules for currency rates within a store.
     * @path /stores/{storeId}/currency_rates/{currencyRateId}
     * @allow (create) - User 'abc' can create a currency rate in their store.
     * @allow (get) - User 'abc' can read a currency rate in their store.
     * @allow (update) - User 'abc' can update a currency rate in their store.
     * @allow (delete) - User 'abc' can delete a currency rate in their store.
     * @deny (create) - User 'def' cannot create a currency rate in store owned by user 'abc'.
     * @principle Enforces store ownership for currency rate management.
     */
    match /stores/{storeId}/currency_rates/{currencyRateId} {
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      allow delete: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
    }

      /**
       * @description Defines the rules for chats within a store.
       * @path /stores/{storeId}/chats/{chatId}
       * @allow (create) - User 'abc' can create a chat in their store if they are a participant.
       * @allow (get) - User 'abc' can read a chat in their store if they are a participant.
       * @allow (update) - User 'abc' can update a chat in their store if they are the owner.
       * @allow (delete) - User 'abc' can delete a chat in their store if they are the owner.
       * @deny (create) - User 'def' cannot create a chat in store owned by user 'abc' if they are not a participant.
       * @principle Enforces store ownership and participant access for chat management.
       */
      match /stores/{storeId}/chats/{chatId} {
          allow create: if isSignedIn()
              && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
              && request.resource.data.participants.hasAny([request.auth.uid]);
          allow get: if isSignedIn()
              && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
              && resource.data.participants.hasAny([request.auth.uid]);
          allow list: if isSignedIn()
              && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
          allow update: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
          allow delete: if isExistingOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      }

      /**
       * @description Defines the rules for chat messages within a chat.
       * @path /stores/{storeId}/chats/{chatId}/messages/{messageId}
       * @allow (create) - User 'abc' can create a message in a chat if they are a participant.
       * @allow (get) - User 'abc' can read a message in a chat if they are a participant.
       * @allow (update) - User 'abc' cannot update a message.
       * @allow (delete) - User 'abc' cannot delete a message.
       * @deny (create) - User 'def' cannot create a message in a chat they are not part of.
       * @principle Enforces participant access for chat message management.
       */
      match /stores/{storeId}/chats/{chatId}/messages/{messageId} {
          allow create: if isSignedIn()
              && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
              && get(/databases/$(database)/documents/stores/$(storeId)/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
          allow get: if isSignedIn()
              && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
              && get(/databases/$(database)/documents/stores/$(storeId)/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
          allow list: if isSignedIn()
              && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
              && get(/databases/$(database)/documents/stores/$(storeId)/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
          allow update: if false;
          allow delete: if false;
      }
  }
}
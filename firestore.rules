/**
 * @file Overview
 * This ruleset enforces a multi-tenant data model, where most data is scoped to a specific `storeId`.
 * Each store has an owner, and this owner has broad access to manage the store's data.
 * User profiles are managed under the `/users/{userId}` path, with the 'uid' field being authoritative for identity.
 *
 * Data Structure:
 * - /stores/{storeId}: Stores configuration and settings for a business.
 * - /users/{userId}: Stores user profile information.
 * - /products/{productId}: Stores product information, scoped by `storeId`.
 * - /inventory_movements/{movementId}: Tracks inventory changes, scoped by `storeId`.
 * - /sales/{saleId}: Records sales transactions, scoped by `storeId`.
 * - /purchases/{purchaseId}: Manages purchase orders, scoped by `storeId`.
 * - /customers/{customerId}: Stores customer data, scoped by `storeId`.
 * - /suppliers/{supplierId}: Manages supplier information, scoped by `storeId`.
 * - /units/{unitId}: Stores units of measure, scoped by `storeId`.
 * - /families/{familyId}: Stores product categories, scoped by `storeId`.
 * - /warehouses/{warehouseId}: Manages warehouse locations, scoped by `storeId`.
 * - /ads/{adId}: Stores advertisement data (no storeId).
 * - /pendingOrders/{orderId}: Stores pending orders, scoped by `storeId`.
 * - /stores/{storeId}/currencyRates/{rateId}: Stores currency exchange rates for a store.
 *
 * Key Security Decisions:
 * - Strict ownership model for stores: Only the store owner can modify store settings.
 * - Data Isolation: Most data types are isolated to a specific store using the `storeId` field. Rules ensure that users can only access data associated with their store.
 * - User Profile Management: Users can only read and write their own profile data.
 * - No listing of all users: Listing users is not permitted to prevent information disclosure.
 * - Public Read for Ads: The 'ads' collection is publicly readable, with no storeId enforcement.
 * - Pending Orders can be viewed by anyone but only storeId can modify.
 *
 * Denormalization for Authorization:
 * - Documents like products, sales, and purchases include a `storeId` field. This denormalization allows rules to quickly check if the requesting user has access to the store associated with that document. This avoids the need for complex queries or additional reads to verify store ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     * @return {boolean} True if the UIDs match, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the store and the document exists.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     * @return {boolean} True if the UIDs match and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the store.
     * @param {string} storeId - The store ID to check against the resource's storeId.
     * @return {boolean} True if the user is the owner of the store, false otherwise.
     */
    function isStoreOwner(storeId) {
        return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /**
     * @description Checks if the authenticated user is the owner of the store and the document's storeId matches the provided storeId.
     * @param {string} storeId - The store ID to check against the resource's storeId.
     * @return {boolean} True if the user is the owner of the store and the storeId matches, false otherwise.
     */
    function isExistingStoreOwner(storeId) {
        return isStoreOwner(storeId) && resource != null;
    }

    /**
     * @description Rules for the /stores collection.
     * @path /stores/{storeId}
     * @allow (create) - Authenticated user can create a store if the ownerId matches their UID.
     * @allow (update) - Authenticated user can update a store only if they are the owner.
     * @allow (delete) - Authenticated user can delete a store only if they are the owner.
     * @deny (create) - User attempts to create a store with an ownerId that doesn't match their UID.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId} {
      allow get: if true;
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingStoreOwner(storeId);
      allow delete: if isExistingStoreOwner(storeId);
    }

    /**
     * @description Rules for the /users collection (user profiles).
     * @path /users/{userId}
     * @allow (get) - Authenticated user can read their own profile data.
     * @allow (create) - Authenticated user can create their own profile data if the UID matches.
     * @allow (update) - Authenticated user can update their own profile data.
     * @allow (delete) - Authenticated user can delete their own profile data.
     * @deny (create) - User attempts to create a profile with a UID that doesn't match their own.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;

      allow create: if isOwner(userId) && request.resource.data.uid == request.auth.uid;
      allow update: if isExistingOwner(userId) && request.resource.data.uid == resource.data.uid;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the /products collection.
     * @path /products/{productId}
     * @allow (get) - Any user can read product data.
     * @allow (create) - Authenticated user can create a product if they are the owner of the store specified in storeId.
     * @allow (update) - Authenticated user can update a product if they are the owner of the store specified in storeId.
     * @allow (delete) - Authenticated user can delete a product if they are the owner of the store specified in storeId.
     * @deny (create) - User attempts to create a product for a store they don't own.
     * @principle Enforces store-level ownership for product data.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for the /inventory_movements collection.
     * @path /inventory_movements/{movementId}
     * @allow (get) - Any user can read inventory movement data.
     * @allow (create) - Authenticated user can create an inventory movement if they are the owner of the store specified in storeId.
     * @allow (update) - Authenticated user can update an inventory movement if they are the owner of the store specified in storeId.
     * @allow (delete) - Authenticated user can delete an inventory movement if they are the owner of the store specified in storeId.
     * @deny (create) - User attempts to create an inventory movement for a store they don't own.
     * @principle Enforces store-level ownership for inventory movement data.
     */
    match /inventory_movements/{movementId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for the /sales collection.
     * @path /sales/{saleId}
     * @allow (get) - Any user can read sale data.
     * @allow (create) - Authenticated user can create a sale if they are the owner of the store specified in storeId.
     * @allow (update) - Authenticated user can update a sale if they are the owner of the store specified in storeId.
     * @allow (delete) - Authenticated user can delete a sale if they are the owner of the store specified in storeId.
     * @deny (create) - User attempts to create a sale for a store they don't own.
     * @principle Enforces store-level ownership for sales data.
     */
    match /sales/{saleId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for the /purchases collection.
     * @path /purchases/{purchaseId}
     * @allow (get) - Any user can read purchase data.
     * @allow (create) - Authenticated user can create a purchase if they are the owner of the store specified in storeId.
     * @allow (update) - Authenticated user can update a purchase if they are the owner of the store specified in storeId.
     * @allow (delete) - Authenticated user can delete a purchase if they are the owner of the store specified in storeId.
     * @deny (create) - User attempts to create a purchase for a store they don't own.
     * @principle Enforces store-level ownership for purchase data.
     */
    match /purchases/{purchaseId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for the /customers collection.
     * @path /customers/{customerId}
     * @allow (get) - Any user can read customer data.
     * @allow (create) - Authenticated user can create a customer if they are the owner of the store specified in storeId.
     * @allow (update) - Authenticated user can update a customer if they are the owner of the store specified in storeId.
     * @allow (delete) - Authenticated user can delete a customer if they are the owner of the store specified in storeId.
     * @deny (create) - User attempts to create a customer for a store they don't own.
     * @principle Enforces store-level ownership for customer data.
     */
    match /customers/{customerId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for the /suppliers collection.
     * @path /suppliers/{supplierId}
     * @allow (get) - Any user can read supplier data.
     * @allow (create) - Authenticated user can create a supplier if they are the owner of the store specified in storeId.
     * @allow (update) - Authenticated user can update a supplier if they are the owner of the store specified in storeId.
     * @allow (delete) - Authenticated user can delete a supplier if they are the owner of the store specified in storeId.
     * @deny (create) - User attempts to create a supplier for a store they don't own.
     * @principle Enforces store-level ownership for supplier data.
     */
    match /suppliers/{supplierId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for the /units collection.
     * @path /units/{unitId}
     * @allow (get) - Any user can read unit data.
     * @allow (create) - Authenticated user can create a unit if they are the owner of the store specified in storeId.
     * @allow (update) - Authenticated user can update a unit if they are the owner of the store specified in storeId.
     * @allow (delete) - Authenticated user can delete a unit if they are the owner of the store specified in storeId.
     * @deny (create) - User attempts to create a unit for a store they don't own.
     * @principle Enforces store-level ownership for unit data.
     */
    match /units/{unitId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for the /families collection.
     * @path /families/{familyId}
     * @allow (get) - Any user can read family data.
     * @allow (create) - Authenticated user can create a family if they are the owner of the store specified in storeId.
     * @allow (update) - Authenticated user can update a family if they are the owner of the store specified in storeId.
     * @allow (delete) - Authenticated user can delete a family if they are the owner of the store specified in storeId.
     * @deny (create) - User attempts to create a family for a store they don't own.
     * @principle Enforces store-level ownership for family data.
     */
    match /families/{familyId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for the /warehouses collection.
     * @path /warehouses/{warehouseId}
     * @allow (get) - Any user can read warehouse data.
     * @allow (create) - Authenticated user can create a warehouse if they are the owner of the store specified in storeId.
     * @allow (update) - Authenticated user can update a warehouse if they are the owner of the store specified in storeId.
     * @allow (delete) - Authenticated user can delete a warehouse if they are the owner of the store specified in storeId.
     * @deny (create) - User attempts to create a warehouse for a store they don't own.
     * @principle Enforces store-level ownership for warehouse data.
     */
    match /warehouses/{warehouseId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for the /ads collection.
     * @path /ads/{adId}
     * @allow (get) - Any user can read ad data.
     * @allow (create) - Only authenticated users can create ads.
     * @allow (update) - Only authenticated users can update ads.
     * @allow (delete) - Only authenticated users can delete ads.
     * @principle Allows public read access but restricts write access to authenticated users.
     */
    match /ads/{adId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Rules for the /pendingOrders collection.
     * @path /pendingOrders/{orderId}
     * @allow (get) - Any user can read pending order data.
     * @allow (create) - Authenticated user can create a pending order if they are the owner of the store specified in storeId.
     * @allow (update) - Authenticated user can update a pending order if they are the owner of the store specified in storeId.
     * @allow (delete) - Authenticated user can delete a pending order if they are the owner of the store specified in storeId.
     * @deny (create) - User attempts to create a pending order for a store they don't own.
     */
    match /pendingOrders/{orderId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for the /stores/{storeId}/currencyRates collection.
     * @path /stores/{storeId}/currencyRates/{rateId}
     * @allow (get) - Any user can read currency rate data.
     * @allow (create) - Authenticated user can create a currency rate if they are the owner of the store specified in storeId.
     * @allow (update) - Authenticated user can update a currency rate if they are the owner of the store specified in storeId.
     * @allow (delete) - Authenticated user can delete a currency rate if they are the owner of the store specified in storeId.
     * @deny (create) - User attempts to create a currency rate for a store they don't own.
     * @principle Enforces store-level ownership for currency rate data.
     */
    match /stores/{storeId}/currencyRates/{rateId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isStoreOwner(storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(storeId);
    }
  }
}
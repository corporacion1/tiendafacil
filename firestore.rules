/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a multi-tenant data model where most data is scoped to a specific `storeId`.
 * Users can only access data belonging to stores they are associated with, based on the `ownerId`
 * field in the `/stores/{storeId}` document or the `storeId` field in the `/users/{userId}` document.
 *
 * Data Structure:
 * - `/stores/{storeId}`: Contains store-specific configuration and metadata.
 * - `/users/{userId}`: Contains user profile information, including their associated `storeId`.
 * - All other collections (e.g., `/products`, `/sales`) are top-level and MUST contain a `storeId`
 *   field to enforce multi-tenancy.
 *
 * Key Security Decisions:
 * - Listing of users (`/users`) is disallowed for security.
 * - The `ownerId` field in the `/stores/{storeId}` document is immutable and can only be set on creation.
 * - Rules are designed to be permissive on data shapes during this prototyping phase but strictly
 *   enforce authorization.
 * - Enforces the separation of data between different stores.
 * - Denormalizes the storeId to all documents for simpler security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @path N/A
     * @allow N/A
     * @deny N/A
     * @principle Authentication is required for nearly all operations.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the owner of the store.
     * @path /stores/{storeId}
     * @allow (get) User with UID 'user123' reading a store document they own.
     * @deny (get) User with UID 'user456' reading a store document they do not own.
     * @principle Enforces store ownership for data access.
     */
    function isStoreOwner(storeId) {
        return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /**
     * @description Checks if the user's storeId claim matches the resource's storeId.
     * @path /products/{productId}
     * @allow (create) Creating a product with a storeId that matches the user's storeId.
     * @deny (create) Creating a product with a storeId that does not match the user's storeId.
     * @principle Enforces that data belongs to the user's store.
     */
    function isStoreResource(storeId) {
      return isSignedIn() && storeId == request.auth.uid;
    }

    /**
     * @description Checks if the user is the owner of the resource.
     * @path N/A
     * @allow N/A
     * @deny N/A
     * @principle Enforces resource ownership for write operations.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the existing owner of the resource (for update/delete).
     * @path N/A
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Stores product information.
     * @path /products/{productId}
     * @allow (create) User with storeId 'store123' creating a product with storeId 'store123'.
     * @deny (create) User with storeId 'store123' creating a product with storeId 'store456'.
     * @principle Enforces store ownership and validates relational integrity.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId;
      allow update: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores inventory movement records.
     * @path /inventory_movements/{movementId}
     * @allow (create) User with storeId 'store123' creating an inventory movement with storeId 'store123'.
     * @deny (create) User with storeId 'store123' creating an inventory movement with storeId 'store456'.
     * @principle Enforces store ownership and validates relational integrity.
     */
    match /inventory_movements/{movementId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId;
      allow update: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores sales transaction records.
     * @path /sales/{saleId}
     * @allow (create) User with storeId 'store123' creating a sale with storeId 'store123'.
     * @deny (create) User with storeId 'store123' creating a sale with storeId 'store456'.
     * @principle Enforces store ownership and validates relational integrity.
     */
    match /sales/{saleId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId;
      allow update: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores purchase order records.
     * @path /purchases/{purchaseId}
     * @allow (create) User with storeId 'store123' creating a purchase with storeId 'store123'.
     * @deny (create) User with storeId 'store123' creating a purchase with storeId 'store456'.
     * @principle Enforces store ownership and validates relational integrity.
     */
    match /purchases/{purchaseId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId;
      allow update: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores customer information.
     * @path /customers/{customerId}
     * @allow (create) User with storeId 'store123' creating a customer with storeId 'store123'.
     * @deny (create) User with storeId 'store123' creating a customer with storeId 'store456'.
     * @principle Enforces store ownership and validates relational integrity.
     */
    match /customers/{customerId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId;
      allow update: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores supplier information.
     * @path /suppliers/{supplierId}
     * @allow (create) User with storeId 'store123' creating a supplier with storeId 'store123'.
     * @deny (create) User with storeId 'store123' creating a supplier with storeId 'store456'.
     * @principle Enforces store ownership and validates relational integrity.
     */
    match /suppliers/{supplierId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId;
      allow update: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores units of measure.
     * @path /units/{unitId}
     * @allow (create) User with storeId 'store123' creating a unit with storeId 'store123'.
     * @deny (create) User with storeId 'store123' creating a unit with storeId 'store456'.
     * @principle Enforces store ownership and validates relational integrity.
     */
    match /units/{unitId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId;
      allow update: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores product families/categories.
     * @path /families/{familyId}
     * @allow (create) User with storeId 'store123' creating a family with storeId 'store123'.
     * @deny (create) User with storeId 'store123' creating a family with storeId 'store456'.
     * @principle Enforces store ownership and validates relational integrity.
     */
    match /families/{familyId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId;
      allow update: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores warehouse information.
     * @path /warehouses/{warehouseId}
     * @allow (create) User with storeId 'store123' creating a warehouse with storeId 'store123'.
     * @deny (create) User with storeId 'store123' creating a warehouse with storeId 'store456'.
     * @principle Enforces store ownership and validates relational integrity.
     */
    match /warehouses/{warehouseId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId;
      allow update: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores application configuration settings for each store.
     * @path /stores/{storeId}
     * @allow (create) User with UID 'user123' creating a store document with ownerId 'user123'.
     * @deny (create) User with UID 'user456' creating a store document with ownerId 'user123'.
     * @principle Enforces store ownership and restricts store management to the owner.
     */
    match /stores/{storeId} {
      allow get: if isStoreOwner(storeId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      allow update: if isStoreOwner(storeId);
      allow delete: if isStoreOwner(storeId);
    }

    /**
     * @description Stores user profiles.
     * @path /users/{userId}
     * @allow (create) User with UID 'user123' creating their own user profile.
     * @deny (create) User with UID 'user456' attempting to create a profile for 'user123'.
     * @principle Enforces user-ownership and prevents unauthorized profile creation.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    /**
     * @description Stores marketing advertisements.
     * @path /ads/{adId}
     * @allow (create) Any authenticated user can create an ad.
     * @deny (create) Unauthenticated users cannot create ads.
     * @principle Allows any signed-in user to create, read, and modify ads.
     */
    match /ads/{adId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Stores orders from the public catalog.
     * @path /pendingOrders/{orderId}
     * @allow (create) Any authenticated user can create a pending order.
     * @deny (create) Unauthenticated users cannot create pending orders.
     */
    match /pendingOrders/{orderId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Stores historical currency exchange rates for a specific store.
     * @path /stores/{storeId}/currencyRates/{rateId}
     * @allow (read, list) Store owner can access its currency rates
     * @deny (write) No one can write in currency rates, only read.
     */
    match /stores/{storeId}/currencyRates/{rateId} {
      allow get: if isStoreOwner(storeId);
      allow list: if isStoreOwner(storeId);
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a security model based on data segregation and path-based authorization.
 * All collections are secured using distinct strategies tailored to their specific data and access patterns.
 *
 * Data Structure:
 * - Top-level collections: /products, /inventoryMovements, /sales, /purchases, /customers, /suppliers, /taxTypes, /configuration.
 * - Subcollections: /sales/{saleId}/saleItems, /purchases/{purchaseId}/purchaseItems.
 *
 * Key Security Decisions:
 * - No blanket read/write access: All rules explicitly define who can access what data.
 * - Write operations require authentication: Only signed-in users can create, update, or delete data.
 * - List operations follow the principle of least privilege. No public listing is enabled.
 * - Helper functions encapsulate complex logic for improved readability and maintainability.
 * - Data validation is limited to ensuring data consistency and relational integrity.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the /products collection.
     * @path /products/{productId}
     * @allow (get, list): Any authenticated user can read product information.
     * @allow (create, update, delete): Only authenticated users can manage products.
     * @deny (create, update, delete): An unauthenticated user attempts to modify product data.
     * @principle Requires authentication for all writes.
     */
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Controls access to the /inventoryMovements collection.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (get, list): Any authenticated user can read inventory movement records.
     * @allow (create, update, delete): Only authenticated users can manage inventory movements.
     * @deny (create, update, delete): An unauthenticated user attempts to modify inventory movement data.
     * @principle Requires authentication for all writes.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Controls access to the /sales collection.
     * @path /sales/{saleId}
     * @allow (get, list): Any authenticated user can read sales transactions.
     * @allow (create, update, delete): Only authenticated users can manage sales transactions.
     * @deny (create, update, delete): An unauthenticated user attempts to modify sale data.
     * @principle Requires authentication for all writes.
     */
    match /sales/{saleId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();

      /**
       * @description Controls access to the /sales/{saleId}/saleItems subcollection.
       * @path /sales/{saleId}/saleItems/{saleItemId}
       * @allow (get, list): Any authenticated user can read sale items.
       * @allow (create, update, delete): Only authenticated users can manage sale items.
       * @deny (create, update, delete): An unauthenticated user attempts to modify sale item data.
       * @principle Requires authentication for all writes.
       */
      match /saleItems/{saleItemId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }
    }

    /**
     * @description Controls access to the /purchases collection.
     * @path /purchases/{purchaseId}
     * @allow (get, list): Any authenticated user can read purchase transactions.
     * @allow (create, update, delete): Only authenticated users can manage purchase transactions.
     * @deny (create, update, delete): An unauthenticated user attempts to modify purchase data.
     * @principle Requires authentication for all writes.
     */
    match /purchases/{purchaseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();

      /**
       * @description Controls access to the /purchases/{purchaseId}/purchaseItems subcollection.
       * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
       * @allow (get, list): Any authenticated user can read purchase items.
       * @allow (create, update, delete): Only authenticated users can manage purchase items.
       * @deny (create, update, delete): An unauthenticated user attempts to modify purchase item data.
       * @principle Requires authentication for all writes.
       */
      match /purchaseItems/{purchaseItemId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }
    }

    /**
     * @description Controls access to the /customers collection.
     * @path /customers/{customerId}
     * @allow (get, list): Any authenticated user can read customer information.
     * @allow (create, update, delete): Only authenticated users can manage customers.
     * @deny (create, update, delete): An unauthenticated user attempts to modify customer data.
     * @principle Requires authentication for all writes.
     */
    match /customers/{customerId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Controls access to the /suppliers collection.
     * @path /suppliers/{supplierId}
     * @allow (get, list): Any authenticated user can read supplier information.
     * @allow (create, update, delete): Only authenticated users can manage suppliers.
     * @deny (create, update, delete): An unauthenticated user attempts to modify supplier data.
     * @principle Requires authentication for all writes.
     */
    match /suppliers/{supplierId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Controls access to the /taxTypes collection.
     * @path /taxTypes/{taxTypeId}
     * @allow (get, list): Any authenticated user can read tax type information.
     * @allow (create, update, delete): Only authenticated users can manage tax types.
     * @deny (create, update, delete): An unauthenticated user attempts to modify tax type data.
     * @principle Requires authentication for all writes.
     */
    match /taxTypes/{taxTypeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Controls access to the /configuration collection.
     * @path /configuration/{configurationId}
     * @allow (get, list): Any authenticated user can read configuration information.
     * @allow (create, update, delete): Only authenticated users can manage configuration.
     * @deny (create, update, delete): An unauthenticated user attempts to modify configuration data.
     * @principle Requires authentication for all writes.
     */
    match /configuration/{configurationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

  }

  /**
   * @description Checks if the user is signed in.
   * @return {boolean} True if the user is signed in, false otherwise.
   */
  function isSignedIn() {
    return request.auth != null;
  }
}
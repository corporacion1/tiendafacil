/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a multi-tenant data model where most top-level collections
 * are shared globally between users. Access is primarily controlled by the `storeId` field
 * present in most documents, ensuring that users can only manage data associated with
 * their specific store. User profiles are secured under their respective user IDs.
 *
 * Data Structure:
 * - /stores/{storeId}: Stores settings and configurations for each store.
 * - /{products, sales, purchases, customers, suppliers, units, families, warehouses}:
 *   Global collections with documents containing a `storeId` field to scope access.
 * - /ads: A global collection for advertisements, potentially with public read access.
 * - /cashSessions: A global collection for cash register sessions.
 * - /users/{userId}: Stores user profiles.
 *
 * Key Security Decisions:
 * - List operations on the global collections are generally disallowed to prevent
 *   unnecessary data exposure. Access is intended to be managed via direct `get`
 *   requests for specific documents.
 * - User listing is disallowed.
 * - All write operations (create, update, delete) require a valid `storeId` and
 *   ownership/association validation.
 *
 * Denormalization for Authorization:
 * - The `storeId` field is present in most entities to allow for efficient filtering
 *   and authorization. This avoids the need for complex queries or joins in the
 *   security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants owner-only access to store settings.
     * @path /stores/{storeId}
     * @allow (get) User with UID matching storeId can read the store settings.
     * @deny (get) User with UID not matching storeId cannot read the store settings.
     * @allow (create, update, delete) User with UID matching storeId can manage the store settings.
     * @deny (create, update, delete) User with UID not matching storeId cannot manage the store settings.
     * @principle Enforces document ownership for all operations.
     */
    match /stores/{storeId} {
      allow get: if isSignedIn() && isOwner(storeId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(storeId);
      allow update: if isSignedIn() && isExistingOwner(storeId);
      allow delete: if isSignedIn() && isExistingOwner(storeId);
    }

    /**
     * @description Restricts access to the products collection to owner-only writes.
     * @path /products
     * @allow (get, list) No direct read or list access to products collection.
     * @deny (get, list) All attempts to directly read or list products.
     * @allow (create) User can create a product if the storeId matches their user ID.
     * @deny (create) User cannot create a product if the storeId does not match their user ID.
     * @allow (update, delete) User can update/delete a product if the storeId matches their user ID.
     * @deny (update, delete) User cannot update/delete a product if the storeId does not match their user ID.
     * @principle Enforces document ownership for writes.
     */
    match /products/{productId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.storeId);
    }

    /**
     * @description Restricts access to the sales collection to owner-only writes.
     * @path /sales
     * @allow (get, list) No direct read or list access to sales collection.
     * @deny (get, list) All attempts to directly read or list sales.
     * @allow (create) User can create a sale if the storeId matches their user ID.
     * @deny (create) User cannot create a sale if the storeId does not match their user ID.
     * @allow (update, delete) User can update/delete a sale if the storeId matches their user ID.
     * @deny (update, delete) User cannot update/delete a sale if the storeId does not match their user ID.
     * @principle Enforces document ownership for writes.
     */
    match /sales/{saleId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.storeId);
    }

    /**
     * @description Restricts access to the purchases collection to owner-only writes.
     * @path /purchases
     * @allow (get, list) No direct read or list access to purchases collection.
     * @deny (get, list) All attempts to directly read or list purchases.
     * @allow (create) User can create a purchase if the storeId matches their user ID.
     * @deny (create) User cannot create a purchase if the storeId does not match their user ID.
     * @allow (update, delete) User can update/delete a purchase if the storeId matches their user ID.
     * @deny (update, delete) User cannot update/delete a purchase if the storeId does not match their user ID.
     * @principle Enforces document ownership for writes.
     */
    match /purchases/{purchaseId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.storeId);
    }

    /**
     * @description Restricts access to the customers collection to owner-only writes.
     * @path /customers
     * @allow (get, list) No direct read or list access to customers collection.
     * @deny (get, list) All attempts to directly read or list customers.
     * @allow (create) User can create a customer if the storeId matches their user ID.
     * @deny (create) User cannot create a customer if the storeId does not match their user ID.
     * @allow (update, delete) User can update/delete a customer if the storeId matches their user ID.
     * @deny (update, delete) User cannot update/delete a customer if the storeId does not match their user ID.
     * @principle Enforces document ownership for writes.
     */
    match /customers/{customerId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.storeId);
    }

    /**
     * @description Restricts access to the suppliers collection to owner-only writes.
     * @path /suppliers
     * @allow (get, list) No direct read or list access to suppliers collection.
     * @deny (get, list) All attempts to directly read or list suppliers.
     * @allow (create) User can create a supplier if the storeId matches their user ID.
     * @deny (create) User cannot create a supplier if the storeId does not match their user ID.
     * @allow (update, delete) User can update/delete a supplier if the storeId matches their user ID.
     * @deny (update, delete) User cannot update/delete a supplier if the storeId does not match their user ID.
     * @principle Enforces document ownership for writes.
     */
    match /suppliers/{supplierId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.storeId);
    }

    /**
     * @description Restricts access to the units collection to owner-only writes.
     * @path /units
     * @allow (get, list) No direct read or list access to units collection.
     * @deny (get, list) All attempts to directly read or list units.
     * @allow (create) User can create a unit if the storeId matches their user ID.
     * @deny (create) User cannot create a unit if the storeId does not match their user ID.
     * @allow (update, delete) User can update/delete a unit if the storeId matches their user ID.
     * @deny (update, delete) User cannot update/delete a unit if the storeId does not match their user ID.
     * @principle Enforces document ownership for writes.
     */
    match /units/{unitId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.storeId);
    }

    /**
     * @description Restricts access to the families collection to owner-only writes.
     * @path /families
     * @allow (get, list) No direct read or list access to families collection.
     * @deny (get, list) All attempts to directly read or list families.
     * @allow (create) User can create a family if the storeId matches their user ID.
     * @deny (create) User cannot create a family if the storeId does not match their user ID.
     * @allow (update, delete) User can update/delete a family if the storeId matches their user ID.
     * @deny (update, delete) User cannot update/delete a family if the storeId does not match their user ID.
     * @principle Enforces document ownership for writes.
     */
    match /families/{familyId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.storeId);
    }

    /**
     * @description Restricts access to the warehouses collection to owner-only writes.
     * @path /warehouses
     * @allow (get, list) No direct read or list access to warehouses collection.
     * @deny (get, list) All attempts to directly read or list warehouses.
     * @allow (create) User can create a warehouse if the storeId matches their user ID.
     * @deny (create) User cannot create a warehouse if the storeId does not match their user ID.
     * @allow (update, delete) User can update/delete a warehouse if the storeId matches their user ID.
     * @deny (update, delete) User cannot update/delete a warehouse if the storeId does not match their user ID.
     * @principle Enforces document ownership for writes.
     */
    match /warehouses/{warehouseId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.storeId);
    }

    /**
     * @description Allows public read access to ads, but restricts writes.
     * @path /ads
     * @allow (get, list) Public read access for all users.
     * @deny (create, update, delete) No write access for users. // TODO: Add owner validation once the schema is updated with an ownership field.
     * @principle Public read with owner-only writes.
     */
    match /ads/{adId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Restricts access to the cashSessions collection.
     * @path /cashSessions
     * @allow (get, list) No direct read or list access to cashSessions collection.
     * @deny (get, list) All attempts to directly read or list cashSessions.
     * @allow (create, update, delete) No write access for users.
     * @principle Enforces document ownership for writes.
     */
    match /cashSessions/{cashSessionId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants owner-only access to user profiles.
     * @path /users/{userId}
     * @allow (get) User with UID matching userId can read their own profile.
     * @deny (get) User with UID not matching userId cannot read the profile.
     * @allow (create) User with UID matching userId can create their own profile.
     * @deny (create) User with UID not matching userId cannot create the profile.
     * @allow (update, delete) User with UID matching userId can manage their own profile.
     * @deny (update, delete) User with UID not matching userId cannot manage the profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
    return isSignedIn() && isOwner(userId) && resource != null;
  }
}
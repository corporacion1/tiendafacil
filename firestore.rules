/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a multi-tenant data model where most collections are shared globally but access is controlled by a 'storeId' field on each document. Only authenticated users can access data.
 *
 * Data Structure:
 * - /stores/{storeId}: Stores settings for each business.
 * - /products: Products available in the system, each associated with a store via 'storeId'.
 * - /sales: Sales records, each associated with a store via 'storeId'.
 * - /purchases: Purchase records, each associated with a store via 'storeId'.
 * - /customers: Customer records, each associated with a store via 'storeId'.
 * - /suppliers: Supplier records, each associated with a store via 'storeId'.
 * - /units: Measurement units, each associated with a store via 'storeId'.
 * - /families: Product families, each associated with a store via 'storeId'.
 * - /warehouses: Warehouse locations, each associated with a store via 'storeId'.
 * - /ads: Advertisements available in the system. Public read, owner writes.
 * - /cashSessions: Cash register sessions.
 * - /users/{userId}: Public user profiles.
 *
 * Key Security Decisions:
 * - All collections except /ads and /users/{userId} require a 'storeId' for access control.
 * - Global listing of documents is disallowed to prevent data leakage across stores. Reads and writes are restricted to authenticated users and validated based on the 'storeId' field.
 * - The /ads collection allows public reads but restricts writes to owners (determined by a denormalized 'ownerId' field on the document).
 * - The /users/{userId} collection enforces strict user-ownership.
 *
 * Denormalization for Authorization:
 * - All store-specific collections require the `storeId` field on each document.
 *   This allows rules to quickly validate that the user has access to a specific store's data.
 *   Example: `allow read: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest()`
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to store settings.
     * @path /stores/{storeId}
     * @allow (get) Authenticated user accessing a specific store's settings.
     * @deny (create) Unauthorized user attempting to create store settings.
     * @principle Enforces store-level access control.
     */
    match /stores/{storeId} {
      allow get: if isSignedIn() && request.auth.uid == storeId;
      allow list: if false;
      allow create: if false;
      allow update: if isSignedIn() && request.auth.uid == storeId;
      allow delete: if isSignedIn() && request.auth.uid == storeId;
    }

    /**
     * @description Controls access to products.
     * @path /products/{productId}
     * @allow (create) Authenticated user creating a product with a valid storeId.
     * @deny (update) Unauthorized user attempting to modify a product in a different store.
     * @principle Enforces store-level access control.
     */
    match /products/{productId} {
      allow get: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
      allow update: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
    }

    /**
     * @description Controls access to sales records.
     * @path /sales/{saleId}
     * @allow (create) Authenticated user creating a sale record with a valid storeId.
     * @deny (update) Unauthorized user attempting to modify a sale record in a different store.
     * @principle Enforces store-level access control.
     */
    match /sales/{saleId} {
      allow get: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
      allow update: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
    }

    /**
     * @description Controls access to purchase records.
     * @path /purchases/{purchaseId}
     * @allow (create) Authenticated user creating a purchase record with a valid storeId.
     * @deny (update) Unauthorized user attempting to modify a purchase record in a different store.
     * @principle Enforces store-level access control.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
          allow update: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
    }

    /**
     * @description Controls access to customer records.
     * @path /customers/{customerId}
     * @allow (create) Authenticated user creating a customer record with a valid storeId.
     * @deny (update) Unauthorized user attempting to modify a customer record in a different store.
     * @principle Enforces store-level access control.
     */
    match /customers/{customerId} {
      allow get: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
         allow update: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
    }

    /**
     * @description Controls access to supplier records.
     * @path /suppliers/{supplierId}
     * @allow (create) Authenticated user creating a supplier record with a valid storeId.
     * @deny (update) Unauthorized user attempting to modify a supplier record in a different store.
     * @principle Enforces store-level access control.
     */
    match /suppliers/{supplierId} {
      allow get: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
      allow update: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
    }

        /**
     * @description Controls access to units records.
     * @path /units/{unitId}
     * @allow (create) Authenticated user creating a unit record with a valid storeId.
     * @deny (update) Unauthorized user attempting to modify a unit record in a different store.
     * @principle Enforces store-level access control.
     */
    match /units/{unitId} {
      allow get: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
      allow update: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
    }

    /**
     * @description Controls access to families records.
     * @path /families/{familyId}
     * @allow (create) Authenticated user creating a family record with a valid storeId.
     * @deny (update) Unauthorized user attempting to modify a family record in a different store.
     * @principle Enforces store-level access control.
     */
    match /families/{familyId} {
      allow get: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
      allow update: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
    }

    /**
     * @description Controls access to warehouses records.
     * @path /warehouses/{warehouseId}
     * @allow (create) Authenticated user creating a warehouse record with a valid storeId.
     * @deny (update) Unauthorized user attempting to modify a warehouse record in a different store.
     * @principle Enforces store-level access control.
     */
    match /warehouses/{warehouseId} {
      allow get: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
     allow update: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
    }

    /**
     * @description Controls access to advertisements.
     * @path /ads/{adId}
     * @allow (get, list) Public access to retrieve and list advertisements.
     * @deny (create, update, delete) Unauthorized user attempting to modify an ad.
     * @principle Public read access with owner-only writes, enforced by the presence of an 'ownerId' field.
     */
    match /ads/{adId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    /**
     * @description Controls access to cash sessions.
     * @path /cashSessions/{cashSessionId}
     */
    match /cashSessions/{cashSessionId} {
      allow get: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
       allow update: if isSignedIn() && request.resource.data.storeId == getStoreIdFromRequest();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreIdFromRequest();
    }

    /**
     * @description Controls access to user profiles.
     * @path /users/{userId}
     * @allow (create) User creating their own profile.
     * @deny (update, delete) Unauthorized user attempting to modify or delete another user's profile.
     * @principle Enforces strict user-ownership for profiles.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }
  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function getStoreIdFromRequest() {
      return request.auth.uid;
  }
}
/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a store-ownership model, where most data is scoped to a specific store.
 *   Users can only access data belonging to a store if they are the owner of that store.
 *   User profiles are secured such that only the user can read/write their own profile.
 *   Top level ads can be read by everyone.
 *
 * @data-structure
 *   - /products/{productId}: Products belonging to a store.
 *   - /inventory_movements/{movementId}: Inventory movements for products in a store.
 *   - /sales/{saleId}: Sales transactions for a store.
 *   - /purchases/{purchaseId}: Purchase orders for a store.
 *   - /customers/{customerId}: Customers of a store.
 *   - /suppliers/{supplierId}: Suppliers for a store.
 *   - /units/{unitId}: Units of measurement for a store.
 *   - /families/{familyId}: Product families/categories for a store.
 *   - /warehouses/{warehouseId}: Warehouses for a store.
 *   - /stores/{storeId}: Store configurations, owned by a user.
 *   - /users/{userId}: User profiles, accessible only by the user.
 *   - /ads/{adId}: Advertisements, publicly readable.
 *   - /pendingOrders/{orderId}: Orders awaiting processing, associated with a store.
 *   - /stores/{storeId}/currencyRates/{rateId}: Currency exchange rates for a specific store.
 *
 * @key-security-decisions
 *   - Users can only read/write data associated with their store.
 *   - Listing of user profiles is disallowed for privacy.
 *   - Advertisements are publicly readable but not writable via rules.
 *   - Store ownership is validated on store creation.
 *
 * @denormalization-for-authorization
 *   - Each document within a store's data tree MUST contain a `storeId` field.
 *   - The Store document MUST contain an `ownerId` field indicating the user who owns the store.
 *   - Products are associated with stores through the storeId field.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     * @path N/A
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the store.
     * @path N/A
     */
    function isStoreOwner(storeId) {
      return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /**
     * @description Checks if the authenticated user is the owner of the user profile.
     * @path N/A
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the existing owner of the document.
     * @path N/A
     */
    function isExistingOwner(ownerId) {
        return isOwner(ownerId) && resource != null;
    }

    /**
     * @description Products are associated with a specific store. Only the store owner can manage products.
     * @path /products/{productId}
     * @allow (create) User with UID 'user123' creates a new product with storeId matching a store owned by 'user123'.
     * @deny (create) User with UID 'user456' attempts to create a product for a store owned by 'user123'.
     * @principle Enforces store-ownership for product data.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId) && resource != null;
    }

    /**
     * @description Inventory movements are associated with a specific store. Only the store owner can manage inventory movements.
     * @path /inventory_movements/{movementId}
     * @allow (create) User with UID 'user123' creates a new inventory movement with storeId matching a store owned by 'user123'.
     * @deny (create) User with UID 'user456' attempts to create an inventory movement for a store owned by 'user123'.
     * @principle Enforces store-ownership for inventory movement data.
     */
    match /inventory_movements/{movementId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId) && resource != null;
    }

    /**
     * @description Sales transactions are associated with a specific store. Only the store owner can manage sales transactions.
     * @path /sales/{saleId}
     * @allow (create) User with UID 'user123' creates a new sale with storeId matching a store owned by 'user123'.
     * @deny (create) User with UID 'user456' attempts to create a sale for a store owned by 'user123'.
     * @principle Enforces store-ownership for sales transaction data.
     */
    match /sales/{saleId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId) && resource != null;
    }

    /**
     * @description Purchase orders are associated with a specific store. Only the store owner can manage purchase orders.
     * @path /purchases/{purchaseId}
     * @allow (create) User with UID 'user123' creates a new purchase with storeId matching a store owned by 'user123'.
     * @deny (create) User with UID 'user456' attempts to create a purchase for a store owned by 'user123'.
     * @principle Enforces store-ownership for purchase order data.
     */
    match /purchases/{purchaseId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId) && resource != null;
    }

    /**
     * @description Customers are associated with a specific store. Only the store owner can manage customer data.
     * @path /customers/{customerId}
     * @allow (create) User with UID 'user123' creates a new customer with storeId matching a store owned by 'user123'.
     * @deny (create) User with UID 'user456' attempts to create a customer for a store owned by 'user123'.
     * @principle Enforces store-ownership for customer data.
     */
    match /customers/{customerId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId) && resource != null;
    }

    /**
     * @description Suppliers are associated with a specific store. Only the store owner can manage supplier data.
     * @path /suppliers/{supplierId}
     * @allow (create) User with UID 'user123' creates a new supplier with storeId matching a store owned by 'user123'.
     * @deny (create) User with UID 'user456' attempts to create a supplier for a store owned by 'user123'.
     * @principle Enforces store-ownership for supplier data.
     */
    match /suppliers/{supplierId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId) && resource != null;
    }

    /**
     * @description Units are associated with a specific store. Only the store owner can manage unit data.
     * @path /units/{unitId}
     */
    match /units/{unitId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId) && resource != null;
    }

    /**
     * @description Families are associated with a specific store. Only the store owner can manage family data.
     * @path /families/{familyId}
     */
    match /families/{familyId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId) && resource != null;
    }

    /**
     * @description Warehouses are associated with a specific store. Only the store owner can manage warehouse data.
     * @path /warehouses/{warehouseId}
     */
    match /warehouses/{warehouseId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId) && resource != null;
    }

    /**
     * @description Stores are owned by a user. Only the owner can read/write the store configuration.
     * @path /stores/{storeId}
     * @allow (create) User with UID 'user123' creates a new store with ownerId set to 'user123'.
     * @deny (create) User with UID 'user456' attempts to create a store with ownerId set to 'user123'.
     * @principle Enforces ownership for store configuration data.
     */
    match /stores/{storeId} {
      allow get: if isSignedIn() && isStoreOwner(storeId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId && request.resource.data.id == storeId;
      allow update: if isSignedIn() && isStoreOwner(storeId) && resource != null;
      allow delete: if isSignedIn() && isStoreOwner(storeId) && resource != null;
    }

    /**
     * @description User profiles are private. Only the user can read/write their own profile.
     * @path /users/{userId}
     * @allow (create) User with UID 'user123' creates their own profile with UID 'user123'.
     * @deny (create) User with UID 'user456' attempts to create a profile for user 'user123'.
     * @principle Enforces user-ownership for profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update: if isExistingOwner(userId) && resource.data.uid == request.resource.data.uid;
      allow delete: if isExistingOwner(userId) && resource.data.uid == request.resource.data.uid;
    }

    /**
     * @description Ads are publicly readable but only manageable via backend services.
     * @path /ads/{adId}
     * @allow (get, list) Any user can read advertisements.
     * @deny (create, update, delete) No client-side writes allowed.
     * @principle Allows public read access to advertisements while restricting write access.
     */
    match /ads/{adId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Pending orders are associated with a specific store. Only the store owner can manage pending orders.
     * @path /pendingOrders/{orderId}
     * @allow (create) User with UID 'user123' creates a new pending order with storeId matching a store owned by 'user123'.
     * @deny (create) User with UID 'user456' attempts to create a pending order for a store owned by 'user123'.
     */
    match /pendingOrders/{orderId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId) && resource != null;
    }

    /**
     * @description Currency rates are associated with a specific store. Only the store owner can manage currency rates.
     * @path /stores/{storeId}/currencyRates/{rateId}
     */
    match /stores/{storeId}/currencyRates/{rateId} {
      allow get: if isSignedIn() && isStoreOwner(storeId);
      allow list: if isSignedIn() && isStoreOwner(storeId);
      allow create: if isSignedIn() && isStoreOwner(storeId);
      allow update: if isSignedIn() && isStoreOwner(storeId);
      allow delete: if isSignedIn() && isStoreOwner(storeId) && resource != null;
    }
  }
}
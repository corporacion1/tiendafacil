/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for most data,
 * with public read access for specific collections like Ads. It also segregates data
 * by store ID to ensure that users can only access data related to their store.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, accessible only to the user.
 * - /stores/{storeId}: Stores store configuration, accessible only to the store owner.
 * - /stores/{storeId}/currencyRates/{rateId}: Stores currency exchange rates for a specific store, accessible only to the store owner.
 * - Other top-level collections: Data is generally accessible only to authenticated users
 *   and often limited to specific stores based on the 'storeId' field in the document.
 * - /ads/{adId}: Public read, owner writes
 *
 * Key Security Decisions:
 * - User listing is disallowed for privacy.
 * - Read-only collections are not explicitly defined, but this could be added in future iterations.
 * - The default security posture is strict: if a relationship is ambiguous, access is denied.
 *
 * Denormalization for Authorization:
 * - Documents in collections like Products, Sales, and Purchases all have a `storeId` field. This allows rules to efficiently verify that the user has access to the store associated with the data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the existing owner of the document.
     * @details Combines ownership check with existence check to prevent accidental operations on non-existent documents.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rule set for user profiles.
     * @path /users/{userId}
     * @allow (create) User with UID 'user123' can create their profile at /users/user123.
     * @allow (get, update, delete) User with UID 'user123' can read, update, and delete their profile at /users/user123.
     * @deny (create) User with UID 'user123' cannot create a profile at /users/anotherUser.
     * @deny (get, update, delete) User with UID 'user123' cannot read, update, or delete the profile at /users/anotherUser.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rule set for stores.
     * @path /stores/{storeId}
     * @allow (create) User with UID 'user123' can create a store with storeId 'store456' if store.ownerId == user123.
     * @allow (get, update, delete) User with UID 'user123' can read, update, and delete store 'store456' if store.ownerId == user123.
     * @deny (create) User with UID 'user123' cannot create a store with storeId 'store456' if store.ownerId != user123.
     * @deny (get, update, delete) User with UID 'user123' cannot read, update, or delete store 'store456' if store.ownerId != user123.
     * @principle Enforces document ownership based on storeId and ownerId.
     */
    match /stores/{storeId} {
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Rule set for products.
     * @path /products/{productId}
     * @allow (create) Authenticated user can create a product with a valid storeId.
     * @allow (get, list, update, delete) Authenticated user can read, list, update and delete a product with a valid storeId.
     * @deny (create) Authenticated user can't create a product without a storeId or with a mismatched storeId.
     * @deny (update, delete) Authenticated user can't update/delete a product with a mismatched storeId.
     * @principle Protects product data by requiring a valid storeId and authenticate user.
     */
    match /products/{productId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId != null && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId != null && resource != null;
    }

    /**
     * @description Rule set for inventory movements.
     * @path /inventory_movements/{movementId}
     * @allow (create) Authenticated user can create an inventory movement with a valid storeId.
     * @allow (get, list, update, delete) Authenticated user can read, list, update and delete an inventory movement with a valid storeId.
     * @deny (create) Authenticated user can't create an inventory movement without a storeId or with a mismatched storeId.
     * @deny (update, delete) Authenticated user can't update/delete an inventory movement with a mismatched storeId.
     * @principle Protects inventory movement data by requiring a valid storeId and authenticate user.
     */
    match /inventory_movements/{movementId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId != null && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId != null && resource != null;
    }

    /**
     * @description Rule set for sales transactions.
     * @path /sales/{saleId}
     * @allow (create) Authenticated user can create a sale with a valid storeId.
     * @allow (get, list, update, delete) Authenticated user can read, list, update and delete a sale with a valid storeId.
     * @deny (create) Authenticated user can't create a sale without a storeId or with a mismatched storeId.
     * @deny (update, delete) Authenticated user can't update/delete a sale with a mismatched storeId.
     * @principle Protects sale transaction data by requiring a valid storeId and authenticate user.
     */
    match /sales/{saleId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId != null && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId != null && resource != null;
    }

    /**
     * @description Rule set for purchase orders.
     * @path /purchases/{purchaseId}
     * @allow (create) Authenticated user can create a purchase with a valid storeId.
     * @allow (get, list, update, delete) Authenticated user can read, list, update and delete a purchase with a valid storeId.
     * @deny (create) Authenticated user can't create a purchase without a storeId or with a mismatched storeId.
     * @deny (update, delete) Authenticated user can't update/delete a purchase with a mismatched storeId.
     * @principle Protects purchase order data by requiring a valid storeId and authenticate user.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId != null && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId != null && resource != null;
    }

    /**
     * @description Rule set for customers.
     * @path /customers/{customerId}
     * @allow (create) Authenticated user can create a customer with a valid storeId.
     * @allow (get, list, update, delete) Authenticated user can read, list, update and delete a customer with a valid storeId.
     * @deny (create) Authenticated user can't create a customer without a storeId or with a mismatched storeId.
     * @deny (update, delete) Authenticated user can't update/delete a customer with a mismatched storeId.
     * @principle Protects customer data by requiring a valid storeId and authenticate user.
     */
    match /customers/{customerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId != null && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId != null && resource != null;
    }

    /**
     * @description Rule set for suppliers.
     * @path /suppliers/{supplierId}
     * @allow (create) Authenticated user can create a supplier with a valid storeId.
     * @allow (get, list, update, delete) Authenticated user can read, list, update and delete a supplier with a valid storeId.
     * @deny (create) Authenticated user can't create a supplier without a storeId or with a mismatched storeId.
     * @deny (update, delete) Authenticated user can't update/delete a supplier with a mismatched storeId.
     * @principle Protects supplier data by requiring a valid storeId and authenticate user.
     */
    match /suppliers/{supplierId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId != null && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId != null && resource != null;
    }

    /**
     * @description Rule set for units of measure.
     * @path /units/{unitId}
     * @allow (create) Authenticated user can create a unit with a valid storeId.
     * @allow (get, list, update, delete) Authenticated user can read, list, update and delete a unit with a valid storeId.
     * @deny (create) Authenticated user can't create a unit without a storeId or with a mismatched storeId.
     * @deny (update, delete) Authenticated user can't update/delete a unit with a mismatched storeId.
     * @principle Protects unit data by requiring a valid storeId and authenticate user.
     */
    match /units/{unitId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId != null && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId != null && resource != null;
    }

    /**
     * @description Rule set for product families/categories.
     * @path /families/{familyId}
     * @allow (create) Authenticated user can create a family with a valid storeId.
     * @allow (get, list, update, delete) Authenticated user can read, list, update and delete a family with a valid storeId.
     * @deny (create) Authenticated user can't create a family without a storeId or with a mismatched storeId.
     * @deny (update, delete) Authenticated user can't update/delete a family with a mismatched storeId.
     * @principle Protects family data by requiring a valid storeId and authenticate user.
     */
    match /families/{familyId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId != null && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId != null && resource != null;
    }

    /**
     * @description Rule set for warehouses.
     * @path /warehouses/{warehouseId}
     * @allow (create) Authenticated user can create a warehouse with a valid storeId.
     * @allow (get, list, update, delete) Authenticated user can read, list, update and delete a warehouse with a valid storeId.
     * @deny (create) Authenticated user can't create a warehouse without a storeId or with a mismatched storeId.
     * @deny (update, delete) Authenticated user can't update/delete a warehouse with a mismatched storeId.
     * @principle Protects warehouse data by requiring a valid storeId and authenticate user.
     */
    match /warehouses/{warehouseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId != null && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId != null && resource != null;
    }

    /**
     * @description Rule set for ads.
     * @path /ads/{adId}
     * @allow (get, list) Any user can read ads.
     * @allow (create, update, delete) Only authenticated users can create, update, and delete ads.
     * @principle Allows public reads but restricts writes to authenticated users.
     */
    match /ads/{adId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Rule set for pending orders.
     * @path /pendingOrders/{orderId}
     * @allow (create) Any user can create a pending order.
     * @allow (get, list, update, delete) Only authenticated users can read, list, update and delete pending orders.
     * @principle Allows public creation of pending orders but restricts management to authenticated users.
     */
    match /pendingOrders/{orderId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if true;
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Rule set for currency rates within a specific store.
     * @path /stores/{storeId}/currencyRates/{rateId}
     * @allow (get, list) Only authenticated users can read or list currency rates.
     * @allow (create, update, delete) Only authenticated users can create, update or delete currency rates, the user should be the store owner.
     * @deny   (list) Unauthenticated users cannot list currency rates.
     * @principle Ensures only store owners can manage currency rates.
     */
    match /stores/{storeId}/currencyRates/{rateId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }
  }
}
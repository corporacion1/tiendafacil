/**
 * @fileoverview Firestore Security Rules for the Inventory Management App.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model, where each user has exclusive access to their store configurations, products, tax types, inventory movements, sales, purchases, and customers.
 *
 * Data Structure:
 * All data is nested under /users/{userId}/stores/{storeId}/..., ensuring that data is isolated to individual users and their stores.
 *
 * Key Security Decisions:
 * - Users can only access data associated with their own user ID and store ID, as determined by the document path.
 * - No listing of users or stores is allowed at the top level, preventing unauthorized data discovery.
 * - Write operations are strictly controlled using the `isOwner` helper function, ensuring that only the authenticated user can create, update, or delete resources within their designated path.
 * - Data validation is relaxed to allow for rapid prototyping, focusing primarily on authorization and relational integrity.
 *
 * Denormalization for Authorization:
 * The `StoreConfig` document does not need to store the `userId` because the path `/users/{userId}/stores/{storeId}/config` already enforces this relationship.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     * @param None
     * @return {boolean} True if the request is authenticated, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     * @param {string} userId The user ID to compare against the authenticated user's ID.
     * @return {boolean} True if the authenticated user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner and the resource exists.
     * @param {string} userId The user ID to compare against the authenticated user's ID.
     * @return {boolean} True if the authenticated user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces ownership for StoreConfig documents.
     * @path /users/{userId}/stores/{storeId}/config
     * @allow (create) User 'user123' can create a config document under their user and store.
     * @deny (create) User 'user456' cannot create a config document under user 'user123''s path.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/stores/{storeId}/config {
      allow get: if isOwner(userId);
      allow list: if false; // Listing store configs is not permitted

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces ownership for Product documents.
     * @path /users/{userId}/stores/{storeId}/products/{productId}
     * @allow (create) User 'user123' can create a product document under their user and store.
     * @deny (create) User 'user456' cannot create a product document under user 'user123''s path.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/stores/{storeId}/products/{productId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces ownership for TaxType documents.
     * @path /users/{userId}/stores/{storeId}/taxTypes/{taxTypeId}
     * @allow (create) User 'user123' can create a tax type document under their user and store.
     * @deny (create) User 'user456' cannot create a tax type document under user 'user123''s path.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/stores/{storeId}/taxTypes/{taxTypeId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces ownership for InventoryMovement documents.
     * @path /users/{userId}/stores/{storeId}/inventoryMovements/{inventoryMovementId}
     * @allow (create) User 'user123' can create an inventory movement document under their user and store.
     * @deny (create) User 'user456' cannot create an inventory movement document under user 'user123''s path.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/stores/{storeId}/inventoryMovements/{inventoryMovementId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces ownership for Sale documents.
     * @path /users/{userId}/stores/{storeId}/sales/{saleId}
     * @allow (create) User 'user123' can create a sale document under their user and store.
     * @deny (create) User 'user456' cannot create a sale document under user 'user123''s path.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/stores/{storeId}/sales/{saleId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces ownership for SaleItem documents.
     * @path /users/{userId}/stores/{storeId}/sales/{saleId}/saleItems/{saleItemId}
     * @allow (create) User 'user123' can create a sale item document under their user and store.
     * @deny (create) User 'user456' cannot create a sale item document under user 'user123''s path.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/stores/{storeId}/sales/{saleId}/saleItems/{saleItemId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces ownership for Purchase documents.
     * @path /users/{userId}/stores/{storeId}/purchases/{purchaseId}
     * @allow (create) User 'user123' can create a purchase document under their user and store.
     * @deny (create) User 'user456' cannot create a purchase document under user 'user123''s path.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/stores/{storeId}/purchases/{purchaseId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces ownership for PurchaseItem documents.
     * @path /users/{userId}/stores/{storeId}/purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     * @allow (create) User 'user123' can create a purchase item document under their user and store.
     * @deny (create) User 'user456' cannot create a purchase item document under user 'user123''s path.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/stores/{storeId}/purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces ownership for Customer documents.
     * @path /users/{userId}/stores/{storeId}/customers/{customerId}
     * @allow (create) User 'user123' can create a customer document under their user and store.
     * @deny (create) User 'user456' cannot create a customer document under user 'user123''s path.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/stores/{storeId}/customers/{customerId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}
/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a store-ownership model, where each document belongs to a specific store.
 * All top-level collections are global and require a `storeId` field for authorization.
 *
 * Data Structure:
 * - /stores/{storeId}: Stores settings for a given store.
 * - /products: Products belonging to a store (requires `storeId`).
 * - /sales: Sales records for a store (requires `storeId`).
 * - /purchases: Purchase orders for a store (requires `storeId`).
 * - /customers: Customer records for a store (requires `storeId`).
 * - /suppliers: Supplier records for a store (requires `storeId`).
 * - /units: Units of measure for a store (requires `storeId`).
 * - /families: Product families for a store (requires `storeId`).
 * - /warehouses: Warehouse locations for a store (requires `storeId`).
 * - /ads: Advertisements (no store-specific ownership implied).
 * - /cashSessions: Cash register sessions (no store-specific ownership implied).
 * - /users/{userId}: Public user profiles.
 *
 * Key Security Decisions:
 * - Listing of global collections is allowed.
 * - All write operations require authentication.
 * - Data validation is limited to authorization-critical fields (e.g., `storeId`).
 * - User listing is disallowed.
 *
 * Denormalization for Authorization:
 * - All store-specific documents MUST include a `storeId` field to simplify authorization checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows reading and writing of store settings only to authenticated users.
     * @path /stores/{storeId}
     * @allow (get, list) if true
     * @allow (create, update, delete) if isSignedIn()
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Requires authentication for write operations.
     */
    match /stores/{storeId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows reading and writing of products only if the storeId matches.
     * @path /products/{productId}
     * @allow (get, list) if true
     * @allow (create) if isSignedIn() && request.resource.data.storeId == storeId();
     * @allow (update, delete) if isSignedIn() && resource.data.storeId == storeId();
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Enforces store ownership for writes.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == storeId();
      allow update: if isSignedIn() && resource.data.storeId == storeId();
      allow delete: if isSignedIn() && resource.data.storeId == storeId();
    }

     /**
      * @description Allows reading and writing of sales records only if the storeId matches.
      * @path /sales/{saleId}
      * @allow (get, list) if true
      * @allow (create) if isSignedIn() && request.resource.data.storeId == storeId();
      * @allow (update, delete) if isSignedIn() && resource.data.storeId == storeId();
      * @deny (create, update, delete) if !isSignedIn()
      * @principle Enforces store ownership for writes.
      */
    match /sales/{saleId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == storeId();
      allow update: if isSignedIn() && resource.data.storeId == storeId();
      allow delete: if isSignedIn() && resource.data.storeId == storeId();
    }

    /**
     * @description Allows reading and writing of purchases only if the storeId matches.
     * @path /purchases/{purchaseId}
     * @allow (get, list) if true
     * @allow (create) if isSignedIn() && request.resource.data.storeId == storeId();
     * @allow (update, delete) if isSignedIn() && resource.data.storeId == storeId();
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Enforces store ownership for writes.
     */
    match /purchases/{purchaseId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == storeId();
      allow update: if isSignedIn() && resource.data.storeId == storeId();
      allow delete: if isSignedIn() && resource.data.storeId == storeId();
    }

    /**
     * @description Allows reading and writing of customers only if the storeId matches.
     * @path /customers/{customerId}
     * @allow (get, list) if true
     * @allow (create) if isSignedIn() && request.resource.data.storeId == storeId();
     * @allow (update, delete) if isSignedIn() && resource.data.storeId == storeId();
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Enforces store ownership for writes.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == storeId();
      allow update: if isSignedIn() && resource.data.storeId == storeId();
      allow delete: if isSignedIn() && resource.data.storeId == storeId();
    }

    /**
     * @description Allows reading and writing of suppliers only if the storeId matches.
     * @path /suppliers/{supplierId}
     * @allow (get, list) if true
     * @allow (create) if isSignedIn() && request.resource.data.storeId == storeId();
     * @allow (update, delete) if isSignedIn() && resource.data.storeId == storeId();
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Enforces store ownership for writes.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == storeId();
      allow update: if isSignedIn() && resource.data.storeId == storeId();
      allow delete: if isSignedIn() && resource.data.storeId == storeId();
    }

    /**
     * @description Allows reading and writing of units only if the storeId matches.
     * @path /units/{unitId}
     * @allow (get, list) if true
     * @allow (create) if isSignedIn() && request.resource.data.storeId == storeId();
     * @allow (update, delete) if isSignedIn() && resource.data.storeId == storeId();
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Enforces store ownership for writes.
     */
    match /units/{unitId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == storeId();
      allow update: if isSignedIn() && resource.data.storeId == storeId();
      allow delete: if isSignedIn() && resource.data.storeId == storeId();
    }

    /**
     * @description Allows reading and writing of families only if the storeId matches.
     * @path /families/{familyId}
     * @allow (get, list) if true
     * @allow (create) if isSignedIn() && request.resource.data.storeId == storeId();
     * @allow (update, delete) if isSignedIn() && resource.data.storeId == storeId();
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Enforces store ownership for writes.
     */
    match /families/{familyId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == storeId();
      allow update: if isSignedIn() && resource.data.storeId == storeId();
      allow delete: if isSignedIn() && resource.data.storeId == storeId();
    }

    /**
     * @description Allows reading and writing of warehouses only if the storeId matches.
     * @path /warehouses/{warehouseId}
     * @allow (get, list) if true
     * @allow (create) if isSignedIn() && request.resource.data.storeId == storeId();
     * @allow (update, delete) if isSignedIn() && resource.data.storeId == storeId();
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Enforces store ownership for writes.
     */
    match /warehouses/{warehouseId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == storeId();
      allow update: if isSignedIn() && resource.data.storeId == storeId();
      allow delete: if isSignedIn() && resource.data.storeId == storeId();
    }

    /**
     * @description Allows reading and writing of ads only to authenticated users.
     * @path /ads/{adId}
     * @allow (get, list) if true
     * @allow (create, update, delete) if isSignedIn();
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Requires authentication for write operations.
     */
    match /ads/{adId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows reading and writing of cashSessions only to authenticated users.
     * @path /cashSessions/{cashSessionId}
     * @allow (get, list) if true
     * @allow (create, update, delete) if isSignedIn();
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Requires authentication for write operations.
     */
    match /cashSessions/{cashSessionId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows reading a user's own profile and creating a profile with a matching user ID.
     * @path /users/{userId}
     * @allow (get) if true;
     * @allow (list) if false;
     * @allow (create) if isSignedIn() && request.auth.uid == userId;
     * @allow (update, delete) if isSignedIn() && request.auth.uid == userId;
     * @deny (create) if !isSignedIn() || request.auth.uid != userId;
     * @deny (update, delete) if !isSignedIn() || request.auth.uid != userId;
     * @principle Enforces document ownership for writes and prevents listing.
     */
    match /users/{userId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
  }

  // Helper function to determine if the user is signed in
  function isSignedIn() {
    return request.auth != null;
  }

    // Helper function to get the storeId from the path
  function storeId() {
    return request.path.split("/")[4];
  }
}
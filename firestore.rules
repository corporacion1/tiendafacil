/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for data access,
 *              with denormalization to ensure authorization independence.
 *
 * Data Structure:
 * - /roles_admin/{userId}: Documents in this collection grant admin privileges to the user.
 * - /users/{userId}: User-specific data. Only the user can access their own data.
 * - /stores/{storeId}: Store configurations, owned by a user.
 * - /stores/{storeId}/families/{familyId}: Families within a store, access controlled by store ownership.
 * - /stores/{storeId}/products/{productId}: Products within a store, access controlled by store ownership.
 * - /stores/{storeId}/taxTypes/{taxTypeId}: Tax types within a store, access controlled by store ownership.
 * - /stores/{storeId}/inventoryMovements/{inventoryMovementId}: Inventory movements within a store, access controlled by store ownership.
 * - /stores/{storeId}/sales/{saleId}: Sales records within a store, access controlled by store ownership.
 * - /stores/{storeId}/sales/{saleId}/saleItems/{saleItemId}: Items within a sale, access controlled by store ownership.
 * - /stores/{storeId}/purchases/{purchaseId}: Purchase records within a store, access controlled by store ownership.
 * - /stores/{storeId}/purchases/{purchaseId}/purchaseItems/{purchaseItemId}: Items within a purchase, access controlled by store ownership.
 * - /stores/{storeId}/customers/{customerId}: Customers of a store, access controlled by store ownership.
 *
 * Key Security Decisions:
 * - User listing is disallowed to protect privacy.
 * - All writes require authentication and authorization.
 * - Data validation is minimized for prototyping, focusing on relational integrity.
 * - `ownerId` is denormalized to subcollections to improve security and performance.
 *
 * Denormalization for Authorization:
 * - The `ownerId` is stored in each store document. This `ownerId` is critically copied into all subcollections of `/stores/{storeId}`
 *   to avoid needing to perform costly `get()` operations during authorization checks in subcollections.
 *   This approach enables simple and performant rules.
 *   Example: A `Product` document at `/stores/{storeId}/products/{productId}` includes the `ownerId` of the store.
 *
 * Structural Segregation:
 * - User data is stored under `/users/{userId}`, separate from store data under `/stores/{storeId}`.
 *   This separation prevents accidental data exposure and simplifies access control.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     * @return {boolean} True if the request is authenticated, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user ID matches the authenticated user's ID.
     * @param {string} userId - The user ID to compare against.
     * @return {boolean} True if the user ID matches the authenticated user's ID, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is an existing owner of the resource.
     * @param {string} userId - The user ID to compare against.
     * @return {boolean} True if the user is the owner of the existing resource, false otherwise.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Checks if the authenticated user has admin privileges.
     * @return {boolean} True if the user has admin privileges, false otherwise.
     */
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description Grants admin users full access to the database.
     * @path /roles_admin/{userId}
     * @allow (get, create, update, delete) if isAdmin()
     * @deny (get, create, update, delete) if !isAdmin()
     * @principle Grants administrative privileges based on document existence in /roles_admin collection.
     */
    match /roles_admin/{userId} {
      allow get: if isAdmin();
      allow list: if false;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Grants a user access to their own user document.
     * @path /users/{userId}
     * @allow (create) if isOwner(userId) - Allows creating a user document with a matching user ID.
     * @allow (get, update, delete) if isOwner(userId) - Allows reading, updating, and deleting their own user document.
     * @deny (create) if !isOwner(userId) - Denies creating a user document with a mismatched user ID.
     * @deny (get, update, delete) if !isOwner(userId) - Denies others from reading, updating, or deleting the user document.
     * @principle Enforces document ownership for user-specific data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Grants access to store configurations based on ownership.
     *              The rules enforce that the 'ownerId' field in the document matches the authenticated user's ID.
     * @path /stores/{storeId}
     * @allow (get, list) if true - Allows public read access to store configurations.
     * @allow (create) if isSignedIn() && request.resource.data.ownerId == request.auth.uid - Allows creating a store with the authenticated user as the owner.
     * @allow (update, delete) if isExistingOwner(resource.data.ownerId) - Allows the owner to update or delete the store configuration.
     * @deny (create) if !isSignedIn() || request.resource.data.ownerId != request.auth.uid - Denies creating a store if not signed in or if the owner ID does not match.
     * @deny (update, delete) if !isExistingOwner(resource.data.ownerId) - Denies updating or deleting the store if not the owner.
     * @principle Enforces document ownership for writes and public read for store information.
     */
    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.ownerId);
      allow delete: if isExistingOwner(resource.data.ownerId);
    }

    /**
     * @description Grants access to families within a store based on store ownership.
     *              The rules enforce that the 'ownerId' field in the document matches the owner of the parent `/stores/{storeId}` document.
     * @path /stores/{storeId}/families/{familyId}
     * @allow (get, list) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows access only to store owner.
     * @allow (create) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows creating a family if the authenticated user owns the store.
     * @allow (update, delete) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows updating or deleting a family if the authenticated user owns the store.
     * @deny (create) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies creating a family if not signed in or if the user does not own the store.
     * @deny (update, delete) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies updating or deleting a family if not the store owner.
     * @principle Enforces document ownership for writes and public read for store information.
     */
    match /stores/{storeId}/families/{familyId} {
      allow get, list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /**
     * @description Grants access to products within a store based on store ownership.
     *              The rules enforce that the 'ownerId' field in the document matches the owner of the parent `/stores/{storeId}` document.
     * @path /stores/{storeId}/products/{productId}
     * @allow (get, list) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows access only to store owner.
     * @allow (create) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows creating a product if the authenticated user owns the store.
     * @allow (update, delete) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows updating or deleting a product if the authenticated user owns the store.
     * @deny (create) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies creating a product if not signed in or if the user does not own the store.
     * @deny (update, delete) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies updating or deleting a product if not the store owner.
     * @principle Enforces document ownership for writes and public read for store information.
     */
    match /stores/{storeId}/products/{productId} {
      allow get, list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /**
     * @description Grants access to tax types within a store based on store ownership.
     *              The rules enforce that the 'ownerId' field in the document matches the owner of the parent `/stores/{storeId}` document.
     * @path /stores/{storeId}/taxTypes/{taxTypeId}
     * @allow (get, list) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows access only to store owner.
     * @allow (create) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows creating a tax type if the authenticated user owns the store.
     * @allow (update, delete) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows updating or deleting a tax type if the authenticated user owns the store.
     * @deny (create) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies creating a tax type if not signed in or if the user does not own the store.
     * @deny (update, delete) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies updating or deleting a tax type if not the store owner.
     * @principle Enforces document ownership for writes and public read for store information.
     */
    match /stores/{storeId}/taxTypes/{taxTypeId} {
      allow get, list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /**
     * @description Grants access to inventory movements within a store based on store ownership.
     *              The rules enforce that the 'ownerId' field in the document matches the owner of the parent `/stores/{storeId}` document.
     * @path /stores/{storeId}/inventoryMovements/{inventoryMovementId}
     * @allow (get, list) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows access only to store owner.
     * @allow (create) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows creating an inventory movement if the authenticated user owns the store.
     * @allow (update, delete) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows updating or deleting an inventory movement if the authenticated user owns the store.
     * @deny (create) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies creating an inventory movement if not signed in or if the user does not own the store.
     * @deny (update, delete) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies updating or deleting an inventory movement if not the store owner.
     * @principle Enforces document ownership for writes and public read for store information.
     */
    match /stores/{storeId}/inventoryMovements/{inventoryMovementId} {
      allow get, list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /**
     * @description Grants access to sales records within a store based on store ownership.
     *              The rules enforce that the 'ownerId' field in the document matches the owner of the parent `/stores/{storeId}` document.
     * @path /stores/{storeId}/sales/{saleId}
     * @allow (get, list) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows access only to store owner.
     * @allow (create) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows creating a sale if the authenticated user owns the store.
     * @allow (update, delete) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows updating or deleting a sale if the authenticated user owns the store.
     * @deny (create) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies creating a sale if not signed in or if the user does not own the store.
     * @deny (update, delete) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies updating or deleting a sale if not the store owner.
     * @principle Enforces document ownership for writes and public read for store information.
     */
    match /stores/{storeId}/sales/{saleId} {
      allow get, list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /**
     * @description Grants access to sale items within a sale based on store ownership.
     *              The rules enforce that the 'ownerId' field in the document matches the owner of the parent `/stores/{storeId}` document.
     * @path /stores/{storeId}/sales/{saleId}/saleItems/{saleItemId}
     * @allow (get, list) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows access only to store owner.
     * @allow (create) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows creating a sale item if the authenticated user owns the store.
     * @allow (update, delete) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows updating or deleting a sale item if the authenticated user owns the store.
     * @deny (create) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies creating a sale item if not signed in or if the user does not own the store.
     * @deny (update, delete) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies updating or deleting a sale item if not the store owner.
     * @principle Enforces document ownership for writes and public read for store information.
     */
    match /stores/{storeId}/sales/{saleId}/saleItems/{saleItemId} {
      allow get, list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /**
     * @description Grants access to purchase records within a store based on store ownership.
     *              The rules enforce that the 'ownerId' field in the document matches the owner of the parent `/stores/{storeId}` document.
     * @path /stores/{storeId}/purchases/{purchaseId}
     * @allow (get, list) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows access only to store owner.
     * @allow (create) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows creating a purchase if the authenticated user owns the store.
     * @allow (update, delete) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows updating or deleting a purchase if the authenticated user owns the store.
     * @deny (create) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies creating a purchase if not signed in or if the user does not own the store.
     * @deny (update, delete) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies updating or deleting a purchase if not the store owner.
     * @principle Enforces document ownership for writes and public read for store information.
     */
    match /stores/{storeId}/purchases/{purchaseId} {
      allow get, list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /**
     * @description Grants access to purchase items within a purchase based on store ownership.
     *              The rules enforce that the 'ownerId' field in the document matches the owner of the parent `/stores/{storeId}` document.
     * @path /stores/{storeId}/purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     * @allow (get, list) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows access only to store owner.
     * @allow (create) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows creating a purchase item if the authenticated user owns the store.
     * @allow (update, delete) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows updating or deleting a purchase item if the authenticated user owns the store.
     * @deny (create) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies creating a purchase item if not signed in or if the user does not own the store.
     * @deny (update, delete) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies updating or deleting a purchase item if not the store owner.
     * @principle Enforces document ownership for writes and public read for store information.
     */
    match /stores/{storeId}/purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
      allow get, list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

   /**
     * @description Grants access to customers within a store based on store ownership.
     *              The rules enforce that the 'ownerId' field in the document matches the owner of the parent `/stores/{storeId}` document.
     * @path /stores/{storeId}/customers/{customerId}
     * @allow (get, list) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows access only to store owner.
     * @allow (create) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows creating a customer if the authenticated user owns the store.
     * @allow (update, delete) if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid - Allows updating or deleting a customer if the authenticated user owns the store.
     * @deny (create) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies creating a customer if not signed in or if the user does not own the store.
     * @deny (update, delete) if !isSignedIn() || get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid - Denies updating or deleting a customer if not the store owner.
     * @principle Enforces document ownership for writes and public read for store information.
     */
    match /stores/{storeId}/customers/{customerId} {
      allow get, list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }
  }
}
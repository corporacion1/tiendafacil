/**
 * @fileoverview Firestore Security Rules for the SaaS application.
 *
 * Core Philosophy:
 * This ruleset enforces a multi-tenant security model where data access is primarily restricted to the owning user or, in the case of stores, the store owner.
 * Read access to product information is generally public, while write access is limited to store admins. User profile creation is self-managed, and roles are immutable post-creation.
 *
 * Data Structure:
 * - /stores: Collection of stores, each owned by a user.
 * - /stores/{storeId}/products: Products belonging to a specific store.
 * - /stores/{storeId}/sales: Sales records for a specific store.
 * - /stores/{storeId}/customers: Customers of a specific store.
 * - /products: Publicly accessible collection of all products across all stores.
 * - /users: Collection of user profiles.
 * - /chats: Collection of chat rooms.
 * - /chats/{chatId}/messages: Messages within a specific chat room.
 *
 * Key Security Decisions:
 * - User profiles are created by the user themselves but cannot be modified afterwards (role is immutable).
 * - Stores can only be created by authenticated users.
 * - Products in the public /products collection are publicly readable, but only store admins can create/modify them.
 * - Listing of Sales and Customers is disallowed to prevent unauthorized data scraping.
 * - Chat messages are writeable by any signed in user; there is no access control.
 *
 * Denormalization for Authorization:
 * - Store documents contain an `ownerId` field to simplify ownership checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows read and create access to stores.
     * @path /stores
     * @allow (create) User with auth can create a store with themselves as the owner.
     * @deny (update, delete) No one can update or delete a store.
     * @principle Enforces store ownership for writes.
     */
    match /stores/{storeId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows store owners to manage products within their store.
     * @path /stores/{storeId}/products/{productId}
     * @allow (create, update, delete) Store owner can manage products.
     * @deny (create, update, delete) Non-store owner cannot manage products.
     * @principle Enforces store ownership for product management.
     */
    match /stores/{storeId}/products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Restricts access to sales data within a store.
     * @path /stores/{storeId}/sales/{saleId}
     * @deny (get, list, create, update, delete) No one can access sales data directly.
     * @principle Disallows direct access to sensitive sales data.
     */
    match /stores/{storeId}/sales/{saleId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Restricts access to customer data within a store.
     * @path /stores/{storeId}/customers/{customerId}
     * @deny (get, list, create, update, delete) No one can access customer data directly.
     * @principle Disallows direct access to sensitive customer data.
     */
    match /stores/{storeId}/customers/{customerId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows public read access to products in the aggregated collection, but restricts writes.
     * @path /products/{productId}
     * @allow (get, list) Anyone can read product data.
     * @deny (create, update, delete) No one can modify product data directly in this collection.
     * @principle Public read access with restricted writes for aggregated product data.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows users to create their own profiles, but restricts modification.
     * @path /users/{userId}
     * @allow (create) User can create their profile.
     * @deny (update, delete) No one can update or delete a user profile.
     * @principle Self-creation of user profiles with immutable roles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows read access to chats.
     * @path /chats/{chatId}
     * @allow (get, list) Anyone can read.
     * @deny (create, update, delete)
     * @principle Public read access for chat list
     */
    match /chats/{chatId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows all signed-in users to create chat messages.
     * @path /chats/{chatId}/messages/{messageId}
     * @allow (create) Any signed-in user can create a message.
     * @deny (update, delete) No one can update or delete chat messages.
     * @principle Open write access for all signed in users
     */
    match /chats/{chatId}/messages/{messageId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description This section handles missing or insufficient permissions.
     * @path /purchases
     * @deny (get, list, create, update, delete) No one can access purchases
     * @principle Explicitly denies access as per the error report.
     */
    match /purchases/{document=**} {
        allow get: if false;
        allow list: if false;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }
  }

  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }
}
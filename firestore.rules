/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes secure authorization while offering data shape flexibility for rapid prototyping.
 * All write operations are strictly controlled, while read operations are more permissive to enable quicker data exploration.
 *
 * Data Structure:
 * The Firestore database consists of several top-level collections: `products`, `taxTypes`, `inventoryMovements`, `sales`, `purchases`, `customers`, `stores`, and `families`.
 * There are subcollections under `sales` and `purchases` for `saleItems` and `purchaseItems` respectively.
 *
 * Key Security Decisions:
 * - All write operations require authentication and ownership.
 * - Listing all documents of a specific collection is generally allowed for authenticated users unless explicitly denied.
 *
 * Denormalization for Authorization:
 * Assuming that all top-level collections have a storeId which can be used for authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Allows only signed-in users.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function onlySignedInUsers() {
      return isSignedIn();
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     * @return {boolean} True if the user IDs match, false otherwise.
     */
    function isOwner(userId) {
        return request.auth.uid == userId;
    }

    /**
     * @description Checks if the document exists and the user is the owner.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     * @return {boolean} True if the user IDs match and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && exists(resource);
    }

    /**
     * @description Checks if the user is the owner of the document based on the 'userId' field.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isDocumentOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /**
     * @description Checks if the user is the owner of the document being created based on the 'userId' field.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isCreatingDocumentOwner() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
    
    /**
     * @description Rules for the /products collection.
     * @path /products/{productId}
     */
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isCreatingDocumentOwner();
      allow update: if isSignedIn() && isDocumentOwner();
      allow delete: if isSignedIn() && isDocumentOwner();
    }

    /**
     * @description Rules for the /taxTypes collection.
     * @path /taxTypes/{taxTypeId}
     */
    match /taxTypes/{taxTypeId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isCreatingDocumentOwner();
      allow update: if isSignedIn() && isDocumentOwner();
      allow delete: if isSignedIn() && isDocumentOwner();
    }

    /**
     * @description Rules for the /inventoryMovements collection.
     * @path /inventoryMovements/{inventoryMovementId}
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isCreatingDocumentOwner();
      allow update: if isSignedIn() && isDocumentOwner();
      allow delete: if isSignedIn() && isDocumentOwner();
    }

    /**
     * @description Rules for the /sales collection.
     * @path /sales/{saleId}
     */
    match /sales/{saleId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isCreatingDocumentOwner();
      allow update: if isSignedIn() && isDocumentOwner();
      allow delete: if isSignedIn() && isDocumentOwner();

      /**
       * @description Rules for the /sales/{saleId}/saleItems subcollection.
       * @path /sales/{saleId}/saleItems/{saleItemId}
       */
      match /sales/{saleId}/saleItems/{saleItemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && isCreatingDocumentOwner();
        allow update: if isSignedIn() && isDocumentOwner();
        allow delete: if isSignedIn() && isDocumentOwner();
      }
    }

    /**
     * @description Rules for the /purchases collection.
     * @path /purchases/{purchaseId}
     */
    match /purchases/{purchaseId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isCreatingDocumentOwner();
      allow update: if isSignedIn() && isDocumentOwner();
      allow delete: if isSignedIn() && isDocumentOwner();

      /**
       * @description Rules for the /purchases/{purchaseId}/purchaseItems subcollection.
       * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
       */
      match /purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && isCreatingDocumentOwner();
        allow update: if isSignedIn() && isDocumentOwner();
        allow delete: if isSignedIn() && isDocumentOwner();
      }
    }

    /**
     * @description Rules for the /customers collection.
     * @path /customers/{customerId}
     */
    match /customers/{customerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isCreatingDocumentOwner();
      allow update: if isSignedIn() && isDocumentOwner();
      allow delete: if isSignedIn() && isDocumentOwner();
    }

    /**
     * @description Rules for the /stores collection.
     * @path /stores/{storeId}
     */
    match /stores/{storeId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isCreatingDocumentOwner();
      allow update: if isSignedIn() && isDocumentOwner();
      allow delete: if isSignedIn() && isDocumentOwner();
    }

    /**
     * @description Rules for the /families collection.
     * @path /families/{familyId}
     */
    match /families/{familyId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isCreatingDocumentOwner();
      allow update: if isSignedIn() && isDocumentOwner();
      allow delete: if isSignedIn() && isDocumentOwner();
    }

    /**
     * @description Rules for the /units collection.
     * @path /units
     */
    match /units/{unitId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isCreatingDocumentOwner();
      allow update: if isSignedIn() && isDocumentOwner();
      allow delete: if isSignedIn() && isDocumentOwner();
    }
  }
}
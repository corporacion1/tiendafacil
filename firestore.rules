rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows only the authenticated user to read/write their own user document.
     * @path /users/{userId}
     * @allow (create) if request.auth.uid == userId
     * @allow (get, update, delete) if request.auth.uid == userId && resource != null
     * @deny (create) if request.auth.uid != userId
     * @deny (get, update, delete) if request.auth.uid != userId
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows store owners to manage their stores.
     * @path /stores/{storeId}
     * @allow (create) if request.auth.uid == request.resource.data.ownerId
     * @allow (get, list, update, delete) if resource.data.ownerId == request.auth.uid && resource != null
     * @deny (create, get, list, update, delete) if resource.data.ownerId != request.auth.uid
     * @principle Enforces store ownership for all store-related operations.
     */
    match /stores/{storeId} {
        function isStoreOwner(storeId) {
          return resource.data.ownerId == request.auth.uid;
        }
        function isCreatingStoreAsOwner(storeId) {
          return request.auth.uid == request.resource.data.ownerId;
        }
        function isExistingStoreOwner(storeId) {
            return resource.data.ownerId == request.auth.uid && resource != null;
        }

        allow get: if isExistingStoreOwner(storeId);
        allow list: if false; // Listing stores is not allowed.
        allow create: if request.auth.uid == request.resource.data.ownerId;
        allow update: if isExistingStoreOwner(storeId);
        allow delete: if isExistingStoreOwner(storeId);

      /**
       * @description Allows store owners to manage products within their store.
       * @path /stores/{storeId}/products/{productId}
       * @allow (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
       * @deny (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid
       * @principle Enforces store ownership for product management.
       */
      match /products/{productId} {
          function getStoreRef() {
            return get(/databases/$(database)/documents/stores/$(storeId));
          }
          function isStoreOwnerFromParent(storeId) {
            return getStoreRef().data.ownerId == request.auth.uid;
          }
          function isExistingStoreOwnerFromParent(storeId) {
              return getStoreRef().data.ownerId == request.auth.uid && resource != null;
          }

          allow get: if isExistingStoreOwnerFromParent($storeId);
          allow list: if isExistingStoreOwnerFromParent($storeId);
          allow create: if isExistingStoreOwnerFromParent($storeId);
          allow update: if isExistingStoreOwnerFromParent($storeId);
          allow delete: if isExistingStoreOwnerFromParent($storeId);
      }

      /**
       * @description Allows store owners to manage units within their store.
       * @path /stores/{storeId}/units/{unitId}
       * @allow (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
       * @deny (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid
       * @principle Enforces store ownership for unit management.
       */
      match /units/{unitId} {
          function getStoreRef() {
            return get(/databases/$(database)/documents/stores/$(storeId));
          }
          let $storeId = parent_paths()[1];
          function isStoreOwnerFromParent(storeId) {
            return getStoreRef().data.ownerId == request.auth.uid;
          }
          function isExistingStoreOwnerFromParent(storeId) {
              return getStoreRef().data.ownerId == request.auth.uid && resource != null;
          }

          allow get: if isExistingStoreOwnerFromParent($storeId);
          allow list: if isExistingStoreOwnerFromParent($storeId);
          allow create: if isExistingStoreOwnerFromParent($storeId);
          allow update: if isExistingStoreOwnerFromParent($storeId);
          allow delete: if isExistingStoreOwnerFromParent($storeId);
      }

      /**
       * @description Allows store owners to manage families within their store.
       * @path /stores/{storeId}/families/{familyId}
       * @allow (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
       * @deny (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid
       * @principle Enforces store ownership for family management.
       */
      match /families/{familyId} {
          function getStoreRef() {
            return get(/databases/$(database)/documents/stores/$(storeId));
          }
          let $storeId = parent_paths()[1];
          function isStoreOwnerFromParent(storeId) {
            return getStoreRef().data.ownerId == request.auth.uid;
          }
          function isExistingStoreOwnerFromParent(storeId) {
              return getStoreRef().data.ownerId == request.auth.uid && resource != null;
          }

          allow get: if isExistingStoreOwnerFromParent($storeId);
          allow list: if isExistingStoreOwnerFromParent($storeId);
          allow create: if isExistingStoreOwnerFromParent($storeId);
          allow update: if isExistingStoreOwnerFromParent($storeId);
          allow delete: if isExistingStoreOwnerFromParent($storeId);
      }

      /**
       * @description Allows store owners to manage warehouses within their store.
       * @path /stores/{storeId}/warehouses/{warehouseId}
       * @allow (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
       * @deny (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid
       * @principle Enforces store ownership for warehouse management.
       */
      match /warehouses/{warehouseId} {
          function getStoreRef() {
            return get(/databases/$(database)/documents/stores/$(storeId));
          }
          let $storeId = parent_paths()[1];
          function isStoreOwnerFromParent(storeId) {
            return getStoreRef().data.ownerId == request.auth.uid;
          }
          function isExistingStoreOwnerFromParent(storeId) {
              return getStoreRef().data.ownerId == request.auth.uid && resource != null;
          }

          allow get: if isExistingStoreOwnerFromParent($storeId);
          allow list: if isExistingStoreOwnerFromParent($storeId);
          allow create: if isExistingStoreOwnerFromParent($storeId);
          allow update: if isExistingStoreOwnerFromParent($storeId);
          allow delete: if isExistingStoreOwnerFromParent($storeId);
      }

      /**
       * @description Allows store owners to manage tax types within their store.
       * @path /stores/{storeId}/tax_types/{taxTypeId}
       * @allow (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
       * @deny (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid
       * @principle Enforces store ownership for tax type management.
       */
      match /tax_types/{taxTypeId} {
          function getStoreRef() {
            return get(/databases/$(database)/documents/stores/$(storeId));
          }
          let $storeId = parent_paths()[1];
          function isStoreOwnerFromParent(storeId) {
            return getStoreRef().data.ownerId == request.auth.uid;
          }
          function isExistingStoreOwnerFromParent(storeId) {
              return getStoreRef().data.ownerId == request.auth.uid && resource != null;
          }

          allow get: if isExistingStoreOwnerFromParent($storeId);
          allow list: if isExistingStoreOwnerFromParent($storeId);
          allow create: if isExistingStoreOwnerFromParent($storeId);
          allow update: if isExistingStoreOwnerFromParent($storeId);
          allow delete: if isExistingStoreOwnerFromParent($storeId);
      }

      /**
       * @description Allows store owners to manage inventory movements within their store.
       * @path /stores/{storeId}/inventory_movements/{inventoryMovementId}
       * @allow (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
       * @deny (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid
       * @principle Enforces store ownership for inventory movement management.
       */
      match /inventory_movements/{inventoryMovementId} {
          function getStoreRef() {
            return get(/databases/$(database)/documents/stores/$(storeId));
          }
          let $storeId = parent_paths()[1];
          function isStoreOwnerFromParent(storeId) {
            return getStoreRef().data.ownerId == request.auth.uid;
          }
          function isExistingStoreOwnerFromParent(storeId) {
              return getStoreRef().data.ownerId == request.auth.uid && resource != null;
          }

          allow get: if isExistingStoreOwnerFromParent($storeId);
          allow list: if isExistingStoreOwnerFromParent($storeId);
          allow create: if isExistingStoreOwnerFromParent($storeId);
          allow update: if isExistingStoreOwnerFromParent($storeId);
          allow delete: if isExistingStoreOwnerFromParent($storeId);
      }

      /**
       * @description Allows store owners to manage sales records within their store.
       * @path /stores/{storeId}/sales/{saleId}
       * @allow (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
       * @deny (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid
       * @principle Enforces store ownership for sales record management.
       */
      match /sales/{saleId} {
          function getStoreRef() {
            return get(/databases/$(database)/documents/stores/$(storeId));
          }
          let $storeId = parent_paths()[1];
          function isStoreOwnerFromParent(storeId) {
            return getStoreRef().data.ownerId == request.auth.uid;
          }
          function isExistingStoreOwnerFromParent(storeId) {
              return getStoreRef().data.ownerId == request.auth.uid && resource != null;
          }

          allow get: if isExistingStoreOwnerFromParent($storeId);
          allow list: if isExistingStoreOwnerFromParent($storeId);
          allow create: if isExistingStoreOwnerFromParent($storeId);
          allow update: if isExistingStoreOwnerFromParent($storeId);
          allow delete: if isExistingStoreOwnerFromParent($storeId);

          /**
           * @description Allows store owners to manage sale items within a sale for their store.
           * @path /stores/{storeId}/sales/{saleId}/sale_items/{saleItemId}
           * @allow (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
           * @deny (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid
           */
          match /sale_items/{saleItemId} {
              function getStoreRef() {
                return get(/databases/$(database)/documents/stores/$(storeId));
              }
              let $storeId = parent_paths()[3];
              function isStoreOwnerFromParent(storeId) {
                return getStoreRef().data.ownerId == request.auth.uid;
              }
              function isExistingStoreOwnerFromParent(storeId) {
                  return getStoreRef().data.ownerId == request.auth.uid && resource != null;
              }

              allow get: if isExistingStoreOwnerFromParent($storeId);
              allow list: if isExistingStoreOwnerFromParent($storeId);
              allow create: if isExistingStoreOwnerFromParent($storeId);
              allow update: if isExistingStoreOwnerFromParent($storeId);
              allow delete: if isExistingStoreOwnerFromParent($storeId);
          }
      }

      /**
       * @description Allows store owners to manage purchases within their store.
       * @path /stores/{storeId}/purchases/{purchaseId}
       * @allow (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
       * @deny (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid
       * @principle Enforces store ownership for purchase management.
       */
      match /purchases/{purchaseId} {
          function getStoreRef() {
            return get(/databases/$(database)/documents/stores/$(storeId));
          }
          let $storeId = parent_paths()[1];
          function isStoreOwnerFromParent(storeId) {
            return getStoreRef().data.ownerId == request.auth.uid;
          }
          function isExistingStoreOwnerFromParent(storeId) {
              return getStoreRef().data.ownerId == request.auth.uid && resource != null;
          }

          allow get: if isExistingStoreOwnerFromParent($storeId);
          allow list: if isExistingStoreOwnerFromParent($storeId);
          allow create: if isExistingStoreOwnerFromParent($storeId);
          allow update: if isExistingStoreOwnerFromParent($storeId);
          allow delete: if isExistingStoreOwnerFromParent($storeId);

          /**
           * @description Allows store owners to manage purchase items within a purchase for their store.
           * @path /stores/{storeId}/purchases/{purchaseId}/purchase_items/{purchaseItemId}
           * @allow (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
           * @deny (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid
           * @principle Enforces store ownership for purchase item management.
           */
          match /purchase_items/{purchaseItemId} {
              function getStoreRef() {
                return get(/databases/$(database)/documents/stores/$(storeId));
              }
              let $storeId = parent_paths()[3];
              function isStoreOwnerFromParent(storeId) {
                return getStoreRef().data.ownerId == request.auth.uid;
              }
              function isExistingStoreOwnerFromParent(storeId) {
                  return getStoreRef().data.ownerId == request.auth.uid && resource != null;
              }

              allow get: if isExistingStoreOwnerFromParent($storeId);
              allow list: if isExistingStoreOwnerFromParent($storeId);
              allow create: if isExistingStoreOwnerFromParent($storeId);
              allow update: if isExistingStoreOwnerFromParent($storeId);
              allow delete: if isExistingStoreOwnerFromParent($storeId);
          }
      }

      /**
       * @description Allows store owners to manage suppliers within their store.
       * @path /stores/{storeId}/suppliers/{supplierId}
       * @allow (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
       * @deny (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid
       * @principle Enforces store ownership for supplier management.
       */
      match /suppliers/{supplierId} {
          function getStoreRef() {
            return get(/databases/$(database)/documents/stores/$(storeId));
          }
          let $storeId = parent_paths()[1];
          function isStoreOwnerFromParent(storeId) {
            return getStoreRef().data.ownerId == request.auth.uid;
          }
          function isExistingStoreOwnerFromParent(storeId) {
              return getStoreRef().data.ownerId == request.auth.uid && resource != null;
          }

          allow get: if isExistingStoreOwnerFromParent($storeId);
          allow list: if isExistingStoreOwnerFromParent($storeId);
          allow create: if isExistingStoreOwnerFromParent($storeId);
          allow update: if isExistingStoreOwnerFromParent($storeId);
          allow delete: if isExistingStoreOwnerFromParent($storeId);
      }

      /**
       * @description Allows store owners to manage customers within their store.
       * @path /stores/{storeId}/customers/{customerId}
       * @allow (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
       * @deny (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid
       * @principle Enforces store ownership for customer management.
       */
      match /customers/{customerId} {
          function getStoreRef() {
            return get(/databases/$(database)/documents/stores/$(storeId));
          }
          let $storeId = parent_paths()[1];
          function isStoreOwnerFromParent(storeId) {
            return getStoreRef().data.ownerId == request.auth.uid;
          }
          function isExistingStoreOwnerFromParent(storeId) {
              return getStoreRef().data.ownerId == request.auth.uid && resource != null;
          }

          allow get: if isExistingStoreOwnerFromParent($storeId);
          allow list: if isExistingStoreOwnerFromParent($storeId);
          allow create: if isExistingStoreOwnerFromParent($storeId);
          allow update: if isExistingStoreOwnerFromParent($storeId);
          allow delete: if isExistingStoreOwnerFromParent($storeId);
      }

      /**
       * @description Allows store owners to manage currency rates within their store.
       * @path /stores/{storeId}/currency_rates/{currencyRateId}
       * @allow (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
       * @deny (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid
       * @principle Enforces store ownership for currency rate management.
       */
      match /currency_rates/{currencyRateId} {
          function getStoreRef() {
            return get(/databases/$(database)/documents/stores/$(storeId));
          }
          let $storeId = parent_paths()[1];
          function isStoreOwnerFromParent(storeId) {
            return getStoreRef().data.ownerId == request.auth.uid;
          }
          function isExistingStoreOwnerFromParent(storeId) {
              return getStoreRef().data.ownerId == request.auth.uid && resource != null;
          }

          allow get: if isExistingStoreOwnerFromParent($storeId);
          allow list: if isExistingStoreOwnerFromParent($storeId);
          allow create: if isExistingStoreOwnerFromParent($storeId);
          allow update: if isExistingStoreOwnerFromParent($storeId);
          allow delete: if isExistingStoreOwnerFromParent($storeId);
      }

      /**
       * @description Allows store owners to manage chats within their store.
       * @path /stores/{storeId}/chats/{chatId}
       * @allow (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
       * @deny (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid
       */
      match /chats/{chatId} {
          function getStoreRef() {
            return get(/databases/$(database)/documents/stores/$(storeId));
          }
          let $storeId = parent_paths()[1];
          function isStoreOwnerFromParent(storeId) {
            return getStoreRef().data.ownerId == request.auth.uid;
          }
          function isExistingStoreOwnerFromParent(storeId) {
              return getStoreRef().data.ownerId == request.auth.uid && resource != null;
          }

          allow get: if isExistingStoreOwnerFromParent($storeId);
          allow list: if isExistingStoreOwnerFromParent($storeId);
          allow create: if isExistingStoreOwnerFromParent($storeId);
          allow update: if isExistingStoreOwnerFromParent($storeId);
          allow delete: if isExistingStoreOwnerFromParent($storeId);

          /**
           * @description Allows store owners to manage chat messages within a chat for their store.
           * @path /stores/{storeId}/chats/{chatId}/messages/{messageId}
           * @allow (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid
           * @deny (get, list, create, update, delete) if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId != request.auth.uid
           */
          match /messages/{messageId} {
              function getStoreRef() {
                return get(/databases/$(database)/documents/stores/$(storeId));
              }
              let $storeId = parent_paths()[3];
              function isStoreOwnerFromParent(storeId) {
                return getStoreRef().data.ownerId == request.auth.uid;
              }
              function isExistingStoreOwnerFromParent(storeId) {
                  return getStoreRef().data.ownerId == request.auth.uid && resource != null;
              }

              allow get: if isExistingStoreOwnerFromParent($storeId);
              allow list: if isExistingStoreOwnerFromParent($storeId);
              allow create: if isExistingStoreOwnerFromParent($storeId);
              allow update: if isExistingStoreOwnerFromParent($storeId);
              allow delete: if isExistingStoreOwnerFromParent($storeId);
          }
      }
    }
  }
}
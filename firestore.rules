/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a store-ownership model, where each document belongs to a specific store.
 *  Only authenticated users can access data, and they can only access data associated with their store.
 *  All data is organized in top-level collections such as /products/{productId}, /sales/{saleId}, etc.
 *
 * Key Security Decisions:
 *  - Public listing is not allowed.
 *  - All write operations require authentication and store-ownership validation.
 *  - No user-specific data trees are used.
 *  - The rules do NOT validate the data schema beyond requiring essential fields for relational integrity and authorization.
 *
 *  To create simpler, more performant rules, data required for authorization is denormalized directly onto the documents being secured.
 *  For example, all documents have a `storeId` field which is used to quickly check if the user has access to the document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the owner of the store, based on the storeId.
     */
    function isStoreOwner(storeId) {
      return isSignedIn() && request.auth.uid == storeId;
    }

    /**
     * @description Checks if the user is the owner of the store and the resource exists.
     */
    function isExistingStoreOwner(storeId) {
      return isStoreOwner(storeId) && resource != null;
    }

    /**
     * @description Collection for products.
     * @path /products/{productId}
     * @allow (create) Authenticated user can create a product if the storeId matches the user's UID and other properties are valid.
     * @deny (create) User attempts to create a product with a mismatched storeId.
     * @allow (get, list) Authenticated user can read product data.
     * @deny (get, list) Unauthenticated user attempts to read product data.
     * @allow (update, delete) Authenticated user can update or delete a product if they are the store owner.
     * @deny (update, delete) User attempts to update or delete a product they do not own.
     * @principle Enforces store ownership for writes.
     */
    match /products/{productId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId);
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Collection for tax types.
     * @path /taxTypes/{taxTypeId}
     * @allow (create) Authenticated user can create a tax type if the storeId matches the user's UID.
     * @deny (create) User attempts to create a tax type with a mismatched storeId.
     * @allow (get, list) Authenticated user can read tax type data.
     * @deny (get, list) Unauthenticated user attempts to read tax type data.
     * @allow (update, delete) Authenticated user can update or delete a tax type if they are the store owner.
     * @deny (update, delete) User attempts to update or delete a tax type they do not own.
     * @principle Enforces store ownership for writes.
     */
    match /taxTypes/{taxTypeId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId);
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Collection for inventory movements.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (create) Authenticated user can create an inventory movement if the storeId matches the user's UID.
     * @deny (create) User attempts to create an inventory movement with a mismatched storeId.
     * @allow (get, list) Authenticated user can read inventory movement data.
     * @deny (get, list) Unauthenticated user attempts to read inventory movement data.
     * @allow (update, delete) Authenticated user can update or delete an inventory movement if they are the store owner.
     * @deny (update, delete) User attempts to update or delete an inventory movement they do not own.
     * @principle Enforces store ownership for writes.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId);
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Collection for sales.
     * @path /sales/{saleId}
     * @allow (create) Authenticated user can create a sale if the storeId matches the user's UID.
     * @deny (create) User attempts to create a sale with a mismatched storeId.
     * @allow (get, list) Authenticated user can read sale data.
     * @deny (get, list) Unauthenticated user attempts to read sale data.
     * @allow (update, delete) Authenticated user can update or delete a sale if they are the store owner.
     * @deny (update, delete) User attempts to update or delete a sale they do not own.
     * @principle Enforces store ownership for writes.
     */
    match /sales/{saleId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId);
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Subcollection for sale items within a sale.
     * @path /sales/{saleId}/saleItems/{saleItemId}
     *   Since access control is inherited from the parent, we check that the parent sale exists and is owned by the user
     * @allow (create) Authenticated user can create a sale item if they own the parent sale.
     * @deny (create) User attempts to create a sale item for a sale they do not own.
     * @allow (get, list) Authenticated user can read sale item data if they own the parent sale.
     * @deny (get, list) Unauthenticated user attempts to read sale item data.
     * @allow (update, delete) Authenticated user can update or delete a sale item if they own the parent sale.
     * @deny (update, delete) User attempts to update or delete a sale item they do not own.
     * @principle Enforces parent-child relationship and store ownership.
     */
    match /sales/{saleId}/saleItems/{saleItemId} {
       allow get: if isSignedIn() && get(/databases/$(database)/documents/sales/$(saleId)).data.storeId == request.auth.uid;
       allow list: if false;
       allow create: if isSignedIn() && get(/databases/$(database)/documents/sales/$(saleId)).data.storeId == request.auth.uid;
       allow update: if isSignedIn() && get(/databases/$(database)/documents/sales/$(saleId)).data.storeId == request.auth.uid && resource != null;
       allow delete: if isSignedIn() && get(/databases/$(database)/documents/sales/$(saleId)).data.storeId == request.auth.uid && resource != null;
    }

    /**
     * @description Collection for purchases.
     * @path /purchases/{purchaseId}
     * @allow (create) Authenticated user can create a purchase if the storeId matches the user's UID.
     * @deny (create) User attempts to create a purchase with a mismatched storeId.
     * @allow (get, list) Authenticated user can read purchase data.
     * @deny (get, list) Unauthenticated user attempts to read purchase data.
     * @allow (update, delete) Authenticated user can update or delete a purchase if they are the store owner.
     * @deny (update, delete) User attempts to update or delete a purchase they do not own.
     * @principle Enforces store ownership for writes.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId);
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Subcollection for purchase items within a purchase.
     * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     *   Since access control is inherited from the parent, we check that the parent purchase exists and is owned by the user
     * @allow (create) Authenticated user can create a purchase item if they own the parent purchase.
     * @deny (create) User attempts to create a purchase item for a purchase they do not own.
     * @allow (get, list) Authenticated user can read purchase item data if they own the parent purchase.
     * @deny (get, list) Unauthenticated user attempts to read purchase item data.
     * @allow (update, delete) Authenticated user can update or delete a purchase item if they own the parent purchase.
     * @deny (update, delete) User attempts to update or delete a purchase item they do not own.
     * @principle Enforces parent-child relationship and store ownership.
     */
    match /purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
       allow get: if isSignedIn() && get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId == request.auth.uid;
       allow list: if false;
       allow create: if isSignedIn() && get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId == request.auth.uid;
       allow update: if isSignedIn() && get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId == request.auth.uid && resource != null;
       allow delete: if isSignedIn() && get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId == request.auth.uid && resource != null;
    }

    /**
     * @description Collection for customers.
     * @path /customers/{customerId}
     * @allow (create) Authenticated user can create a customer if the storeId matches the user's UID.
     * @deny (create) User attempts to create a customer with a mismatched storeId.
     * @allow (get, list) Authenticated user can read customer data.
     * @deny (get, list) Unauthenticated user attempts to read customer data.
     * @allow (update, delete) Authenticated user can update or delete a customer if they are the store owner.
     * @deny (update, delete) User attempts to update or delete a customer they do not own.
     * @principle Enforces store ownership for writes.
     */
    match /customers/{customerId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId);
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Collection for store configurations.
     * @path /stores/{storeId}
     * @allow (create) Authenticated user can create a store configuration if the storeId matches the user's UID.
     * @deny (create) User attempts to create a store configuration with a mismatched storeId.
     * @allow (get) Authenticated user can read store configuration data if the storeId matches the user's UID.
     * @deny (get) Unauthenticated user attempts to read store configuration data.
     * @allow list: if false;
     * @allow (update, delete) Authenticated user can update or delete a store configuration if they are the store owner.
     * @deny (update, delete) User attempts to update or delete a store configuration they do not own.
     * @principle Enforces strict store ownership for all operations.
     */
    match /stores/{storeId} {
      allow get: if isStoreOwner(storeId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.id == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.id);
      allow delete: if isExistingStoreOwner(resource.data.id);
    }

    /**
     * @description Collection for product families.
     * @path /families/{familyId}
     * @allow (create) Authenticated user can create a family if the storeId matches the user's UID.
     * @deny (create) User attempts to create a family with a mismatched storeId.
     * @allow (get, list) Authenticated user can read family data.
     * @deny (get, list) Unauthenticated user attempts to read family data.
     * @allow (update, delete) Authenticated user can update or delete a family if they are the store owner.
     * @deny (update, delete) User attempts to update or delete a family they do not own.
     * @principle Enforces store ownership for writes.
     */
    match /families/{familyId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId);
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }
  }
}
/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset is designed for the rapid prototyping phase. It prioritizes strong authorization while relaxing data validation,
 * allowing developers to quickly iterate on the data model without being blocked by schema enforcement.
 *
 * Data Structure:
 * - /products: Top-level collection of product data.
 * - /chats: Top-level collection of chat rooms.
 * - /chats/{chatId}/messages: Subcollection of messages for each chat room.
 *
 * Key Security Decisions:
 * - Products are publicly readable but only writeable by authenticated users.
 * - Chat messages can only be read if signed in.
 * - Data validation is minimized to facilitate rapid prototyping and schema changes.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to the /products collection. Products are publicly readable,
     *              but require authentication to create, update, or delete.
     * @path /products
     * @allow (get, list): Anyone can read the products.
     * @allow (create): Authenticated users can create products. The 'ownerId' must match their UID.
     * @allow (update, delete): Only the owner of the product can update or delete it.
     * @deny  (create, update, delete): Unauthenticated users cannot create, update, or delete products.
     * @principle Allows public read access while enforcing ownership for write operations.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    /**
     * @description Manages access to the /chats collection.
     * @path /chats
     * @allow (get, list): Only signed-in users can list and get the chats.
     * @allow (create): Only signed-in users can create chats.
     * @allow (update, delete): Only signed-in users can update or delete chats.
     * @deny (create, update, delete, get, list): If the user is not signed in.
     * @principle: Restricts access to chats for signed-in users only.
     */
    match /chats/{chatId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update, delete: if isSignedIn() && isOwner(resource.data.ownerId);
    }

    /**
     * @description Manages access to the /chats/{chatId}/messages subcollection.
     * @path /chats/{chatId}/messages
     * @allow (get, list): Only signed-in users can list and get messages within a chat.
     * @allow (create): Only signed-in users can create messages within a chat.
     * @allow (update, delete): Only signed-in users can update or delete messages within a chat.
     * @deny (create, update, delete, get, list): If the user is not signed in.
     * @principle: Restricts access to chat messages for signed-in users only.
     */
    match /chats/{chatId}/messages/{messageId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update, delete: if isSignedIn() && isOwner(resource.data.ownerId);
    }

    // --- Helper functions ---

    /**
     * @description Checks if the user is signed in.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the owner of the resource.
     * @param {string} userId The user ID to compare against.
     * @return {bool} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the existing owner of the resource.
     * @param {string} userId The user ID to compare against.
     * @return {bool} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}
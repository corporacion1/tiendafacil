/**
 * @fileoverview Firestore Security Rules for the inventory and point-of-sale system.
 *
 * Core Philosophy:
 * This ruleset enforces a strict data-siloing model. Only authenticated users can access data, and only if they are the owner of the requested document.
 *
 * Data Structure:
 * The Firestore database is structured into top-level collections:
 * - /products/{productId}
 * - /inventoryMovements/{inventoryMovementId}
 * - /sales/{saleId}
 * - /sales/{saleId}/saleItems/{saleItemId}
 * - /purchases/{purchaseId}
 * - /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
 * - /customers/{customerId}
 * - /suppliers/{supplierId}
 * - /taxTypes/{taxTypeId}
 * - /configuration/{configurationId}
 *
 * Key Security Decisions:
 * - All top-level collections are secured using an owner-only access model. The user must be authenticated to read or write data.
 * - Listing of documents in any collection is forbidden to prevent unauthorized data discovery. Only direct `get` requests are permitted.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(resourceId) {
        return request.auth.uid == resourceId;
    }

    function isExistingOwner(resourceId) {
        return isSignedIn() && isOwner(resourceId) && resource != null;
    }

    /**
     * @description: Secures the /products collection, allowing only authenticated users to read or write a specific product document.
     * @path: /products/{productId}
     * @allow: An authenticated user (create)
     * @deny: An unauthenticated user trying to read or write a product.
     * @principle: Enforces document ownership for writes.
     */
    match /products/{productId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isExistingOwner(productId);
      allow delete: if isExistingOwner(productId);
    }

    /**
     * @description: Secures the /inventoryMovements collection, allowing only authenticated users to read or write a specific inventory movement document.
     * @path: /inventoryMovements/{inventoryMovementId}
     * @allow: An authenticated user (create)
     * @deny: An unauthenticated user trying to read or write an inventory movement.
     * @principle: Enforces document ownership for writes.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isExistingOwner(inventoryMovementId);
      allow delete: if isExistingOwner(inventoryMovementId);
    }

    /**
     * @description: Secures the /sales collection, allowing only authenticated users to read or write a specific sale document.
     * @path: /sales/{saleId}
     * @allow: An authenticated user (create)
     * @deny: An unauthenticated user trying to read or write a sale.
     * @principle: Enforces document ownership for writes.
     */
    match /sales/{saleId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isExistingOwner(saleId);
      allow delete: if isExistingOwner(saleId);
    }

    /**
     * @description: Secures the /sales/{saleId}/saleItems collection, allowing only authenticated users to read or write a specific sale item document.
     * @path: /sales/{saleId}/saleItems/{saleItemId}
     * @allow: An authenticated user (create)
     * @deny: An unauthenticated user trying to read or write a sale item.
     * @principle: Enforces document ownership for writes.
     */
    match /sales/{saleId}/saleItems/{saleItemId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isExistingOwner(saleItemId);
      allow delete: if isExistingOwner(saleItemId);
    }

    /**
     * @description: Secures the /purchases collection, allowing only authenticated users to read or write a specific purchase document.
     * @path: /purchases/{purchaseId}
     * @allow: An authenticated user (create)
     * @deny: An unauthenticated user trying to read or write a purchase.
     * @principle: Enforces document ownership for writes.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isExistingOwner(purchaseId);
      allow delete: if isExistingOwner(purchaseId);
    }

    /**
     * @description: Secures the /purchases/{purchaseId}/purchaseItems collection, allowing only authenticated users to read or write a specific purchase item document.
     * @path: /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     * @allow: An authenticated user (create)
     * @deny: An unauthenticated user trying to read or write a purchase item.
     * @principle: Enforces document ownership for writes.
     */
    match /purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isExistingOwner(purchaseItemId);
      allow delete: if isExistingOwner(purchaseItemId);
    }

    /**
     * @description: Secures the /customers collection, allowing only authenticated users to read or write a specific customer document.
     * @path: /customers/{customerId}
     * @allow: An authenticated user (create)
     * @deny: An unauthenticated user trying to read or write a customer.
     * @principle: Enforces document ownership for writes.
     */
    match /customers/{customerId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isExistingOwner(customerId);
      allow delete: if isExistingOwner(customerId);
    }

    /**
     * @description: Secures the /suppliers collection, allowing only authenticated users to read or write a specific supplier document.
     * @path: /suppliers/{supplierId}
     * @allow: An authenticated user (create)
     * @deny: An unauthenticated user trying to read or write a supplier.
     * @principle: Enforces document ownership for writes.
     */
    match /suppliers/{supplierId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isExistingOwner(supplierId);
      allow delete: if isExistingOwner(supplierId);
    }

    /**
     * @description: Secures the /taxTypes collection, allowing only authenticated users to read or write a specific tax type document.
     * @path: /taxTypes/{taxTypeId}
     * @allow: An authenticated user (create)
     * @deny: An unauthenticated user trying to read or write a tax type.
     * @principle: Enforces document ownership for writes.
     */
    match /taxTypes/{taxTypeId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isExistingOwner(taxTypeId);
      allow delete: if isExistingOwner(taxTypeId);
    }

    /**
     * @description: Secures the /configuration collection, allowing only authenticated users to read or write a specific configuration document.
     * @path: /configuration/{configurationId}
     * @allow: An authenticated user (create)
     * @deny: An unauthenticated user trying to read or write a configuration.
     * @principle: Enforces document ownership for writes.
     */
    match /configuration/{configurationId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isExistingOwner(configurationId);
      allow delete: if isExistingOwner(configurationId);
    }
  }
}
/**
 * @file Firestore Security Rules
 * @version 2
 *
 * @description
 * This ruleset enforces a strict store-ownership model, ensuring that users can only
 * access data related to their assigned store. User profiles are managed under the /users/{userId}
 * path, with create permission limited to self-creation.
 *
 * Data Structure:
 * - /stores/{storeId}: Stores configuration settings for each store.
 * - /users/{userId}: Stores user profiles.
 * - /products/{productId}: Stores product information.
 * - /inventory_movements/{movementId}: Stores inventory movement records.
 * - /sales/{saleId}: Stores sales transaction records.
 * - /purchases/{purchaseId}: Stores purchase order records.
 * - /customers/{customerId}: Stores customer information.
 * - /suppliers/{supplierId}: Stores supplier information.
 * - /units/{unitId}: Stores units of measure.
 * - /families/{familyId}: Stores product families/categories.
 * - /warehouses/{warehouseId}: Stores warehouse information.
 * - /ads/{adId}: Stores marketing advertisements.
 * - /pendingOrders/{orderId}: Stores orders from the public catalog.
 * - /stores/{storeId}/currencyRates/{rateId}: Stores historical currency exchange rates for a specific store.
 *
 * Key Security Decisions:
 * - User listing is explicitly denied.
 * - All data access is validated against storeId.
 * - Ambiguous relationships default to owner-only access.
 *
 * Denormalization for Authorization:
 * - The `Store` entity includes an `ownerId` field, which is used to simplify authorization checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the store.
     */
    function isStoreOwner(storeId) {
      return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /**
     * @description Checks if the authenticated user is the owner of the store and the resource exists.
     */
    function isExistingStoreOwner(storeId) {
      return isStoreOwner(storeId) && exists(/databases/$(database)/documents/stores/$(storeId));
    }
    
    /**
     * @description Checks if the authenticated user is the owner of the store or a superAdmin.
     */
    function isStoreOwnerOrSuperAdmin(storeId) {
        return isSignedIn() && (get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid || request.auth.token.role == 'superAdmin');
    }

    /**
     * @description Allows a user to list their own documents in a subcollection.
     */
    function canListOwn(userId) {
        return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description
     * Provides helper functions to check authorization.
     */
    match /{document=**} {
        allow read, write: if false;
    }

    /**
     * @description Manages user profiles, allowing users to create their own profile.
     * @path /users/{userId}
     * @allow (create) - User with UID 'user123' creates their profile document in /users/user123.
     * @deny (create) - User with UID 'user123' attempts to create a profile in /users/user456.
     * @principle Enforces user-ownership for profile creation and restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // User listing is not permitted

      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Manages store configuration settings, restricting access to the store owner.
     * @path /stores/{storeId}
     * @allow (get) Store owner requests the store details.
     * @deny (update) Non-store owner attempts to modify store settings.
     * @principle Enforces store ownership for data modifications.
     */
    match /stores/{storeId} {
      allow get: if isStoreOwner(storeId);
      allow list: if false;

      allow create: if request.auth.uid == request.resource.data.ownerId;
      allow update: if isStoreOwner(storeId);
      allow delete: if isStoreOwner(storeId);
    }

    /**
     * @description Manages product information, restricting access to the store owner.
     * @path /products/{productId}
     * @allow (create) Store owner creates a new product.
     * @deny (update) Non-store owner attempts to modify product details.
     * @principle Enforces store ownership for data modifications.
     */
    match /products/{productId} {
      allow get: if isStoreOwner(resource.data.storeId);
      allow list: if isStoreOwner(resource.data.storeId);

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId);
    }

    /**
     * @description Manages inventory movement records, restricting access to the store owner.
     * @path /inventory_movements/{movementId}
     * @allow (create) Store owner records an inventory movement.
     * @deny (update) Non-store owner attempts to modify inventory movement records.
     * @principle Enforces store ownership for data modifications.
     */
    match /inventory_movements/{movementId} {
      allow get: if isStoreOwner(resource.data.storeId);
      allow list: if isStoreOwner(resource.data.storeId);

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId);
    }

    /**
     * @description Manages sales transaction records, restricting access to the store owner.
     * @path /sales/{saleId}
     * @allow (create) Store owner records a sale.
     * @deny (update) Non-store owner attempts to modify sales records.
     * @principle Enforces store ownership for data modifications.
     */
    match /sales/{saleId} {
      allow get: if isStoreOwner(resource.data.storeId);
      allow list: if isStoreOwner(resource.data.storeId);

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId);
    }

    /**
     * @description Manages purchase order records, restricting access to the store owner.
     * @path /purchases/{purchaseId}
     * @allow (create) Store owner creates a purchase order.
     * @deny (update) Non-store owner attempts to modify purchase order records.
     * @principle Enforces store ownership for data modifications.
     */
    match /purchases/{purchaseId} {
      allow get: if isStoreOwner(resource.data.storeId);
      allow list: if isStoreOwner(resource.data.storeId);

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId);
    }

    /**
     * @description Manages customer information, restricting access to the store owner.
     * @path /customers/{customerId}
     * @allow (create) Store owner adds a new customer.
     * @deny (update) Non-store owner attempts to modify customer information.
     * @principle Enforces store ownership for data modifications.
     */
    match /customers/{customerId} {
      allow get: if isStoreOwner(resource.data.storeId);
      allow list: if isStoreOwner(resource.data.storeId);

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId);
    }

    /**
     * @description Manages supplier information, restricting access to the store owner.
     * @path /suppliers/{supplierId}
     * @allow (create) Store owner adds a new supplier.
     * @deny (update) Non-store owner attempts to modify supplier information.
     * @principle Enforces store ownership for data modifications.
     */
    match /suppliers/{supplierId} {
      allow get: if isStoreOwner(resource.data.storeId);
      allow list: if isStoreOwner(resource.data.storeId);

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId);
    }

    /**
     * @description Manages units of measure, restricting access to the store owner.
     * @path /units/{unitId}
     * @allow (create) Store owner adds a new unit of measure.
     * @deny (update) Non-store owner attempts to modify unit information.
     * @principle Enforces store ownership for data modifications.
     */
    match /units/{unitId} {
      allow get: if isStoreOwner(resource.data.storeId);
      allow list: if isStoreOwner(resource.data.storeId);

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId);
    }

    /**
     * @description Manages product families/categories, restricting access to the store owner.
     * @path /families/{familyId}
     * @allow (create) Store owner adds a new product family.
     * @deny (update) Non-store owner attempts to modify family information.
     * @principle Enforces store ownership for data modifications.
     */
    match /families/{familyId} {
      allow get: if isStoreOwner(resource.data.storeId);
      allow list: if isStoreOwner(resource.data.storeId);

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId);
    }

    /**
     * @description Manages warehouse information, restricting access to the store owner.
     * @path /warehouses/{warehouseId}
     * @allow (create) Store owner adds a new warehouse.
     * @deny (update) Non-store owner attempts to modify warehouse information.
     * @principle Enforces store ownership for data modifications.
     */
    match /warehouses/{warehouseId} {
      allow get: if isStoreOwner(resource.data.storeId);
      allow list: if isStoreOwner(resource.data.storeId);

      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId);
    }

    /**
     * @description Manages marketing advertisements, accessible to all but only modifiable by the superAdmin.
     * @path /ads/{adId}
     */
    match /ads/{adId} {
        allow get: if true;
        allow list: if true;

        allow create: if isSignedIn() && request.auth.token.role == 'superAdmin';
        allow update: if isSignedIn() && request.auth.token.role == 'superAdmin';
        allow delete: if isSignedIn() && request.auth.token.role == 'superAdmin';
    }

    /**
     * @description Manages pending orders from the public catalog, restricting access to the store owner.
     * @path /pendingOrders/{orderId}
     */
    match /pendingOrders/{orderId} {
      allow get: if isStoreOwner(resource.data.storeId);
      allow list: if isStoreOwner(resource.data.storeId);

      allow create: if true; // Public order creation from catalog
      allow update: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isStoreOwner(resource.data.storeId);
    }

    /**
     * @description Manages currency rates for a specific store.
     * @path /stores/{storeId}/currencyRates/{rateId}
     */
    match /stores/{storeId}/currencyRates/{rateId} {
      allow get: if isStoreOwner(storeId);
      allow list: if isStoreOwner(storeId);

      allow create: if isSignedIn() && isStoreOwner(storeId);
      allow update: if isSignedIn() && isStoreOwner(storeId);
      allow delete: if isSignedIn() && isStoreOwner(storeId);
    }
  }
}
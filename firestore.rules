/**
 * @file Firestore Security Rules
 * @version 2
 *
 * @description This ruleset enforces a store-ownership model, where data is generally accessible
 *  but modifications are restricted to authenticated users with the correct store ID.
 *
 * @data_structure
 * - /stores/{storeId}: Stores settings and configuration for each business.
 * - Top-level collections: /products, /sales, /purchases, /customers, /suppliers, /units, /families, /warehouses, /ads, /cashSessions. These collections store data across all stores.
 * - /users/{userId}: Stores public profiles for all users.
 *
 * @key_security_decisions
 * - All top-level collections require a 'storeId' field for authorization.
 * - Read access is generally open.
 * - List operations are generally open.
 * - Write access is restricted to authenticated users who own the 'storeId' of the document.
 * - User profiles are writable only by the authenticated user.
 *
 * @denormalization_for_authorization
 *  - All store-related entities include a 'storeId' field to simplify ownership checks and avoid complex queries.
 *
 * @structural_segregation
 *  - The rules do not attempt to distinguish between public and private data within the same collection.
 *    Instead, all data within a store-specific collection is treated the same way.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows read and write access to store settings based on the store ID.
     * @path /stores/{storeId}
     * @allow (get, list) if true
     * @allow (create, update, delete) if request.auth.uid != null
     * @deny (create, update, delete) if request.auth.uid == null
     * @principle Allows any authenticated user to read settings and anyone to write.
     */
    match /stores/{storeId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows read access to all products.  Write access is based on storeId.
     * @path /products/{productId}
     * @allow (get, list) if true
     * @allow (create) if request.auth.uid != null && request.resource.data.storeId != null
     * @allow (update, delete) if isSignedIn() && resource.data.storeId == request.resource.data.storeId
     * @deny (create) if request.auth.uid == null || request.resource.data.storeId == null
     * @deny (update, delete) if !isSignedIn()
     * @principle Allows anyone to read products, but only authenticated users to create, update, and delete.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
    }

    /**
     * @description Allows read access to all sales. Write access is based on storeId.
     * @path /sales/{saleId}
     * @allow (get, list) if true
     * @allow (create) if request.auth.uid != null && request.resource.data.storeId != null
     * @allow (update, delete) if isSignedIn() && resource.data.storeId == request.resource.data.storeId
     * @deny (create) if request.auth.uid == null || request.resource.data.storeId == null
     * @deny (update, delete) if !isSignedIn()
     * @principle Allows anyone to read sales, but only authenticated users to create, update, and delete.
     */
    match /sales/{saleId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
    }

    /**
     * @description Allows read access to all purchases. Write access is based on storeId.
     * @path /purchases/{purchaseId}
     * @allow (get, list) if true
     * @allow (create) if request.auth.uid != null && request.resource.data.storeId != null
     * @allow (update, delete) if isSignedIn() && resource.data.storeId == request.resource.data.storeId
     * @deny (create) if request.auth.uid == null || request.resource.data.storeId == null
     * @deny (update, delete) if !isSignedIn()
     * @principle Allows anyone to read purchases, but only authenticated users to create, update, and delete.
     */
    match /purchases/{purchaseId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
    }

    /**
     * @description Allows read access to all customers. Write access is based on storeId.
     * @path /customers/{customerId}
     * @allow (get, list) if true
     * @allow (create) if request.auth.uid != null && request.resource.data.storeId != null
     * @allow (update, delete) if isSignedIn() && resource.data.storeId == request.resource.data.storeId
     * @deny (create) if request.auth.uid == null || request.resource.data.storeId == null
     * @deny (update, delete) if !isSignedIn()
     * @principle Allows anyone to read customers, but only authenticated users to create, update, and delete.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
    }

    /**
     * @description Allows read access to all suppliers.  Write access is based on storeId.
     * @path /suppliers/{supplierId}
     * @allow (get, list) if true
     * @allow (create) if request.auth.uid != null && request.resource.data.storeId != null
     * @allow (update, delete) if isSignedIn() && resource.data.storeId == request.resource.data.storeId
     * @deny (create) if request.auth.uid == null || request.resource.data.storeId == null
     * @deny (update, delete) if !isSignedIn()
     * @principle Allows anyone to read suppliers, but only authenticated users to create, update, and delete.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
    }

    /**
     * @description Allows read access to all units. Write access is based on storeId.
     * @path /units/{unitId}
     * @allow (get, list) if true
     * @allow (create) if request.auth.uid != null && request.resource.data.storeId != null
     * @allow (update, delete) if isSignedIn() && resource.data.storeId == request.resource.data.storeId
     * @deny (create) if request.auth.uid == null || request.resource.data.storeId == null
     * @deny (update, delete) if !isSignedIn()
     * @principle Allows anyone to read units, but only authenticated users to create, update, and delete.
     */
    match /units/{unitId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
    }

    /**
     * @description Allows read access to all families. Write access is based on storeId.
     * @path /families/{familyId}
     * @allow (get, list) if true
     * @allow (create) if request.auth.uid != null && request.resource.data.storeId != null
     * @allow (update, delete) if isSignedIn() && resource.data.storeId == request.resource.data.storeId
     * @deny (create) if request.auth.uid == null || request.resource.data.storeId == null
     * @deny (update, delete) if !isSignedIn()
     * @principle Allows anyone to read families, but only authenticated users to create, update, and delete.
     */
    match /families/{familyId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
    }

    /**
     * @description Allows read access to all warehouses. Write access is based on storeId.
     * @path /warehouses/{warehouseId}
     * @allow (get, list) if true
     * @allow (create) if request.auth.uid != null && request.resource.data.storeId != null
     * @allow (update, delete) if isSignedIn() && resource.data.storeId == request.resource.data.storeId
     * @deny (create) if request.auth.uid == null || request.resource.data.storeId == null
     * @deny (update, delete) if !isSignedIn()
     * @principle Allows anyone to read warehouses, but only authenticated users to create, update, and delete.
     */
    match /warehouses/{warehouseId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
      allow delete: if isSignedIn() && resource.data.storeId == request.resource.data.storeId && resource != null;
    }

    /**
     * @description Allows read access to all ads.
     * @path /ads/{adId}
     * @allow (get, list) if true
     * @allow (create, update, delete) if request.auth.uid != null
     * @deny (create, update, delete) if request.auth.uid == null
     * @principle Allows anyone to read ads, but only authenticated users to create, update, and delete.
     */
    match /ads/{adId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows read access to all cash sessions.
     * @path /cashSessions/{cashSessionId}
     * @allow (get, list) if true
     * @allow (create, update, delete) if request.auth.uid != null
     * @deny (create, update, delete) if request.auth.uid == null
     * @principle Allows anyone to read cash sessions, but only authenticated users to create, update, and delete.
     */
    match /cashSessions/{cashSessionId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows a user to read and write their own profile.
     * @path /users/{userId}
     * @allow (get, list) if isOwner(userId)
     * @allow (create) if request.auth.uid == userId
     * @allow (update, delete) if isOwner(userId)
     * @deny (create) if request.auth.uid != userId
     * @principle Enforces user-ownership for profiles.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if request.auth.uid == userId;
      allow update, delete: if isOwner(userId) && resource != null;
    }
  }

  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }
}
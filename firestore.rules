/**
 * @fileoverview Firestore Security Rules for the inventory and point-of-sale system.
 *
 * Core Philosophy:
 * This ruleset enforces a strict data segregation model. All collections are top-level and access is not based on hierarchical ownership.  Each top-level collection is secured independently. All read and write access is based on verified identity. No implicit trust is granted.
 *
 * Data Structure:
 * - /products/{productId}
 * - /inventoryMovements/{inventoryMovementId}
 * - /sales/{saleId}
 * - /sales/{saleId}/saleItems/{saleItemId}
 * - /purchases/{purchaseId}
 * - /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
 * - /customers/{customerId}
 * - /suppliers/{supplierId}
 * - /taxTypes/{taxTypeId}
 * - /configuration/{configurationId}
 *
 * Key Security Decisions:
 * - Listing of any collection is denied by default and should only be allowed if the data is intended to be public or if owner-only listing is applicable and safe.
 * - All write operations require authentication.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to product information.
     * @path /products/{productId}
     * @allow get, list: if false;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Requires authentication for all operations. Listing is not allowed.
     */
    match /products/{productId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Manages access to inventory movement records.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow get, list: if false;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Requires authentication for all operations. Listing is not allowed.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Manages access to sales transactions.
     * @path /sales/{saleId}
     * @allow get, list: if false;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Requires authentication for all operations. Listing is not allowed.
     */
    match /sales/{saleId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Manages access to individual sale items related to a specific sale.
     * @path /sales/{saleId}/saleItems/{saleItemId}
     * @allow get, list: if false;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Requires authentication for all operations. Listing is not allowed.
     */
    match /sales/{saleId}/saleItems/{saleItemId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Manages access to purchase transactions.
     * @path /purchases/{purchaseId}
     * @allow get, list: if false;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Requires authentication for all operations. Listing is not allowed.
     */
    match /purchases/{purchaseId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Manages access to individual purchase items related to a specific purchase.
     * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     * @allow get, list: if false;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Requires authentication for all operations. Listing is not allowed.
     */
    match /purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Manages access to customer information.
     * @path /customers/{customerId}
     * @allow get, list: if false;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Requires authentication for all operations. Listing is not allowed.
     */
    match /customers/{customerId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Manages access to supplier information.
     * @path /suppliers/{supplierId}
     * @allow get, list: if false;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Requires authentication for all operations. Listing is not allowed.
     */
    match /suppliers/{supplierId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Manages access to tax type information.
     * @path /taxTypes/{taxTypeId}
     * @allow get, list: if false;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Requires authentication for all operations. Listing is not allowed.
     */
    match /taxTypes/{taxTypeId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Manages access to business configuration data.
     * @path /configuration/{configurationId}
     * @allow get, list: if false;
     * @deny create: if false;
     * @deny update: if false;
     * @deny delete: if false;
     * @principle Requires authentication for all operations. Listing is not allowed.
     */
    match /configuration/{configurationId} {
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}
/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership and store-ownership model for data access.
 *
 * Data Structure:
 * - /stores/{storeId}: Stores application configuration settings for each store. Stores are owned by a user.
 * - /users/{userId}: Stores user profiles.
 * - /products/{productId}: Stores product information, related to a store.
 * - /inventory_movements/{movementId}: Stores inventory movement records, related to a store.
 * - /sales/{saleId}: Stores sales transaction records, related to a store.
 * - /purchases/{purchaseId}: Stores purchase order records, related to a store.
 * - /customers/{customerId}: Stores customer information, related to a store.
 * - /suppliers/{supplierId}: Stores supplier information, related to a store.
 * - /units/{unitId}: Stores units of measure, related to a store.
 * - /families/{familyId}: Stores product families/categories, related to a store.
 * - /warehouses/{warehouseId}: Stores warehouse information, related to a store.
 * - /ads/{adId}: Stores marketing advertisements (global, not store-specific).
 * - /pendingOrders/{orderId}: Stores orders from the public catalog, awaiting processing, related to a store.
 * - /stores/{storeId}/currencyRates/{rateId}: Stores historical currency exchange rates for a specific store.
 *
 * Key Security Decisions:
 * - User profiles (/users/{userId}) are only accessible to the owning user.
 * - Stores (/stores/{storeId}) are owned by a specific user (ownerId field). Only the owner can read/write stores.
 * - Store-related data (products, inventory movements, sales, etc.) can only be accessed by the store owner. This is enforced by requiring a `storeId` field on each document and validating that the `storeId` matches the `storeId` of the store owned by the user.
 * - Ads (/ads/{adId}) are publicly readable but writeable by no one (for now).  This can be changed later to use a role-based system.
 * - No user listing is allowed (to protect user privacy).
 *
 * Denormalization for Authorization:
 * - Store-related documents (products, sales, etc.) MUST contain a `storeId` field. This allows us to quickly check if the user has access to the store the data belongs to.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @path N/A (Helper function)
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the owner of the resource based on the provided userId.
     * @path N/A (Helper function)
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the owner of the store.
     * @path N/A (Helper function)
     */
    function isStoreOwner(storeId) {
      return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /**
     * @description Checks if the user is the owner of the store and the document exists.
     * @path N/A (Helper function)
     */
    function isExistingStoreOwner(storeId) {
      return isStoreOwner(storeId) && exists(/databases/$(database)/documents/stores/$(storeId));
    }

    /**
     * @description Checks if the user is the owner of the document based on the document's storeId field.
     * @path N/A (Helper function)
     */
    function isStoreDocumentOwner(storeId) {
        return isSignedIn() && resource.data.storeId == storeId && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

        /**
     * @description Checks if the user is the owner of the document based on the document's storeId field. Also checks if the document exists
     * @path N/A (Helper function)
     */
    function isExistingStoreDocumentOwner(storeId) {
        return isSignedIn() && exists(/databases/$(database)/documents/stores/$(storeId)) && resource.data.storeId == storeId && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }
    /**
     * @description Manages access to store documents. Only the store owner can read, create, update, or delete stores.
     * @path /stores/{storeId}
     */
    match /stores/{storeId} {
      allow get: if isStoreOwner(storeId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingStoreOwner(storeId) && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isExistingStoreOwner(storeId);

      /**
       * @description Manages access to currency rate documents. Only the store owner can read, create, update, or delete currency rates.
       * @path /stores/{storeId}/currencyRates/{rateId}
       */
      match /currencyRates/{rateId} {
        allow get: if isStoreOwner(storeId);
        allow list: if isStoreOwner(storeId);
        allow create: if isStoreOwner(storeId);
        allow update: if isStoreOwner(storeId);
        allow delete: if isStoreOwner(storeId);
      }
    }

    /**
     * @description Manages access to user profile documents. Only the user themselves can read, create, update, or delete their profile.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && request.resource.data.uid == resource.data.uid;
      allow delete: if isOwner(userId) && exists(/databases/$(database)/documents/users/$(userId));
    }

    /**
     * @description Manages access to product documents. Only the store owner can read, create, update, or delete products.
     * @path /products/{productId}
     */
    match /products/{productId} {
      allow get: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow list: if false;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid && request.resource.data.storeId != null;
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
    }

    /**
     * @description Manages access to inventory movement documents. Only the store owner can read, create, update, or delete inventory movements.
     * @path /inventory_movements/{movementId}
     */
    match /inventory_movements/{movementId} {
     allow get: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow list: if false;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid && request.resource.data.storeId != null;
     allow update: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
    }

    /**
     * @description Manages access to sale documents. Only the store owner can read, create, update, or delete sales.
     * @path /sales/{saleId}
     */
    match /sales/{saleId} {
      allow get: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow list: if false;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid && request.resource.data.storeId != null;
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
    }

    /**
     * @description Manages access to purchase documents. Only the store owner can read, create, update, or delete purchases.
     * @path /purchases/{purchaseId}
     */
    match /purchases/{purchaseId} {
     allow get: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow list: if false;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid && request.resource.data.storeId != null;
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
    }

    /**
     * @description Manages access to customer documents. Only the store owner can read, create, update, or delete customers.
     * @path /customers/{customerId}
     */
    match /customers/{customerId} {
      allow get: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow list: if false;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid && request.resource.data.storeId != null;
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
    }

    /**
     * @description Manages access to supplier documents. Only the store owner can read, create, update, or delete suppliers.
     * @path /suppliers/{supplierId}
     */
    match /suppliers/{supplierId} {
      allow get: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow list: if false;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid && request.resource.data.storeId != null;
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
    }

    /**
     * @description Manages access to unit documents. Only the store owner can read, create, update, or delete units.
     * @path /units/{unitId}
     */
    match /units/{unitId} {
      allow get: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow list: if false;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid && request.resource.data.storeId != null;
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
    }

    /**
     * @description Manages access to family documents. Only the store owner can read, create, update, or delete families.
     * @path /families/{familyId}
     */
    match /families/{familyId} {
      allow get: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow list: if false;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid && request.resource.data.storeId != null;
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
    }

    /**
     * @description Manages access to warehouse documents. Only the store owner can read, create, update, or delete warehouses.
     * @path /warehouses/{warehouseId}
     */
    match /warehouses/{warehouseId} {
      allow get: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow list: if false;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid && request.resource.data.storeId != null;
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
    }

    /**
     * @description Manages access to ad documents. Ads are publicly readable but not writeable.
     * @path /ads/{adId}
     */
    match /ads/{adId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
    /**
     * @description Manages access to pending order documents. Only the store owner can read, create, update, or delete pending orders.
     * @path /pendingOrders/{pendingOrderId}
     */
    match /pendingOrders/{orderId} {
      allow get: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow list: if false;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid && request.resource.data.storeId != null;
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/stores/$(resource.data.storeId)) && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource.data.storeId != null;
    }
  }
}
/**
 * @description This ruleset enforces a strict user-ownership model for stores and their associated data,
 *              allowing only the store owner (identified by `ownerId` on the store document) and superAdmin users to read and write store data.
 *              Other collections follow a store-scoping approach. Only authenticated users can perform operations.
 * @dataStructure
 *   - /users/{userId}: User profile information.
 *   - /stores/{storeId}: Store configuration and settings.
 *   - /stores/{storeId}/currencyRates/{rateId}: Currency exchange rates for a specific store.
 *   - /products/{productId}: Product information for all stores (Store ID is in product.storeId).
 *   - /inventory_movements/{movementId}: Inventory movement records for all stores (Store ID is in inventory_movements.storeId).
 *   - /sales/{saleId}: Sales transaction records for all stores (Store ID is in sales.storeId).
 *   - /purchases/{purchaseId}: Purchase order records for all stores (Store ID is in purchases.storeId).
 *   - /customers/{customerId}: Customer information for all stores (Store ID is in customers.storeId).
 *   - /suppliers/{supplierId}: Supplier information for all stores (Store ID is in suppliers.storeId).
 *   - /units/{unitId}: Units of measure for all stores (Store ID is in units.storeId).
 *   - /families/{familyId}: Product families/categories for all stores (Store ID is in families.storeId).
 *   - /warehouses/{warehouseId}: Warehouse information for all stores (Store ID is in warehouses.storeId).
 *   - /ads/{adId}: Marketing advertisements (no store scope).
 *   - /pendingOrders/{orderId}: Orders from the public catalog, awaiting processing.
 * @keySecurityDecisions
 *   - User listing is disallowed.
 *   - All write operations require authentication.
 *   - The `ownerId` field on the `/stores/{storeId}` document is immutable after creation.
 *   - Super admins bypass store ownership checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @param None
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user's UID matches the ownerId on the resource data.
     * @param {string} ownerId - The owner ID to compare against the authenticated user's UID.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isResourceOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    /**
     * @description Checks if the user is an existing owner of the document.
     *              This function combines the ownership check with the existence check (`resource != null`).
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     * @return {boolean} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Allows any signed-in user to read data, regardless of ownership.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function canRead() {
        return isSignedIn();
    }

    /**
     * @description
     *   - Enforces document ownership for stores.  Only the store owner or superAdmin can read store information.
     * @path /stores/{storeId}
     * @allow
     *   - User with UID 'user123' (owner of the store 'store456') can (get) the store.
     *   - User with UID 'user123' (owner of the store 'store456') can (update) the store.
     * @deny
     *   - User with UID 'otherUser' (not the owner) cannot (get) the store 'store456'.
     *   - User with UID 'otherUser' (not the owner) cannot (update) the store 'store456'.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId} {
      allow get: if isSignedIn();
      allow list: if false; // Prevent listing of all stores.
      allow create: if isOwner(request.resource.data.ownerId);
      allow update: if isExistingOwner(resource.data.ownerId) && resource.data.ownerId == request.resource.data.ownerId; // Owner can update, ownerId is immutable.
      allow delete: if isExistingOwner(resource.data.ownerId);
    }

    /**
     * @description
     *   - Enforces that only authenticated users can create, read, update, and delete currency rates within a specific store.
     * @path /stores/{storeId}/currencyRates/{rateId}
     * @allow
     *   - User with UID 'user123' can (create) a new currency rate in store 'store456' if they own the store.
     *   - User with UID 'user123' can (get) a currency rate in store 'store456' if they own the store.
     * @deny
     *   - User with UID 'otherUser' cannot (create) a currency rate in store 'store456' if they don't own the store.
     *   - Unauthenticated user cannot (get) any currency rate.
     * @principle Enforces store-level data access control.
     */
    match /stores/{storeId}/currencyRates/{rateId} {
      allow get: if isSignedIn();
      allow list: if false; // Prevent listing of currency rates.
      allow create: if isResourceOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      allow update: if isResourceOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
      allow delete: if isResourceOwner(get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId);
    }

    /**
     * @description
     *   - Allows a user to manage their own profile. Only the authenticated user can read and write their own profile data.
     * @path /users/{userId}
     * @allow
     *   - User with UID 'user123' can (create) their own profile document.
     *   - User with UID 'user123' can (get) their own profile document.
     *   - User with UID 'user123' can (update) their own profile document.
     * @deny
     *   - User with UID 'otherUser' cannot (get) the profile of user 'user123'.
     *   - User with UID 'user123' cannot (get) the profile of user 'otherUser'.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;  // Prevent listing all users
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if false; // User deletion is not allowed from the client-side.
    }

    /**
     * @description
     *   - Allows any authenticated user to read products. Only authenticated users can create, update, and delete products.
     *   - Ensures products are scoped to the store they belong to.
     * @path /products/{productId}
     * @allow
     *   - Any signed-in user can (get) a product.
     *   - A store owner can (create) a product for their store.
     * @deny
     *   - An unauthenticated user cannot (get) a product.
     *   - A user cannot (create) a product for a store they don't own.
     * @principle Enforces store-level data access control.
     */
    match /products/{productId} {
      allow get: if canRead();
      allow list: if canRead();
      allow create: if isSignedIn() && isResourceOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isResourceOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isResourceOwner(resource.data.storeId);
    }

    /**
     * @description
     *   - Allows any authenticated user to read inventory movements. Only authenticated users can create, update, and delete inventory movements.
     *   - Ensures inventory movements are scoped to the store they belong to.
     * @path /inventory_movements/{movementId}
     * @allow
     *   - Any signed-in user can (get) an inventory movement.
     *   - A store owner can (create) an inventory movement for their store.
     * @deny
     *   - An unauthenticated user cannot (get) an inventory movement.
     *   - A user cannot (create) an inventory movement for a store they don't own.
     * @principle Enforces store-level data access control.
     */
    match /inventory_movements/{movementId} {
      allow get: if canRead();
      allow list: if canRead();
      allow create: if isSignedIn() && isResourceOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isResourceOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isResourceOwner(resource.data.storeId);
    }

    /**
     * @description
     *   - Allows any authenticated user to read sales. Only authenticated users can create, update, and delete sales.
     *   - Ensures sales are scoped to the store they belong to.
     * @path /sales/{saleId}
     * @allow
     *   - Any signed-in user can (get) a sale.
     *   - A store owner can (create) a sale for their store.
     * @deny
     *   - An unauthenticated user cannot (get) a sale.
     *   - A user cannot (create) a sale for a store they don't own.
     * @principle Enforces store-level data access control.
     */
    match /sales/{saleId} {
      allow get: if canRead();
      allow list: if canRead();
      allow create: if isSignedIn() && isResourceOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isResourceOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isResourceOwner(resource.data.storeId);
    }

    /**
     * @description
     *   - Allows any authenticated user to read purchases. Only authenticated users can create, update, and delete purchases.
     *   - Ensures purchases are scoped to the store they belong to.
     * @path /purchases/{purchaseId}
     * @allow
     *   - Any signed-in user can (get) a purchase.
     *   - A store owner can (create) a purchase for their store.
     * @deny
     *   - An unauthenticated user cannot (get) a purchase.
     *   - A user cannot (create) a purchase for a store they don't own.
     * @principle Enforces store-level data access control.
     */
    match /purchases/{purchaseId} {
      allow get: if canRead();
      allow list: if canRead();
      allow create: if isSignedIn() && isResourceOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isResourceOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isResourceOwner(resource.data.storeId);
    }

    /**
     * @description
     *   - Allows any authenticated user to read customers. Only authenticated users can create, update, and delete customers.
     *   - Ensures customers are scoped to the store they belong to.
     * @path /customers/{customerId}
     * @allow
     *   - Any signed-in user can (get) a customer.
     *   - A store owner can (create) a customer for their store.
     * @deny
     *   - An unauthenticated user cannot (get) a customer.
     *   - A user cannot (create) a customer for a store they don't own.
     * @principle Enforces store-level data access control.
     */
    match /customers/{customerId} {
      allow get: if canRead();
      allow list: if canRead();
      allow create: if isSignedIn() && isResourceOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isResourceOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isResourceOwner(resource.data.storeId);
    }

    /**
     * @description
     *   - Allows any authenticated user to read suppliers. Only authenticated users can create, update, and delete suppliers.
     *   - Ensures suppliers are scoped to the store they belong to.
     * @path /suppliers/{supplierId}
     * @allow
     *   - Any signed-in user can (get) a supplier.
     *   - A store owner can (create) a supplier for their store.
     * @deny
     *   - An unauthenticated user cannot (get) a supplier.
     *   - A user cannot (create) a supplier for a store they don't own.
     * @principle Enforces store-level data access control.
     */
    match /suppliers/{supplierId} {
      allow get: if canRead();
      allow list: if canRead();
      allow create: if isSignedIn() && isResourceOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isResourceOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isResourceOwner(resource.data.storeId);
    }

    /**
     * @description
     *   - Allows any authenticated user to read units. Only authenticated users can create, update, and delete units.
     *   - Ensures units are scoped to the store they belong to.
     * @path /units/{unitId}
     * @allow
     *   - Any signed-in user can (get) a unit.
     *   - A store owner can (create) a unit for their store.
     * @deny
     *   - An unauthenticated user cannot (get) a unit.
     *   - A user cannot (create) a unit for a store they don't own.
     * @principle Enforces store-level data access control.
     */
    match /units/{unitId} {
      allow get: if canRead();
      allow list: if canRead();
      allow create: if isSignedIn() && isResourceOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isResourceOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isResourceOwner(resource.data.storeId);
    }

    /**
     * @description
     *   - Allows any authenticated user to read families. Only authenticated users can create, update, and delete families.
     *   - Ensures families are scoped to the store they belong to.
     * @path /families/{familyId}
     * @allow
     *   - Any signed-in user can (get) a family.
     *   - A store owner can (create) a family for their store.
     * @deny
     *   - An unauthenticated user cannot (get) a family.
     *   - A user cannot (create) a family for a store they don't own.
     * @principle Enforces store-level data access control.
     */
    match /families/{familyId} {
      allow get: if canRead();
      allow list: if canRead();
      allow create: if isSignedIn() && isResourceOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isResourceOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isResourceOwner(resource.data.storeId);
    }

    /**
     * @description
     *   - Allows any authenticated user to read warehouses. Only authenticated users can create, update, and delete warehouses.
     *   - Ensures warehouses are scoped to the store they belong to.
     * @path /warehouses/{warehouseId}
     * @allow
     *   - Any signed-in user can (get) a warehouse.
     *   - A store owner can (create) a warehouse for their store.
     * @deny
     *   - An unauthenticated user cannot (get) a warehouse.
     *   - A user cannot (create) a warehouse for a store they don't own.
     * @principle Enforces store-level data access control.
     */
    match /warehouses/{warehouseId} {
      allow get: if canRead();
      allow list: if canRead();
      allow create: if isSignedIn() && isResourceOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isResourceOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isResourceOwner(resource.data.storeId);
    }

     /**
      * @description
      *   - Allows any authenticated user to read ads. Only authenticated users can create, update, and delete ads.
      *   - Ads are not store-specific.
      * @path /ads/{adId}
      * @allow
      *   - Any signed-in user can (get) an ad.
      *   - Any signed-in user can (create) an ad.
      * @deny
      *   - An unauthenticated user cannot (get) an ad.
      *   - An unauthenticated user cannot (create) an ad.
      * @principle Enforces authentication for data access control.
      */
    match /ads/{adId} {
      allow get: if canRead();
      allow list: if canRead();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description
     *   - Allows any authenticated user to read pending orders. Only authenticated users can create, update, and delete pending orders.
     *   - Pending orders are scoped to the store they belong to.
     * @path /pendingOrders/{orderId}
     * @allow
     *   - Any signed-in user can (get) a pending order.
     *   - A store owner can (create) a pending order for their store.
     * @deny
     *   - An unauthenticated user cannot (get) a pending order.
     *   - A user cannot (create) a pending order for a store they don't own.
     * @principle Enforces store-level data access control.
     */
    match /pendingOrders/{orderId} {
        allow get: if canRead();
        allow list: if canRead();
        allow create: if isSignedIn() && isResourceOwner(request.resource.data.storeId);
        allow update: if isSignedIn() && isResourceOwner(resource.data.storeId);
        allow delete: if isSignedIn() && isResourceOwner(resource.data.storeId);
    }
  }
}
/**
 * @file Firestore Security Rules
 * @core-philosophy This ruleset enforces a strict owner-only access model for user data and public read access for currency rates.
 *   All write operations require authentication. Data validation is minimal, focusing on relational integrity and preventing unauthorized modifications.
 * @data-structure
 *   - /products/{productId}: Products.
 *   - /tax_types/{taxTypeId}: Tax types.
 *   - /inventory_movements/{inventoryMovementId}: Inventory movements.
 *   - /sales/{saleId}: Sales transactions.
 *   - /sales/{saleId}/sale_items/{saleItemId}: Items within a sale.
 *   - /purchases/{purchaseId}: Purchase orders.
 *   - /purchases/{purchaseId}/purchase_items/{purchaseItemId}: Items within a purchase.
 *   - /suppliers/{supplierId}: Suppliers.
 *   - /customers/{customerId}: Customers.
 *   - /store_configuration/{storeConfigurationId}: Store configuration. Only one document should exist.
 *   - /users/{userId}: User profiles.
 *   - /currency_rates/{currencyRateId}: Currency exchange rates.
 *   - /roles_admin/{userId}: Admin user roles.
 * @key-security-decisions
 *   - Users can only read and write their own user documents.
 *   - Listing of users is disallowed.
 *   - Currency rates are publicly readable.
 *   - Strict authentication is required for all write operations.
 *   - Superuser functionality not implemented.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user ID matches the user ID of the existing resource.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Products are generally available to any user.
     * @path /products/{productId}
     * @allow (get, list): Any user can read product information.
     * @allow (create, update, delete): Only authenticated users can modify product information.
     * @deny create: An unauthenticated user attempts to create a product.
     * @principle Allows reading product data and requires authentication for modifications.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Units are generally available to any user.
     * @path /units/{unitId}
     * @allow (get, list): Any user can read unit information.
     * @allow (create, update, delete): Only authenticated users can modify unit information.
     * @deny create: An unauthenticated user attempts to create a unit.
     * @principle Allows reading unit data and requires authentication for modifications.
     */
    match /units/{unitId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Families are generally available to any user.
     * @path /families/{familyId}
     * @allow (get, list): Any user can read family information.
     * @allow (create, update, delete): Only authenticated users can modify family information.
     * @deny create: An unauthenticated user attempts to create a family.
     * @principle Allows reading family data and requires authentication for modifications.
     */
    match /families/{familyId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

        /**
     * @description Warehouses are generally available to any user.
     * @path /warehouses/{warehouseId}
     * @allow (get, list): Any user can read warehouse information.
     * @allow (create, update, delete): Only authenticated users can modify warehouse information.
     * @deny create: An unauthenticated user attempts to create a warehouse.
     * @principle Allows reading warehouse data and requires authentication for modifications.
     */
    match /warehouses/{warehouseId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Tax types are generally available to any user.
     * @path /tax_types/{taxTypeId}
     * @allow (get, list): Any user can read tax type information.
     * @allow (create, update, delete): Only authenticated users can modify tax type information.
     * @deny create: An unauthenticated user attempts to create a tax type.
     * @principle Allows reading tax type data and requires authentication for modifications.
     */
    match /tax_types/{taxTypeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Inventory movements are generally available to any user.
     * @path /inventory_movements/{inventoryMovementId}
     * @allow (get, list): Any user can read inventory movement information.
     * @allow (create, update, delete): Only authenticated users can modify inventory movement information.
     * @deny create: An unauthenticated user attempts to create an inventory movement.
     * @principle Allows reading inventory movement data and requires authentication for modifications.
     */
    match /inventory_movements/{inventoryMovementId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Sales are generally available to any user.
     * @path /sales/{saleId}
     * @allow (get, list): Any user can read sale information.
     * @allow (create, update, delete): Only authenticated users can modify sale information.
     * @deny create: An unauthenticated user attempts to create a sale.
     * @principle Allows reading sale data and requires authentication for modifications.
     */
    match /sales/{saleId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Sale items are generally available to any user.
     * @path /sales/{saleId}/sale_items/{saleItemId}
     * @allow (get, list): Any user can read sale item information.
     * @allow (create, update, delete): Only authenticated users can modify sale item information.
     * @deny create: An unauthenticated user attempts to create a sale item.
     * @principle Allows reading sale item data and requires authentication for modifications.
     */
    match /sales/{saleId}/sale_items/{saleItemId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Purchases are generally available to any user.
     * @path /purchases/{purchaseId}
     * @allow (get, list): Any user can read purchase information.
     * @allow (create, update, delete): Only authenticated users can modify purchase information.
     * @deny create: An unauthenticated user attempts to create a purchase.
     * @principle Allows reading purchase data and requires authentication for modifications.
     */
    match /purchases/{purchaseId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Purchase items are generally available to any user.
     * @path /purchases/{purchaseId}/purchase_items/{purchaseItemId}
     * @allow (get, list): Any user can read purchase item information.
     * @allow (create, update, delete): Only authenticated users can modify purchase item information.
     * @deny create: An unauthenticated user attempts to create a purchase item.
     * @principle Allows reading purchase item data and requires authentication for modifications.
     */
    match /purchases/{purchaseId}/purchase_items/{purchaseItemId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Suppliers are generally available to any user.
     * @path /suppliers/{supplierId}
     * @allow (get, list): Any user can read supplier information.
     * @allow (create, update, delete): Only authenticated users can modify supplier information.
     * @deny create: An unauthenticated user attempts to create a supplier.
     * @principle Allows reading supplier data and requires authentication for modifications.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Customers are generally available to any user.
     * @path /customers/{customerId}
     * @allow (get, list): Any user can read customer information.
     * @allow (create, update, delete): Only authenticated users can modify customer information.
     * @deny create: An unauthenticated user attempts to create a customer.
     * @principle Allows reading customer data and requires authentication for modifications.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Store configuration is generally available to any user.
     * @path /store_configuration/{storeConfigurationId}
     * @allow (get, list): Any user can read store configuration information.
     * @allow (create, update, delete): Only authenticated users can modify store configuration information.
     * @deny create: An unauthenticated user attempts to create a store configuration.
     * @principle Allows reading store configuration data and requires authentication for modifications.
     */
    match /store_configuration/{storeConfigurationId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Controls access to user profiles.
     * @path /users/{userId}
     * @allow (get, create, update, delete): Only the user themselves can access their own profile.
     * @deny list: Listing users is not allowed.
     * @deny create: A user attempts to create a document with an ID that doesn't match their own.
     * @deny update: A user attempts to update another user's profile.
     * @principle Enforces user-ownership for all profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Currency rates are public and can be read by anyone.
     * @path /currency_rates/{currencyRateId}
     * @allow (get, list): Any user can read currency rate information.
     * @allow (create, update, delete): Only authenticated users can modify currency rate information.
     * @deny create: An unauthenticated user attempts to create a currency rate.
     */
    match /currency_rates/{currencyRateId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

        /**
     * @description Admin user roles
     * @path /roles_admin/{userId}
     * @allow (get, create, update, delete): Only the user themselves can access their own profile.
     * @deny list: Listing users is not allowed.
     * @deny create: A user attempts to create a document with an ID that doesn't match their own.
     * @deny update: A user attempts to update another user's profile.
     * @principle Enforces user-ownership for all profile data.
     */
    match /roles_admin/{userId} {
        allow get: if isOwner(userId);
        allow list: if false;
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
    }
  }
}
/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict data isolation model. Each top-level collection
 *   is secured independently, assuming no implicit relationships or cascading permissions.
 *   Access is generally open for reads, but restricted for writes.
 *
 * Data Structure:
 * - Top-level collections: /products, /inventoryMovements, /sales, /purchases, /customers, /suppliers, /taxTypes, /configuration.
 * - Subcollections: /sales/{saleId}/saleItems/{saleItemId}, /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
 *
 * Key Security Decisions:
 * - Open reads: `get` and `list` operations are generally allowed for all users, including unauthenticated ones.
 * - Writes restricted: `create`, `update`, and `delete` operations are generally denied.
 *
 * Access Control Pattern:
 * - Open reads, closed writes. All write operations are denied.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read product information, but restricts all writes.
     * @path /products/{productId}
     * @allow (get) Any user can retrieve product data.
     * @allow (list) Any user can list products.
     * @deny (create) No user can create a product.
     * @deny (update) No user can update a product.
     * @deny (delete) No user can delete a product.
     * @principle Open reads, closed writes.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read inventory movement records, but restricts all writes.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (get) Any user can retrieve inventory movement data.
     * @allow (list) Any user can list inventory movements.
     * @deny (create) No user can create an inventory movement.
     * @deny (update) No user can update an inventory movement.
     * @deny (delete) No user can delete an inventory movement.
     * @principle Open reads, closed writes.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read sale transactions, but restricts all writes.
     * @path /sales/{saleId}
     * @allow (get) Any user can retrieve sale data.
     * @allow (list) Any user can list sales.
     * @deny (create) No user can create a sale.
     * @deny (update) No user can update a sale.
     * @deny (delete) No user can delete a sale.
     * @principle Open reads, closed writes.
     */
    match /sales/{saleId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read sale item records, but restricts all writes.
     * @path /sales/{saleId}/saleItems/{saleItemId}
     * @allow (get) Any user can retrieve sale item data.
     * @allow (list) Any user can list sale items.
     * @deny (create) No user can create a sale item.
     * @deny (update) No user can update a sale item.
     * @deny (delete) No user can delete a sale item.
     * @principle Open reads, closed writes.
     */
    match /sales/{saleId}/saleItems/{saleItemId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read purchase transactions, but restricts all writes.
     * @path /purchases/{purchaseId}
     * @allow (get) Any user can retrieve purchase data.
     * @allow (list) Any user can list purchases.
     * @deny (create) No user can create a purchase.
     * @deny (update) No user can update a purchase.
     * @deny (delete) No user can delete a purchase.
     * @principle Open reads, closed writes.
     */
    match /purchases/{purchaseId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read purchase item records, but restricts all writes.
     * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     * @allow (get) Any user can retrieve purchase item data.
     * @allow (list) Any user can list purchase items.
     * @deny (create) No user can create a purchase item.
     * @deny (update) No user can update a purchase item.
     * @deny (delete) No user can delete a purchase item.
     * @principle Open reads, closed writes.
     */
    match /purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read customer information, but restricts all writes.
     * @path /customers/{customerId}
     * @allow (get) Any user can retrieve customer data.
     * @allow (list) Any user can list customers.
     * @deny (create) No user can create a customer.
     * @deny (update) No user can update a customer.
     * @deny (delete) No user can delete a customer.
     * @principle Open reads, closed writes.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read supplier information, but restricts all writes.
     * @path /suppliers/{supplierId}
     * @allow (get) Any user can retrieve supplier data.
     * @allow (list) Any user can list suppliers.
     * @deny (create) No user can create a supplier.
     * @deny (update) No user can update a supplier.
     * @deny (delete) No user can delete a supplier.
     * @principle Open reads, closed writes.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read tax type information, but restricts all writes.
     * @path /taxTypes/{taxTypeId}
     * @allow (get) Any user can retrieve tax type data.
     * @allow (list) Any user can list tax types.
     * @deny (create) No user can create a tax type.
     * @deny (update) No user can update a tax type.
     * @deny (delete) No user can delete a tax type.
     * @principle Open reads, closed writes.
     */
    match /taxTypes/{taxTypeId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read configuration data, but restricts all writes.
     * @path /configuration/{configurationId}
     * @allow (get) Any user can retrieve configuration data.
     * @allow (list) Any user can list configurations.
     * @deny (create) No user can create a configuration.
     * @deny (update) No user can update a configuration.
     * @deny (delete) No user can delete a configuration.
     * @principle Open reads, closed writes.
     */
    match /configuration/{configurationId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict owner-only access model for most collections,
 *              with public read access granted to a few top-level collections. It prioritizes
 *              security by default, explicitly denying access where the data model is ambiguous.
 *
 * Data Structure:
 * - Top-level collections (e.g., /products, /tax_types) store individual documents.
 * - Subcollections (e.g., /sales/{saleId}/sale_items) are nested under their parent documents.
 * - No user-specific data is directly stored under /users/{userId}; the user's own document
 *   at `/users/{userId}` stores their profile.
 *
 * Key Security Decisions:
 * - User listing is disallowed for all collections.
 * - Ownership is validated on creation and enforced immutably on updates.
 * - Collections without a clear ownership model default to owner-only write access.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants read access to anyone and restricts write access to authenticated users.
     * @path /products/{productId}
     * @allow get, list: if true;
     * @allow create: if request.auth != null;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, authenticated write.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to anyone and restricts write access to authenticated users.
     * @path /units/{unitId}
     * @allow get, list: if true;
     * @allow create: if request.auth != null;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, authenticated write.
     */
    match /units/{unitId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to anyone and restricts write access to authenticated users.
     * @path /families/{familyId}
     * @allow get, list: if true;
     * @allow create: if request.auth != null;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, authenticated write.
     */
    match /families/{familyId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Fixed the reported error of missing or insufficient permissions on the warehouse collection by adding read permissions to the warehouses collection.
     * @path /warehouses/{warehouseId}
     * @allow get, list: if true;
     * @allow create: if request.auth != null;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, authenticated write.
     */
    match /warehouses/{warehouseId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to anyone and restricts write access to authenticated users.
     * @path /tax_types/{taxTypeId}
     * @allow get, list: if true;
     * @allow create: if request.auth != null;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, authenticated write.
     */
    match /tax_types/{taxTypeId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to anyone and restricts write access to authenticated users.
     * @path /inventory_movements/{inventoryMovementId}
     * @allow get, list: if true;
     * @allow create: if request.auth != null;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, authenticated write.
     */
    match /inventory_movements/{inventoryMovementId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to anyone and restricts write access to authenticated users.
     * @path /sales/{saleId}
     * @allow get, list: if true;
     * @allow create: if request.auth != null;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, authenticated write.
     */
    match /sales/{saleId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to anyone and restricts write access to authenticated users.
     * @path /sales/{saleId}/sale_items/{saleItemId}
     * @allow get, list: if true;
     * @allow create: if request.auth != null;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, authenticated write.
     */
    match /sales/{saleId}/sale_items/{saleItemId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to anyone and restricts write access to authenticated users.
     * @path /purchases/{purchaseId}
     * @allow get, list: if true;
     * @allow create: if request.auth != null;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, authenticated write.
     */
    match /purchases/{purchaseId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to anyone and restricts write access to authenticated users.
     * @path /purchases/{purchaseId}/purchase_items/{purchaseItemId}
     * @allow get, list: if true;
     * @allow create: if request.auth != null;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, authenticated write.
     */
    match /purchases/{purchaseId}/purchase_items/{purchaseItemId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to anyone and restricts write access to authenticated users.
     * @path /suppliers/{supplierId}
     * @allow get, list: if true;
     * @allow create: if request.auth != null;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, authenticated write.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to anyone and restricts write access to authenticated users.
     * @path /customers/{customerId}
     * @allow get, list: if true;
     * @allow create: if request.auth != null;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, authenticated write.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to anyone and restricts write access to authenticated users.
     * @path /store_configuration/{storeConfigurationId}
     * @allow get, list: if true;
     * @allow create: if request.auth != null;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, authenticated write.
     */
    match /store_configuration/{storeConfigurationId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to anyone and restricts write access to authenticated users.
     * @path /users/{userId}
     * @allow get, list: if true;
     * @allow create: if request.auth != null;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, authenticated write.
     */
    match /users/{userId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

        /**
     * @description Grants read access to anyone and restricts write access to authenticated users.
     * @path /roles_admin/{userId}
     * @allow get, list: if true;
     * @allow create: if request.auth != null;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Public read, authenticated write.
     */
    match /roles_admin/{userId} {
      allow get, list: if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }
  }
}
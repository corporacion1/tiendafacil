/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership and store-ownership model for data access.
 *
 * Data Structure:
 * - /stores/{storeId}: Stores application configuration settings for each store. Owned by the user who created the store.
 * - /users/{userId}: Stores user profiles. Only accessible by the user themselves.
 * - Other top-level collections (e.g., /products, /customers, /sales): scoped to a specific store (storeId).
 * - /stores/{storeId}/currencyRates/{rateId}: Currency rates are scoped to a store.
 *
 * Key Security Decisions:
 * - Users can only read or write their own user profile.
 * - Store data can only be read or modified by the owner of the store.
 * - Other collections are secured by requiring the 'storeId' to match the store being accessed.
 * - No public listing is allowed for any collections containing private data.
 *
 * Denormalization for Authorization:
 * - Most documents require a 'storeId' field to associate them with a specific store.
 * - Stores have an `ownerId` to define store ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own user profile.
     * @path /users/{userId}
     * @allow (get, create, update, delete, list) if the user's UID matches the userId.
     * @deny (get, create, update, delete, list) if the user's UID does not match the userId.
     * @principle Enforces user-ownership for profile data.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows store owners to read and manage their store configuration.
     * @path /stores/{storeId}
     * @allow (get, create, update, delete, list) if the user's UID matches the store's ownerId.
     * @deny (get, create, update, delete, list) if the user's UID does not match the store's ownerId.
     * @principle Enforces store-ownership for configuration data.
     */
    match /stores/{storeId} {
      function isStoreOwner(storeId) {
        return request.auth.uid == resource.data.ownerId;
      }
      function isCreatingStoreAsOwner(storeId) {
        return request.auth.uid == request.resource.data.ownerId;
      }
        function isExistingStoreOwner(storeId) {
        return request.auth.uid == resource.data.ownerId && resource != null;
      }
      allow get: if isStoreOwner(storeId);
      allow list: if false;
      allow create: if request.resource.data.keys().hasAll(['ownerId']) && isCreatingStoreAsOwner(storeId);
      allow update: if isExistingStoreOwner(storeId);
      allow delete: if isExistingStoreOwner(storeId);
    }

        /**
     * @description Allows reading product information.
     * @path /products/{productId}
     * @allow (get, list) anyone can read a product
     * @allow (create, update, delete) only store owners can modify.
     * @deny (create, update, delete) if the user's UID does not match the store's ownerId.
     * @principle Data can be read by anyone but only edited by store owner.
     */
    match /products/{productId} {
      function isValidStoreId(storeId) {
        return request.resource.data.storeId == storeId;
      }
      function isExistingStoreOwner(storeId) {
        return get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      }
      allow get, list: if true;
      allow create: if request.resource.data.keys().hasAll(['storeId']) && isValidStoreId(storeId) && isExistingStoreOwner(request.resource.data.storeId);
      allow update: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
      allow delete: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Allows reading inventory movement records.
     * @path /inventory_movements/{movementId}
     * @allow (get, list) anyone can read a movement
     * @allow (create, update, delete) only store owners can modify.
     * @deny (create, update, delete) if the user's UID does not match the store's ownerId.
     */
    match /inventory_movements/{movementId} {
      function isValidStoreId(storeId) {
        return request.resource.data.storeId == storeId;
      }
      function isExistingStoreOwner(storeId) {
        return get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      }
      allow get, list: if true;
      allow create: if request.resource.data.keys().hasAll(['storeId']) && isValidStoreId(storeId) && isExistingStoreOwner(request.resource.data.storeId);
      allow update: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
      allow delete: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Allows reading sales transaction records.
     * @path /sales/{saleId}
     * @allow (get, list) anyone can read a sale
     * @allow (create, update, delete) only store owners can modify.
     * @deny (create, update, delete) if the user's UID does not match the store's ownerId.
     */
    match /sales/{saleId} {
      function isValidStoreId(storeId) {
        return request.resource.data.storeId == storeId;
      }
      function isExistingStoreOwner(storeId) {
        return get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      }
      allow get, list: if true;
      allow create: if request.resource.data.keys().hasAll(['storeId']) && isValidStoreId(storeId) && isExistingStoreOwner(request.resource.data.storeId);
      allow update: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
      allow delete: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Allows reading purchase order records.
     * @path /purchases/{purchaseId}
     * @allow (get, list) anyone can read a purchase
     * @allow (create, update, delete) only store owners can modify.
     * @deny (create, update, delete) if the user's UID does not match the store's ownerId.
     */
    match /purchases/{purchaseId} {
      function isValidStoreId(storeId) {
        return request.resource.data.storeId == storeId;
      }
      function isExistingStoreOwner(storeId) {
        return get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      }
      allow get, list: if true;
      allow create: if request.resource.data.keys().hasAll(['storeId']) && isValidStoreId(storeId) && isExistingStoreOwner(request.resource.data.storeId);
      allow update: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
      allow delete: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Allows reading customer information.
     * @path /customers/{customerId}
     * @allow (get, list) anyone can read a customer
     * @allow (create, update, delete) only store owners can modify.
     * @deny (create, update, delete) if the user's UID does not match the store's ownerId.
     */
    match /customers/{customerId} {
      function isValidStoreId(storeId) {
        return request.resource.data.storeId == storeId;
      }
      function isExistingStoreOwner(storeId) {
        return get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      }
      allow get, list: if true;
      allow create: if request.resource.data.keys().hasAll(['storeId']) && isValidStoreId(storeId) && isExistingStoreOwner(request.resource.data.storeId);
      allow update: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
      allow delete: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Allows reading supplier information.
     * @path /suppliers/{supplierId}
     * @allow (get, list) anyone can read a supplier
     * @allow (create, update, delete) only store owners can modify.
     * @deny (create, update, delete) if the user's UID does not match the store's ownerId.
     */
    match /suppliers/{supplierId} {
      function isValidStoreId(storeId) {
        return request.resource.data.storeId == storeId;
      }
      function isExistingStoreOwner(storeId) {
        return get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      }
      allow get, list: if true;
      allow create: if request.resource.data.keys().hasAll(['storeId']) && isValidStoreId(storeId) && isExistingStoreOwner(request.resource.data.storeId);
      allow update: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
      allow delete: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Allows reading units of measure.
     * @path /units/{unitId}
     * @allow (get, list) anyone can read a unit
     * @allow (create, update, delete) only store owners can modify.
     * @deny (create, update, delete) if the user's UID does not match the store's ownerId.
     */
    match /units/{unitId} {
      function isValidStoreId(storeId) {
        return request.resource.data.storeId == storeId;
      }
      function isExistingStoreOwner(storeId) {
        return get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      }
      allow get, list: if true;
      allow create: if request.resource.data.keys().hasAll(['storeId']) && isValidStoreId(storeId) && isExistingStoreOwner(request.resource.data.storeId);
      allow update: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
      allow delete: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Allows reading product families/categories.
     * @path /families/{familyId}
     * @allow (get, list) anyone can read a family
     * @allow (create, update, delete) only store owners can modify.
     * @deny (create, update, delete) if the user's UID does not match the store's ownerId.
     */
    match /families/{familyId} {
      function isValidStoreId(storeId) {
        return request.resource.data.storeId == storeId;
      }
      function isExistingStoreOwner(storeId) {
        return get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      }
      allow get, list: if true;
      allow create: if request.resource.data.keys().hasAll(['storeId']) && isValidStoreId(storeId) && isExistingStoreOwner(request.resource.data.storeId);
      allow update: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
      allow delete: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Allows reading warehouse information.
     * @path /warehouses/{warehouseId}
     * @allow (get, list) anyone can read a warehouse
     * @allow (create, update, delete) only store owners can modify.
     * @deny (create, update, delete) if the user's UID does not match the store's ownerId.
     */
    match /warehouses/{warehouseId} {
      function isValidStoreId(storeId) {
        return request.resource.data.storeId == storeId;
      }
      function isExistingStoreOwner(storeId) {
        return get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      }
      allow get, list: if true;
      allow create: if request.resource.data.keys().hasAll(['storeId']) && isValidStoreId(storeId) && isExistingStoreOwner(request.resource.data.storeId);
      allow update: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
      allow delete: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
    }
    /**
     * @description Allows reading marketing advertisements.
     * @path /ads/{adId}
     * @allow (get, list) anyone can read a advertisement
     * @allow (create, update, delete) only store owners can modify.
     */
    match /ads/{adId} {
        allow get, list: if true;
        allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Allows reading pending orders.
     * @path /pendingOrders/{orderId}
     * @allow (get, list) anyone can read a pending order
     * @allow (create, update, delete) only store owners can modify.
     * @deny (create, update, delete) if the user's UID does not match the store's ownerId.
     */
    match /pendingOrders/{orderId} {
      function isValidStoreId(storeId) {
        return request.resource.data.storeId == storeId;
      }
        function isExistingStoreOwner(storeId) {
        return get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      }
      allow get, list: if true;
      allow create: if request.resource.data.keys().hasAll(['storeId']) && isValidStoreId(storeId) && isExistingStoreOwner(request.resource.data.storeId);
      allow update: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
      allow delete: if resource.data.keys().hasAll(['storeId']) && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Allows store owners to read and manage currency rates for their store.
     * @path /stores/{storeId}/currencyRates/{rateId}
     * @allow (get, create, update, delete, list) if the user's UID matches the store's ownerId.
     * @deny (get, create, update, delete, list) if the user's UID does not match the store's ownerId.
     * @principle Enforces store-ownership for currency rate data.
     */
    match /stores/{storeId}/currencyRates/{rateId} {
      function isStoreOwner(storeId) {
        return get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      }
        function isExistingStoreOwner(storeId) {
        return get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      }
      allow get: if isStoreOwner(storeId);
      allow list: if false;
      allow create: if isStoreOwner(storeId);
      allow update: if isExistingStoreOwner(storeId);
      allow delete: if isExistingStoreOwner(storeId);
    }
  }
}
/**
 * @fileoverview Firestore Security Rules for the point-of-sale application.
 *
 * Core Philosophy:
 * This ruleset prioritizes security by default, restricting access unless explicitly granted.
 * It uses a store-ownership model, where most data is associated with a specific store.
 * Only authenticated users can perform write operations and only if they are an owner of a given store.
 *
 * Data Structure:
 * The Firestore database is organized into top-level collections for entities like products, tax types,
 * inventory movements, sales, purchases, customers, stores and families. Several collections such as salesItems and purchaseItems are subcollections.
 * Most collections have a `storeId` field to scope the data.
 *
 * Key Security Decisions:
 * - Listing of the `purchases` collection is denied by default (as fix for the reported error).
 * - All write operations require the user to be authenticated.
 * - All `update` and `delete` operations include a resource existence check for added security.
 * - No data validation is performed in this prototyping phase except to check `storeId` on `create` operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the owner of the store.
     * @param {string} storeId - The ID of the store.
     * @return {boolean} True if the user's UID matches the `storeId`, false otherwise.
     */
    function isStoreOwner(storeId) {
      return isSignedIn() && request.auth.uid == storeId;
    }

    /**
     * @description Checks if the user is the owner of the document based on the storeId.
     * For update and delete operations, it also verifies the resource exists.
     * @param {string} storeId - The ID of the store to check.
     * @return {boolean} True if the user is the owner and the resource exists (for update/delete), false otherwise.
     */
    function isExistingStoreOwner(storeId) {
      return isStoreOwner(storeId) && resource != null;
    }

    /**
     * @description Collection for products.
     * @path /products/{productId}
     * @allow (create) User signed in can create a product with the storeId equal to it's uid.
     * @allow (get, list) Any user can read a product.
     * @deny (update) User signed in cannot update a product that does not belongs to the authenticated user.
     * @deny (delete) User signed in cannot delete a product that does not belongs to the authenticated user.
     * @principle Enforces store ownership for writes, public read access.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId);
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Collection for tax types.
     * @path /taxTypes/{taxTypeId}
     * @allow (create) User signed in can create a tax type with the storeId equal to it's uid.
     * @allow (get, list) Any user can read a tax type.
     * @deny (update) User signed in cannot update a tax type that does not belongs to the authenticated user.
     * @deny (delete) User signed in cannot delete a tax type that does not belongs to the authenticated user.
     * @principle Enforces store ownership for writes, public read access.
     */
    match /taxTypes/{taxTypeId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId);
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Collection for inventory movements.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (create) User signed in can create an inventory movement with the storeId equal to it's uid.
     * @allow (get, list) Any user can read an inventory movement.
     * @deny (update) User signed in cannot update an inventory movement that does not belongs to the authenticated user.
     * @deny (delete) User signed in cannot delete an inventory movement that does not belongs to the authenticated user.
     * @principle Enforces store ownership for writes, public read access.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId);
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Collection for sales.
     * @path /sales/{saleId}
     * @allow (create) User signed in can create a sale with the storeId equal to it's uid.
     * @allow (get, list) Any user can read a sale.
     * @deny (update) User signed in cannot update a sale that does not belongs to the authenticated user.
     * @deny (delete) User signed in cannot delete a sale that does not belongs to the authenticated user.
     * @principle Enforces store ownership for writes, public read access.
     */
    match /sales/{saleId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId);
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Subcollection for sale items within a sale.
     * @path /sales/{saleId}/saleItems/{saleItemId}
     * @allow (create) User signed in can create a sale item with the storeId equal to it's uid.
     * @allow (get, list) Any user can read a sale item.
     * @deny (update) User signed in cannot update a sale item that does not belongs to the authenticated user.
     * @deny (delete) User signed in cannot delete a sale item that does not belongs to the authenticated user.
     * @principle Enforces store ownership for writes, public read access.
     */
    match /sales/{saleId}/saleItems/{saleItemId} {
      allow get, list: if true;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/sales/$(saleId)).data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(get(/databases/$(database)/documents/sales/$(saleId)).data.storeId);
      allow delete: if isExistingStoreOwner(get(/databases/$(database)/documents/sales/$(saleId)).data.storeId);
    }

    /**
     * @description Collection for purchases.
     * @path /purchases/{purchaseId}
     * @allow (create) User signed in can create a purchase with the storeId equal to it's uid.
     * @deny (get, list) Listing is denied.
     * @deny (update) User signed in cannot update a purchase that does not belongs to the authenticated user.
     * @deny (delete) User signed in cannot delete a purchase that does not belongs to the authenticated user.
     * @principle Enforces store ownership for writes, denying listing to resolve the reported error.
     */
    match /purchases/{purchaseId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId);
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Subcollection for purchase items within a purchase.
     * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     * @allow (create) User signed in can create a purchase item with the storeId equal to it's uid.
     * @allow (get, list) Any user can read a purchase item.
     * @deny (update) User signed in cannot update a purchase item that does not belongs to the authenticated user.
     * @deny (delete) User signed in cannot delete a purchase item that does not belongs to the authenticated user.
     * @principle Enforces store ownership for writes, public read access.
     */
    match /purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
      allow get, list: if true;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId);
      allow delete: if isExistingStoreOwner(get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId);
    }

    /**
     * @description Collection for customers.
     * @path /customers/{customerId}
     * @allow (create) User signed in can create a customer with the storeId equal to it's uid.
     * @allow (get, list) Any user can read a customer.
     * @deny (update) User signed in cannot update a customer that does not belongs to the authenticated user.
     * @deny (delete) User signed in cannot delete a customer that does not belongs to the authenticated user.
     * @principle Enforces store ownership for writes, public read access.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId);
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Collection for store configurations.
     * @path /stores/{storeId}
     * @allow (create) User signed in can create a store configuration with the id equal to it's uid.
     * @allow (get, list) Any user can read a store configuration.
     * @deny (update) User signed in cannot update a store configuration that does not belongs to the authenticated user.
     * @deny (delete) User signed in cannot delete a store configuration that does not belongs to the authenticated user.
     * @principle Enforces store ownership for writes, public read access.
     */
    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.id == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.id);
      allow delete: if isExistingStoreOwner(resource.data.id);
    }

    /**
     * @description Collection for product families.
     * @path /families/{familyId}
     * @allow (create) User signed in can create a family with the storeId equal to it's uid.
     * @allow (get, list) Any user can read a family.
     * @deny (update) User signed in cannot update a family that does not belongs to the authenticated user.
     * @deny (delete) User signed in cannot delete a family that does not belongs to the authenticated user.
     * @principle Enforces store ownership for writes, public read access.
     */
    match /families/{familyId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId);
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }
  }
}
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas permisivas para desarrollo - Permitir lectura y escritura a usuarios autenticados
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // El catálogo de productos debe ser de lectura pública
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /families/{familyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Los pedidos pendientes pueden ser creados por cualquiera (público), pero solo leídos/eliminados por usuarios autenticados (el staff)
    match /pendingOrders/{orderId} {
        allow create: if true;
        allow read, delete, update: if request.auth != null;
    }
  }
}

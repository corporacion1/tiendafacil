/**
 * @fileoverview Firestore Security Rules for the point-of-sale application.
 *
 * Core Philosophy:
 * This ruleset enforces a store-ownership model. Most data is scoped to a specific store,
 * and only authenticated users can access and modify data within their store.
 *
 * Data Structure:
 * - Top-level collections for main entities like `products`, `taxTypes`, `inventoryMovements`, `sales`, `purchases`, `customers`, `stores`, and `families`.
 * - Subcollections `saleItems` under `sales` and `purchaseItems` under `purchases`.
 *
 * Key Security Decisions:
 * - All data is scoped to a `storeId`.
 * - Only authenticated users can access the data, preventing public read access.
 *
 * Denormalization for Authorization:
 *  The `storeId` is used in every document to control data access.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Products can only be read and written by authenticated users and all have `storeId` property.
     * @path /products/{productId}
     * @allow (get, list): Authenticated user can read products
     * @allow (create): Authenticated user can create products with valid `storeId`
     * @allow (update, delete): Authenticated user can update/delete products with valid `storeId`
     * @deny (create): Unauthenticated user can not create products
     * @deny (update, delete): Unauthenticated user can not update/delete products
     * @principle Enforces store-level ownership for product data.
     */
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Tax types can only be read and written by authenticated users and all have `storeId` property.
     * @path /taxTypes/{taxTypeId}
     * @allow (get, list): Authenticated user can read tax types
     * @allow (create): Authenticated user can create tax types with valid `storeId`
     * @allow (update, delete): Authenticated user can update/delete tax types with valid `storeId`
     * @deny (create): Unauthenticated user can not create tax types
     * @deny (update, delete): Unauthenticated user can not update/delete tax types
     * @principle Enforces store-level ownership for tax type data.
     */
    match /taxTypes/{taxTypeId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Inventory movements can only be read and written by authenticated users and all have `storeId` property.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (get, list): Authenticated user can read inventory movements
     * @allow (create): Authenticated user can create inventory movements with valid `storeId`
     * @allow (update, delete): Authenticated user can update/delete inventory movements with valid `storeId`
     * @deny (create): Unauthenticated user can not create inventory movements
     * @deny (update, delete): Unauthenticated user can not update/delete inventory movements
     * @principle Enforces store-level ownership for inventory movement data.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Sales can only be read and written by authenticated users and all have `storeId` property.
     * @path /sales/{saleId}
     * @allow (get, list): Authenticated user can read sales
     * @allow (create): Authenticated user can create sales with valid `storeId`
     * @allow (update, delete): Authenticated user can update/delete sales with valid `storeId`
     * @deny (create): Unauthenticated user can not create sales
     * @deny (update, delete): Unauthenticated user can not update/delete sales
     * @principle Enforces store-level ownership for sale data.
     */
    match /sales/{saleId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Sale items can only be read and written by authenticated users and all have a parent sale with a `storeId` property.
     * @path /sales/{saleId}/saleItems/{saleItemId}
     * @allow (get, list): Authenticated user can read sale items if the parent sale is valid.
     * @allow (create): Authenticated user can create sale items if the parent sale is valid.
     * @allow (update, delete): Authenticated user can update/delete sale items if the parent sale is valid.
     * @deny (create): Unauthenticated user can not create sale items
     * @deny (update, delete): Unauthenticated user can not update/delete sale items
     * @principle Enforces store-level ownership for sale item data, inherited from the parent sale.
     */
    match /sales/{saleId}/saleItems/{saleItemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Purchases can only be read and written by authenticated users and all have `storeId` property.
     * @path /purchases/{purchaseId}
     * @allow (get, list): Authenticated user can read purchases
     * @allow (create): Authenticated user can create purchases with valid `storeId`
     * @allow (update, delete): Authenticated user can update/delete purchases with valid `storeId`
     * @deny (create): Unauthenticated user can not create purchases
     * @deny (update, delete): Unauthenticated user can not update/delete purchases
     * @principle Enforces store-level ownership for purchase data.
     */
    match /purchases/{purchaseId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Purchase items can only be read and written by authenticated users and all have a parent purchase with a `storeId` property.
     * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     * @allow (get, list): Authenticated user can read purchase items if the parent purchase is valid.
     * @allow (create): Authenticated user can create purchase items if the parent purchase is valid.
     * @allow (update, delete): Authenticated user can update/delete purchase items if the parent purchase is valid.
     * @deny (create): Unauthenticated user can not create purchase items
     * @deny (update, delete): Unauthenticated user can not update/delete purchase items
     * @principle Enforces store-level ownership for purchase item data, inherited from the parent purchase.
     */
    match /purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Customers can only be read and written by authenticated users and all have `storeId` property.
     * @path /customers/{customerId}
     * @allow (get, list): Authenticated user can read customers
     * @allow (create): Authenticated user can create customers with valid `storeId`
     * @allow (update, delete): Authenticated user can update/delete customers with valid `storeId`
     * @deny (create): Unauthenticated user can not create customers
     * @deny (update, delete): Unauthenticated user can not update/delete customers
     * @principle Enforces store-level ownership for customer data.
     */
    match /customers/{customerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Store configurations can only be read and written by authenticated users.
     * @path /stores/{storeId}
     * @allow (get, list): Authenticated user can read store configurations
     * @allow (create): Authenticated user can create store configurations.
     * @allow (update, delete): Authenticated user can update/delete store configurations.
     * @deny (create): Unauthenticated user can not create store configurations
     * @deny (update, delete): Unauthenticated user can not update/delete store configurations
     * @principle Enforces authentication for store configuration data.
     */
    match /stores/{storeId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Product families can only be read and written by authenticated users and all have `storeId` property.
     * @path /families/{familyId}
     * @allow (get, list): Authenticated user can read families
     * @allow (create): Authenticated user can create families with valid `storeId`
     * @allow (update, delete): Authenticated user can update/delete families with valid `storeId`
     * @deny (create): Unauthenticated user can not create families
     * @deny (update, delete): Unauthenticated user can not update/delete families
     * @principle Enforces store-level ownership for family data.
     */
    match /families/{familyId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}
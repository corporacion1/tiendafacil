
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read access to products for the catalog
    match /products/{productId} {
      allow read, write: if true;
    }

    // Allow public read access to ads for the catalog
    match /ads/{adId} {
      allow read, write: if true;
    }
    
    // Customers can be created by anyone in the demo
    match /customers/{customerId} {
      allow read, write: if true;
    }

    // Sales can be created by anyone in the demo
    match /sales/{saleId} {
      allow read, write: if true;
    }

    // Purchases can be created by authenticated users
    match /purchases/{purchaseId} {
      allow read, write: if true;
    }
    
    // Suppliers can be managed by authenticated users
    match /suppliers/{supplierId} {
      allow read, write: if true;
    }

    // App configuration data
    match /units/{unitId} {
      allow read, write: if true;
    }
    match /families/{familyId} {
      allow read, write: if true;
    }
    match /warehouses/{warehouseId} {
      allow read, write: if true;
    }
    match /inventory_movements/{movementId} {
        allow read, write: if true;
    }
  }
}

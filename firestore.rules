/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a store-ownership model, where most data is scoped to a specific store and accessible only by the store owner.
 *
 * Data Structure:
 * - /stores/{storeId}: Stores configuration and owner information for each store. Only the owner can manage store settings.
 * - /products/{productId}: Stores product information.
 * - /inventory_movements/{movementId}: Tracks inventory changes.
 * - /sales/{saleId}: Records sales transactions.
 * - /purchases/{purchaseId}: Manages purchase orders.
 * - /customers/{customerId}: Contains customer details.
 * - /suppliers/{supplierId}: Contains supplier details.
 * - /units/{unitId}: Stores units of measure.
 * - /families/{familyId}: Categorizes products into families.
 * - /warehouses/{warehouseId}: Manages warehouse information.
 * - /users/{userId}: Stores user profile information. The profile is accessible only by the user themselves.
 * - /ads/{adId}: Stores advertisement data. These are publicly readable.
 * - /pendingOrders/{orderId}: Holds pending orders from the public catalog.
 * - /stores/{storeId}/currencyRates/{rateId}: Currency exchange rates for a store.
 *
 * Key Security Decisions:
 * - User listing is disallowed. Only the currently authenticated user can access their own profile.
 * - Store-owned data (products, sales, etc.) is secured by requiring a `storeId` field in the document, which must match the store ID in the path.
 * - Public read access is granted for ads.
 *
 * Denormalization for Authorization:
 * - Many collections require the `storeId` field to match the parent `storeId` to simplify access control.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @principle Authentication is required for most operations.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource (user ID matches).
     * @principle Enforces ownership for user-specific data.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the store.
     * @principle Enforces ownership for store-specific data.
     */
    function isStoreOwner(storeId) {
      return get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /**
     * @description Checks if the authenticated user is the owner of the store and the document exists.
     */
    function isExistingStoreOwner(storeId) {
      return isStoreOwner(storeId) && resource != null;
    }
    
    /**
     * @description Checks if the authenticated user is the owner of the resource (user ID matches) and the document exists.
     * @principle Protects against accidental deletion or modification of non-existent documents.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for user profiles.
     * @path /users/{userId}
     * @allow (create) If the user's UID matches the userId in the path.
     * @deny (create) If the user's UID does not match the userId in the path.
     * @allow (get) If the user's UID matches the userId in the path.
     * @deny (get) If the user's UID does not match the userId in the path.
     * @allow (update) If the user's UID matches the userId in the path.
     * @deny (update) If the user's UID does not match the userId in the path.
     * @allow (delete) If the user's UID matches the userId in the path.
     * @deny (delete) If the user's UID does not match the userId in the path.
     * @principle Users can only access and modify their own profile data.
     */
    match /users/{userId} {
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.uid == userId;
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.uid == resource.data.uid;
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Rules for store configurations.
     * @path /stores/{storeId}
     * @allow (create) If the user is signed in and the ownerId matches the user's UID.
     * @deny (create) If the user is not signed in or the ownerId does not match the user's UID.
     * @allow (get) If the user is signed in and is the store owner.
     * @deny (get) If the user is not signed in or is not the store owner.
     * @allow (update) If the user is signed in and is the store owner.
     * @deny (update) If the user is not signed in or is not the store owner.
     * @allow (delete) If the user is signed in and is the store owner.
     * @deny (delete) If the user is not signed in or is not the store owner.
     * @principle Only the store owner can manage store settings.
     */
    match /stores/{storeId} {
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid && request.resource.data.id == storeId;
      allow get: if isSignedIn() && isStoreOwner(storeId);
      allow list: if false;
      allow update: if isSignedIn() && isExistingStoreOwner(storeId) && request.resource.data.ownerId == resource.data.ownerId && request.resource.data.id == storeId;
      allow delete: if isSignedIn() && isExistingStoreOwner(storeId);
    }

    /**
     * @description Rules for products within a store.
     * @path /products/{productId}
     * @allow (create) If the user is the store owner and the storeId matches.
     * @deny (create) If the user is not the store owner or the storeId does not match.
     * @allow (get) If the user is the store owner.
     * @deny (get) If the user is not the store owner.
     * @allow (update) If the user is the store owner.
     * @deny (update) If the user is not the store owner.
     * @allow (delete) If the user is the store owner.
     * @deny (delete) If the user is not the store owner.
     * @principle Only the store owner can manage products.
     */
    match /products/{productId} {
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow get: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow list: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for inventory movements within a store.
     * @path /inventory_movements/{movementId}
     * @allow (create) If the user is the store owner and the storeId matches.
     * @deny (create) If the user is not the store owner or the storeId does not match.
     * @allow (get) If the user is the store owner.
     * @deny (get) If the user is not the store owner.
     * @allow (update) If the user is the store owner.
     * @deny (update) If the user is not the store owner.
     * @allow (delete) If the user is the store owner.
     * @deny (delete) If the user is not the store owner.
     * @principle Only the store owner can manage inventory movements.
     */
    match /inventory_movements/{movementId} {
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow get: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow list: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for sales transactions within a store.
     * @path /sales/{saleId}
     * @allow (create) If the user is the store owner and the storeId matches.
     * @deny (create) If the user is not the store owner or the storeId does not match.
     * @allow (get) If the user is the store owner.
     * @deny (get) If the user is not the store owner.
     * @allow (update) If the user is the store owner.
     * @deny (update) If the user is not the store owner.
     * @allow (delete) If the user is the store owner.
     * @deny (delete) If the user is not the store owner.
     * @principle Only the store owner can manage sales transactions.
     */
    match /sales/{saleId} {
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow get: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow list: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for purchase orders within a store.
     * @path /purchases/{purchaseId}
     * @allow (create) If the user is the store owner and the storeId matches.
     * @deny (create) If the user is not the store owner or the storeId does not match.
     * @allow (get) If the user is the store owner.
     * @deny (get) If the user is not the store owner.
     * @allow (update) If the user is the store owner.
     * @deny (update) If the user is not the store owner.
     * @allow (delete) If the user is the store owner.
     * @deny (delete) If the user is not the store owner.
     * @principle Only the store owner can manage purchase orders.
     */
    match /purchases/{purchaseId} {
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow get: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow list: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for customers within a store.
     * @path /customers/{customerId}
     * @allow (create) If the user is the store owner and the storeId matches.
     * @deny (create) If the user is not the store owner or the storeId does not match.
     * @allow (get) If the user is the store owner.
     * @deny (get) If the user is not the store owner.
     * @allow (update) If the user is the store owner.
     * @deny (update) If the user is not the store owner.
     * @allow (delete) If the user is the store owner.
     * @deny (delete) If the user is not the store owner.
     * @principle Only the store owner can manage customers.
     */
    match /customers/{customerId} {
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow get: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow list: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for suppliers within a store.
     * @path /suppliers/{supplierId}
     * @allow (create) If the user is the store owner and the storeId matches.
     * @deny (create) If the user is not the store owner or the storeId does not match.
     * @allow (get) If the user is the store owner.
     * @deny (get) If the user is not the store owner.
     * @allow (update) If the user is the store owner.
     * @deny (update) If the user is not the store owner.
     * @allow (delete) If the user is the store owner.
     * @deny (delete) If the user is not the store owner.
     * @principle Only the store owner can manage suppliers.
     */
    match /suppliers/{supplierId} {
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow get: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow list: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for units within a store.
     * @path /units/{unitId}
     * @allow (create) If the user is the store owner and the storeId matches.
     * @deny (create) If the user is not the store owner or the storeId does not match.
     * @allow (get) If the user is the store owner.
     * @deny (get) If the user is not the store owner.
     * @allow (update) If the user is the store owner.
     * @deny (update) If the user is not the store owner.
     * @allow (delete) If the user is the store owner.
     * @deny (delete) If the user is not the store owner.
     * @principle Only the store owner can manage units.
     */
    match /units/{unitId} {
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow get: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow list: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for families within a store.
     * @path /families/{familyId}
     * @allow (create) If the user is the store owner and the storeId matches.
     * @deny (create) If the user is not the store owner or the storeId does not match.
     * @allow (get) If the user is the store owner.
     * @deny (get) If the user is not the store owner.
     * @allow (update) If the user is the store owner.
     * @deny (update) If the user is not the store owner.
     * @allow (delete) If the user is the store owner.
     * @deny (delete) If the user is not the store owner.
     * @principle Only the store owner can manage families.
     */
    match /families/{familyId} {
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow get: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow list: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for warehouses within a store.
     * @path /warehouses/{warehouseId}
     * @allow (create) If the user is the store owner and the storeId matches.
     * @deny (create) If the user is not the store owner or the storeId does not match.
     * @allow (get) If the user is the store owner.
     * @deny (get) If the user is not the store owner.
     * @allow (update) If the user is the store owner.
     * @deny (update) If the user is not the store owner.
     * @allow (delete) If the user is the store owner.
     * @deny (delete) If the user is not the store owner.
     * @principle Only the store owner can manage warehouses.
     */
    match /warehouses/{warehouseId} {
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow get: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow list: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for advertisements. Publicly readable.
     * @path /ads/{adId}
     * @allow (get) Anyone can read advertisements.
     * @allow (list) Anyone can list advertisements.
     * @principle Advertisements are publicly accessible.
     */
    match /ads/{adId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Rules for pending orders.
     * @path /pendingOrders/{orderId}
     * @allow (create) If the user is the store owner and the storeId matches.
     * @deny (create) If the user is not the store owner or the storeId does not match.
     * @allow (get) If the user is the store owner.
     * @deny (get) If the user is not the store owner.
     * @allow (update) If the user is the store owner.
     * @deny (update) If the user is not the store owner.
     * @allow (delete) If the user is the store owner.
     * @deny (delete) If the user is not the store owner.
     */
    match /pendingOrders/{orderId} {
      allow create: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow get: if isSignedIn() && isStoreOwner(resource.data.storeId);
      allow list: if isSignedIn() && isStoreOwner(request.resource.data.storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Rules for currency rates within a store.
     * @path /stores/{storeId}/currencyRates/{rateId}
     * @allow (create) If the user is the store owner.
     * @deny (create) If the user is not the store owner.
     * @allow (get) If the user is the store owner.
     * @deny (get) If the user is not the store owner.
     * @allow (update) If the user is the store owner.
     * @deny (update) If the user is not the store owner.
     * @allow (delete) If the user is the store owner.
     * @deny (delete) If the user is not the store owner.
     * @principle Only the store owner can manage currency rates.
     */
    match /stores/{storeId}/currencyRates/{rateId} {
      allow create: if isSignedIn() && isStoreOwner(storeId);
      allow get: if isSignedIn() && isStoreOwner(storeId);
      allow list: if isSignedIn() && isStoreOwner(storeId);
      allow update: if isSignedIn() && isExistingStoreOwner(storeId);
      allow delete: if isSignedIn() && isExistingStoreOwner(storeId);
    }
  }
}
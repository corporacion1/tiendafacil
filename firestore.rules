/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict authorization model where only authenticated users can access data, and write access is generally disallowed unless explicitly permitted.
 *
 * Data Structure:
 * - All data is stored in top-level collections: /products, /inventoryMovements, /sales, /purchases, /customers, /suppliers, /taxTypes, /configuration.
 * - Subcollections are used for nested data like saleItems under sales and purchaseItems under purchases.
 *
 * Key Security Decisions:
 * - All collections require user authentication for both read and write access.
 * - Listing operations are generally disallowed to prevent information leakage, unless the collection is intended for public data.
 * - This ruleset prioritizes security by default, denying access unless explicitly granted.
 * - No data shape validation is performed beyond requiring authentication.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the /products collection.
     * @path /products/{productId}
     * @allow (get, list): Authenticated user can read.
     * @deny (create, update, delete): No one can write.
     * @principle Requires authentication for read access; no write access granted.
     */
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to the /inventoryMovements collection.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (get, list): Authenticated user can read.
     * @deny (create, update, delete): No one can write.
     * @principle Requires authentication for read access; no write access granted.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to the /sales collection.
     * @path /sales/{saleId}
     * @allow (get, list): Authenticated user can read.
     * @deny (create, update, delete): No one can write.
     * @principle Requires authentication for read access; no write access granted.
     */
    match /sales/{saleId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to the /sales/{saleId}/saleItems collection.
     * @path /sales/{saleId}/saleItems/{saleItemId}
     * @allow (get, list): Authenticated user can read.
     * @deny (create, update, delete): No one can write.
     * @principle Requires authentication for read access; no write access granted.
     */
    match /sales/{saleId}/saleItems/{saleItemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to the /purchases collection.
     * @path /purchases/{purchaseId}
     * @allow (get, list): Authenticated user can read.
     * @deny (create, update, delete): No one can write.
     * @principle Requires authentication for read access; no write access granted.
     */
    match /purchases/{purchaseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to the /purchases/{purchaseId}/purchaseItems collection.
     * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     * @allow (get, list): Authenticated user can read.
     * @deny (create, update, delete): No one can write.
     * @principle Requires authentication for read access; no write access granted.
     */
    match /purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to the /customers collection.
     * @path /customers/{customerId}
     * @allow (get, list): Authenticated user can read.
     * @deny (create, update, delete): No one can write.
     * @principle Requires authentication for read access; no write access granted.
     */
    match /customers/{customerId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to the /suppliers collection.
     * @path /suppliers/{supplierId}
     * @allow (get, list): Authenticated user can read.
     * @deny (create, update, delete): No one can write.
     * @principle Requires authentication for read access; no write access granted.
     */
    match /suppliers/{supplierId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to the /taxTypes collection.
     * @path /taxTypes/{taxTypeId}
     * @allow (get, list): Authenticated user can read.
     * @deny (create, update, delete): No one can write.
     * @principle Requires authentication for read access; no write access granted.
     */
    match /taxTypes/{taxTypeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to the /configuration collection.
     * @path /configuration/{configurationId}
     * @allow (get, list): Authenticated user can read.
     * @deny (create, update, delete): No one can write.
     * @principle Requires authentication for read access; no write access granted.
     */
    match /configuration/{configurationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}
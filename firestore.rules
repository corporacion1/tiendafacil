/**
 * @fileoverview Firestore Security Rules for the inventory and point-of-sale system.
 *
 * Core Philosophy:
 * This ruleset provides secure access to inventory and sales data, primarily using a data-centric security model.
 * Each top-level collection is independently secured, and relationships between documents are not used for authorization.
 *
 * Data Structure:
 * - /products/{productId}: Stores product information.
 * - /inventoryMovements/{inventoryMovementId}: Stores inventory movement records.
 * - /sales/{saleId}: Stores sales transactions.
 * - /sales/{saleId}/saleItems/{saleItemId}: Stores individual sale items related to a specific sale.
 * - /purchases/{purchaseId}: Stores purchase transactions.
 * - /purchases/{purchaseId}/purchaseItems/{purchaseItemId}: Stores individual purchase items related to a specific purchase.
 * - /customers/{customerId}: Stores customer information.
 * - /suppliers/{supplierId}: Stores supplier information.
 * - /taxTypes/{taxTypeId}: Stores tax type information.
 * - /configuration/{configurationId}: Stores business configuration data.
 *
 * Key Security Decisions:
 * - All collections except Configuration require authentication to access.
 * - There are no implicit relationships between collections that grant permissions.
 *
 * Denormalization for Authorization:
 *   This ruleset avoids complex authorization checks. For example, it does not check if a customer exists before creating a sale.
 *
 * Structural Segregation:
 *   All data is stored in top-level collections, with no user-specific subcollections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to product information. Only authenticated users can read and write product data.
     * @path /products/{productId}
     * @allow (get, list): Authenticated user can read product information.
     * @allow (create, update, delete): Authenticated user can write product information.
     * @deny (get, list): Unauthenticated user cannot read product information.
     * @deny (create, update, delete): Unauthenticated user cannot write product information.
     * @principle Authenticated users can manage product information.
     */
    match /products/{productId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to inventory movement records. Only authenticated users can read and write inventory movement data.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (get, list): Authenticated user can read inventory movement information.
     * @allow (create, update, delete): Authenticated user can write inventory movement information.
     * @deny (get, list): Unauthenticated user cannot read inventory movement information.
     * @deny (create, update, delete): Unauthenticated user cannot write inventory movement information.
     * @principle Authenticated users can manage inventory movement information.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to sales transactions. Only authenticated users can read and write sales transaction data.
     * @path /sales/{saleId}
     * @allow (get, list): Authenticated user can read sales transaction information.
     * @allow (create, update, delete): Authenticated user can write sales transaction information.
     * @deny (get, list): Unauthenticated user cannot read sales transaction information.
     * @deny (create, update, delete): Unauthenticated user cannot write sales transaction information.
     * @principle Authenticated users can manage sales transaction information.
     */
    match /sales/{saleId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to sale items related to a specific sale. Only authenticated users can read and write sale item data.
     * @path /sales/{saleId}/saleItems/{saleItemId}
     * @allow (get, list): Authenticated user can read sale item information.
     * @allow (create, update, delete): Authenticated user can write sale item information.
     * @deny (get, list): Unauthenticated user cannot read sale item information.
     * @deny (create, update, delete): Unauthenticated user cannot write sale item information.
     * @principle Authenticated users can manage sale item information.
     */
    match /sales/{saleId}/saleItems/{saleItemId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to purchase transactions. Only authenticated users can read and write purchase transaction data.
     * @path /purchases/{purchaseId}
     * @allow (get, list): Authenticated user can read purchase transaction information.
     * @allow (create, update, delete): Authenticated user can write purchase transaction information.
     * @deny (get, list): Unauthenticated user cannot read purchase transaction information.
     * @deny (create, update, delete): Unauthenticated user cannot write purchase transaction information.
     * @principle Authenticated users can manage purchase transaction information.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to purchase items related to a specific purchase. Only authenticated users can read and write purchase item data.
     * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     * @allow (get, list): Authenticated user can read purchase item information.
     * @allow (create, update, delete): Authenticated user can write purchase item information.
     * @deny (get, list): Unauthenticated user cannot read purchase item information.
     * @deny (create, update, delete): Unauthenticated user cannot write purchase item information.
     * @principle Authenticated users can manage purchase item information.
     */
    match /purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to customer information. Only authenticated users can read and write customer data.
     * @path /customers/{customerId}
     * @allow (get, list): Authenticated user can read customer information.
     * @allow (create, update, delete): Authenticated user can write customer information.
     * @deny (get, list): Unauthenticated user cannot read customer information.
     * @deny (create, update, delete): Unauthenticated user cannot write customer information.
     * @principle Authenticated users can manage customer information.
     */
    match /customers/{customerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to supplier information. Only authenticated users can read and write supplier data.
     * @path /suppliers/{supplierId}
     * @allow (get, list): Authenticated user can read supplier information.
     * @allow (create, update, delete): Authenticated user can write supplier information.
     * @deny (get, list): Unauthenticated user cannot read supplier information.
     * @deny (create, update, delete): Unauthenticated user cannot write supplier information.
     * @principle Authenticated users can manage supplier information.
     */
    match /suppliers/{supplierId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to tax type information. Only authenticated users can read and write tax type data.
     * @path /taxTypes/{taxTypeId}
     * @allow (get, list): Authenticated user can read tax type information.
     * @allow (create, update, delete): Authenticated user can write tax type information.
     * @deny (get, list): Unauthenticated user cannot read tax type information.
     * @deny (create, update, delete): Unauthenticated user cannot write tax type information.
     * @principle Authenticated users can manage tax type information.
     */
    match /taxTypes/{taxTypeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to business configuration data.  This data is publicly readable, but only authenticated users can modify it.
     * @path /configuration/{configurationId}
     * @allow (get, list): Anyone can read the configuration.
     * @allow (create, update, delete): Only authenticated users can modify the configuration.
     * @deny (create, update, delete): Unauthenticated users cannot write configuration information.
     * @principle Configuration data is public readable, but writes are restricted to authenticated users.
     */
    match /configuration/{configurationId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

  }

  /**
   * @description Checks if the user is signed in.
   * @return {boolean} True if the user is signed in, false otherwise.
   */
  function isSignedIn() {
    return request.auth != null;
  }
}
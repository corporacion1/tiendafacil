rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's ID matches the provided user ID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user's ID matches the resource's storeId.
     */
    function isStore(storeId) {
      return isSignedIn() && request.auth.uid == storeId;
    }

    /**
     * @description Checks if the user is the owner and the resource exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Checks if the incoming storeId matches the existing document's storeId.
     */
    function isStoreIdValidOnUpdate(storeId) {
        return request.resource.data.storeId == storeId;
    }

    /**
     * @description Stores product information.
     * @path /products/{productId}
     * @allow (list) Anyone can list products
     * @allow (get) Anyone can get products
     * @allow (create) Authenticated user with matching storeId can create a product.
     * @allow (update) Authenticated user with matching storeId can update an existing product.
     * @allow (delete) Authenticated user with matching storeId can delete an existing product.
     * @deny (create) Unauthenticated user cannot create a product.
     * @deny (update) User without matching storeId cannot update a product.
     * @deny (delete) User without matching storeId cannot delete a product.
     * @principle Enforces store-level ownership for products.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores inventory movement records.
     * @path /inventory_movements/{movementId}
     * @allow (list) Anyone can list inventory movements.
     * @allow (get) Anyone can get inventory movements.
     * @allow (create) Authenticated user with matching storeId can create an inventory movement.
     * @allow (update) Authenticated user with matching storeId can update an existing inventory movement.
     * @allow (delete) Authenticated user with matching storeId can delete an existing inventory movement.
     * @deny (create) Unauthenticated user cannot create an inventory movement.
     * @deny (update) User without matching storeId cannot update an inventory movement.
     * @deny (delete) User without matching storeId cannot delete an inventory movement.
     * @principle Enforces store-level ownership for inventory movements.
     */
    match /inventory_movements/{movementId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores sales transaction records.
     * @path /sales/{saleId}
     * @allow (list) Anyone can list sales.
     * @allow (get) Anyone can get sales.
     * @allow (create) Authenticated user with matching storeId can create a sale.
     * @allow (update) Authenticated user with matching storeId can update an existing sale.
     * @allow (delete) Authenticated user with matching storeId can delete a sale.
     * @deny (create) Unauthenticated user cannot create a sale.
     * @deny (update) User without matching storeId cannot update a sale.
     * @deny (delete) User without matching storeId cannot delete a sale.
     * @principle Enforces store-level ownership for sales.
     */
    match /sales/{saleId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores purchase order records.
     * @path /purchases/{purchaseId}
     * @allow (list) Anyone can list purchases.
     * @allow (get) Anyone can get purchases.
     * @allow (create) Authenticated user with matching storeId can create a purchase.
     * @allow (update) Authenticated user with matching storeId can update an existing purchase.
     * @allow (delete) Authenticated user with matching storeId can delete a purchase.
     * @deny (create) Unauthenticated user cannot create a purchase.
     * @deny (update) User without matching storeId cannot update a purchase.
     * @deny (delete) User without matching storeId cannot delete a purchase.
     * @principle Enforces store-level ownership for purchases.
     */
    match /purchases/{purchaseId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores customer information.
     * @path /customers/{customerId}
     * @allow (list) Anyone can list customers.
     * @allow (get) Anyone can get customers.
     * @allow (create) Authenticated user with matching storeId can create a customer.
     * @allow (update) Authenticated user with matching storeId can update an existing customer.
     * @allow (delete) Authenticated user with matching storeId can delete a customer.
     * @deny (create) Unauthenticated user cannot create a customer.
     * @deny (update) User without matching storeId cannot update a customer.
     * @deny (delete) User without matching storeId cannot delete a customer.
     * @principle Enforces store-level ownership for customers.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores supplier information.
     * @path /suppliers/{supplierId}
     * @allow (list) Anyone can list suppliers.
     * @allow (get) Anyone can get suppliers.
     * @allow (create) Authenticated user with matching storeId can create a supplier.
     * @allow (update) Authenticated user with matching storeId can update an existing supplier.
     * @allow (delete) Authenticated user with matching storeId can delete a supplier.
     * @deny (create) Unauthenticated user cannot create a supplier.
     * @deny (update) User without matching storeId cannot update a supplier.
     * @deny (delete) User without matching storeId cannot delete a supplier.
     * @principle Enforces store-level ownership for suppliers.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores units of measure.
     * @path /units/{unitId}
     * @allow (list) Anyone can list units.
     * @allow (get) Anyone can get units.
     * @allow (create) Authenticated user with matching storeId can create a unit.
     * @allow (update) Authenticated user with matching storeId can update an existing unit.
     * @allow (delete) Authenticated user with matching storeId can delete a unit.
     * @deny (create) Unauthenticated user cannot create a unit.
     * @deny (update) User without matching storeId cannot update a unit.
     * @deny (delete) User without matching storeId cannot delete a unit.
     * @principle Enforces store-level ownership for units.
     */
    match /units/{unitId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores product families/categories.
     * @path /families/{familyId}
     * @allow (list) Anyone can list families.
     * @allow (get) Anyone can get families.
     * @allow (create) Authenticated user with matching storeId can create a family.
     * @allow (update) Authenticated user with matching storeId can update an existing family.
     * @allow (delete) Authenticated user with matching storeId can delete a family.
     * @deny (create) Unauthenticated user cannot create a family.
     * @deny (update) User without matching storeId cannot update a family.
     * @deny (delete) User without matching storeId cannot delete a family.
     * @principle Enforces store-level ownership for families.
     */
    match /families/{familyId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores warehouse information.
     * @path /warehouses/{warehouseId}
     * @allow (list) Anyone can list warehouses.
     * @allow (get) Anyone can get warehouses.
     * @allow (create) Authenticated user with matching storeId can create a warehouse.
     * @allow (update) Authenticated user with matching storeId can update an existing warehouse.
     * @allow (delete) Authenticated user with matching storeId can delete a warehouse.
     * @deny (create) Unauthenticated user cannot create a warehouse.
     * @deny (update) User without matching storeId cannot update a warehouse.
     * @deny (delete) User without matching storeId cannot delete a warehouse.
     * @principle Enforces store-level ownership for warehouses.
     */
    match /warehouses/{warehouseId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores application configuration settings for each store.
     * @path /stores/{storeId}
     * @allow (get) Anyone can get stores.
     * @allow (list) Anyone can list stores.
     * @allow (create) Authenticated user can create a store if the storeId matches their uid.
     * @allow (update) Authenticated user who is the owner of the store can update it.
     * @allow (delete) Authenticated user who is the owner of the store can delete it.
     * @deny (create) Unauthenticated user cannot create a store.
     * @deny (update) User who is not the owner of the store cannot update it.
     * @deny (delete) User who is not the owner of the store cannot delete it.
     * @principle Enforces ownership for store configurations.
     */
    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid && request.resource.data.id == storeId;
      allow update: if isSignedIn() && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    /**
     * @description Stores user profiles.
     * @path /users/{userId}
     * @allow (get) Authenticated user can get their own profile.
     * @allow (list) Not allowed, listing user is highly restricted.
     * @allow (create) Authenticated user can create their own profile if the userId matches their uid.
     * @allow (update) Authenticated user can update their own profile.
     * @allow (delete) Authenticated user can delete their own profile.
     * @deny (create) User cannot create a profile with a different userId.
     * @deny (update) User cannot update someone else's profile.
     * @deny (delete) User cannot delete someone else's profile.
     * @principle Enforces user-level ownership for profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Stores marketing advertisements.
     * @path /ads/{adId}
     * @allow (list) Anyone can list ads.
     * @allow (get) Anyone can get ads.
     * @allow (create) Authenticated user with matching storeId can create an ad.
     * @allow (update) Authenticated user with matching storeId can update an existing ad.
     * @allow (delete) Authenticated user with matching storeId can delete an ad.
     * @deny (create) Unauthenticated user cannot create an ad.
     * @deny (update) User without matching storeId cannot update an ad.
     * @deny (delete) User without matching storeId cannot delete an ad.
     * @principle Allows public read access for ads, restricts modification to store.
     */
    match /ads/{adId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
    }

    /**
     * @description Stores orders from the public catalog.
     * @path /pendingOrders/{orderId}
     * @allow (list) Anyone can list pendingOrders.
     * @allow (get) Anyone can get pendingOrders.
     * @allow (create) Authenticated user with matching storeId can create a pendingOrder.
     * @allow (update) Authenticated user with matching storeId can update an existing pendingOrder.
     * @allow (delete) Authenticated user with matching storeId can delete a pendingOrder.
     * @deny (create) Unauthenticated user cannot create a pendingOrder.
     * @deny (update) User without matching storeId cannot update a pendingOrder.
     * @deny (delete) User without matching storeId cannot delete a pendingOrder.
     */
    match /pendingOrders/{orderId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
    }

     /**
      * @description Stores historical currency exchange rates for a specific store.
      * @path /stores/{storeId}/currencyRates/{rateId}
      * @allow (list) Anyone can list currencyRates.
      * @allow (get) Anyone can get currencyRates.
      * @allow (create) Authenticated user with matching storeId can create a currencyRate.
      * @allow (update) Authenticated user with matching storeId can update an existing currencyRate.
      * @allow (delete) Authenticated user with matching storeId can delete an existing currencyRate.
      * @deny (create) Unauthenticated user cannot create a currencyRate.
      * @deny (update) User without matching storeId cannot update a currencyRate.
      * @deny (delete) User without matching storeId cannot delete a currencyRate.
      */
    match /stores/{storeId}/currencyRates/{rateId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == storeId;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isSignedIn() && request.resource.data.storeId == resource.data.storeId;
    }
  }
}
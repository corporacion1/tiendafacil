/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict store-ownership model, where most data is isolated to a specific store.
 * All collections require a `storeId` field for authorization.
 * Data Structure:
 * - `/stores/{storeId}`: Stores configuration and ownership details. Only the owner can create/modify stores.
 * - Other top-level collections (e.g., `/products`, `/customers`): Contain data related to a specific store and require a `storeId` field.
 * - `/users/{userId}`: Stores user profile information; only the user can read/write their own profile.
 * - `/stores/{storeId}/currencyRates/{rateId}`: Stores currency exchange rates, accessible only within the specified store.
 *
 * Key Security Decisions:
 * - Public listing is disallowed for most collections to prevent unauthorized data access. Only owners of a store can read data related to that store.
 * - All write operations are validated against the `storeId` to ensure data consistency.
 * - User profiles (`/users/{userId}`) are strictly private and only accessible to the authenticated user.
 * - The default security posture for ambiguous relationships is strict owner-only access.
 *
 * Denormalization for Authorization:
 * - The `storeId` field is present in almost all entities and is crucial for authorization. This avoids needing to perform expensive `get()` operations to fetch the store document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource based on the provided userId.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource, and that the document already exists.
     * @param {string} userId - The user ID to compare against the authenticated user's UID.
     * @return {boolean} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Matches the /products/{productId} collection.
     * @path /products/{productId}
     * @allow (read) - Allow anyone to read product data.
     * @allow (create) - Only allow if the storeId matches the user's store ID.
     * @deny (update) - Deny updates if the user is not the owner of the store.
     * @deny (delete) - Deny deletes if the user is not the owner of the store.
     * @principle Enforces store-level ownership for products.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
    }

    /**
     * @description Matches the /inventory_movements/{movementId} collection.
     * @path /inventory_movements/{movementId}
     * @allow (read) - Allow anyone to read inventory movement data.
     * @allow (create) - Only allow if the storeId matches the user's store ID.
     * @deny (update) - Deny updates if the user is not the owner of the store.
     * @deny (delete) - Deny deletes if the user is not the owner of the store.
     * @principle Enforces store-level ownership for inventory movements.
     */
    match /inventory_movements/{movementId} {
      allow get: if true;
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
    }

    /**
     * @description Matches the /sales/{saleId} collection.
     * @path /sales/{saleId}
     * @allow (read) - Allow anyone to read sales data.
     * @allow (create) - Only allow if the storeId matches the user's store ID.
     * @deny (update) - Deny updates if the user is not the owner of the store.
     * @deny (delete) - Deny deletes if the user is not the owner of the store.
     * @principle Enforces store-level ownership for sales records.
     */
    match /sales/{saleId} {
      allow get: if true;
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
    }

    /**
     * @description Matches the /purchases/{purchaseId} collection.
     * @path /purchases/{purchaseId}
     * @allow (read) - Allow anyone to read purchase data.
     * @allow (create) - Only allow if the storeId matches the user's store ID.
     * @deny (update) - Deny updates if the user is not the owner of the store.
     * @deny (delete) - Deny deletes if the user is not the owner of the store.
     * @principle Enforces store-level ownership for purchase records.
     */
    match /purchases/{purchaseId} {
      allow get: if true;
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
    }

    /**
     * @description Matches the /customers/{customerId} collection.
     * @path /customers/{customerId}
     * @allow (read) - Allow anyone to read customer data.
     * @allow (create) - Only allow if the storeId matches the user's store ID.
     * @deny (update) - Deny updates if the user is not the owner of the store.
     * @deny (delete) - Deny deletes if the user is not the owner of the store.
     * @principle Enforces store-level ownership for customer data.
     */
    match /customers/{customerId} {
      allow get: if true;
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
    }

    /**
     * @description Matches the /suppliers/{supplierId} collection.
     * @path /suppliers/{supplierId}
     * @allow (read) - Allow anyone to read supplier data.
     * @allow (create) - Only allow if the storeId matches the user's store ID.
     * @deny (update) - Deny updates if the user is not the owner of the store.
     * @deny (delete) - Deny deletes if the user is not the owner of the store.
     * @principle Enforces store-level ownership for supplier data.
     */
    match /suppliers/{supplierId} {
      allow get: if true;
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
    }

    /**
     * @description Matches the /units/{unitId} collection.
     * @path /units/{unitId}
     * @allow (read) - Allow anyone to read unit data.
     * @allow (create) - Only allow if the storeId matches the user's store ID.
     * @deny (update) - Deny updates if the user is not the owner of the store.
     * @deny (delete) - Deny deletes if the user is not the owner of the store.
     * @principle Enforces store-level ownership for unit data.
     */
    match /units/{unitId} {
      allow get: if true;
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
    }

    /**
     * @description Matches the /families/{familyId} collection.
     * @path /families/{familyId}
     * @allow (read) - Allow anyone to read family data.
     * @allow (create) - Only allow if the storeId matches the user's store ID.
     * @deny (update) - Deny updates if the user is not the owner of the store.
     * @deny (delete) - Deny deletes if the user is not the owner of the store.
     * @principle Enforces store-level ownership for family data.
     */
    match /families/{familyId} {
      allow get: if true;
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
    }

    /**
     * @description Matches the /warehouses/{warehouseId} collection.
     * @path /warehouses/{warehouseId}
     * @allow (read) - Allow anyone to read warehouse data.
     * @allow (create) - Only allow if the storeId matches the user's store ID.
     * @deny (update) - Deny updates if the user is not the owner of the store.
     * @deny (delete) - Deny deletes if the user is not the owner of the store.
     * @principle Enforces store-level ownership for warehouse data.
     */
    match /warehouses/{warehouseId} {
      allow get: if true;
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
    }

    /**
     * @description Matches the /stores/{storeId} collection.
     * @path /stores/{storeId}
     * @allow (read) - Allow anyone to read store data.
     * @allow (create) - Only allow if the user is the owner of the store.
     * @deny (update) - Deny updates if the user is not the owner of the store.
     * @deny (delete) - Deny deletes if the user is not the owner of the store.
     * @principle Enforces owner-only access to store configuration.
     */
    match /stores/{storeId} {
      allow get: if true;
      allow list: if false;

      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.ownerId);
      allow delete: if isExistingOwner(resource.data.ownerId);

      /**
       * @description Matches the /stores/{storeId}/currencyRates/{rateId} collection.
       * @path /stores/{storeId}/currencyRates/{rateId}
       */
      match /currencyRates/{rateId} {
        allow get: if true;
        allow list: if false;
        allow create: if isSignedIn() && getStoreId() == storeId;
        allow update: if isSignedIn() && getStoreId() == storeId;
        allow delete: if isSignedIn() && getStoreId() == storeId;
      }
    }

    /**
     * @description Matches the /users/{userId} collection.
     * @path /users/{userId}
     * @allow (read) - Allow only the user to read their own profile.
     * @allow (create) - Allow only the user to create their own profile (self-registration).
     * @deny (update) - Deny updates if the user is not the owner of the profile.
     * @deny (delete) - Deny deletes if the user is not the owner of the profile.
     * @principle Enforces strict user-level ownership for profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;

      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.uid == resource.data.uid;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Matches the /ads/{adId} collection.
     * @path /ads/{adId}
     */
    match /ads/{adId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Matches the /pendingOrders/{orderId} collection.
     * @path /pendingOrders/{orderId}
     */
    match /pendingOrders/{orderId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
    }

    /**
     * @description Helper function to fetch storeId from user profile
     * @return {string} - Returns the storeId of the current authenticated user.
     */
    function getStoreId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId;
    }
  }
}
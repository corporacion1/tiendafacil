/**
 * @fileoverview Firestore Security Rules for the Inventory Management System.
 *
 * Core Philosophy:
 * This ruleset enforces a multi-tenant security model where each store's data is isolated.
 * Users can only access data within stores they own. Superusers can potentially bypass some restrictions.
 *
 * Data Structure:
 * - /users/{userId}: Global user profiles.
 * - /stores/{storeId}: Root collection for tenant stores. Each store has an `ownerId` field.
 * - /stores/{storeId}/[...]: Subcollections containing store-specific data (products, units, etc.).
 *
 * Key Security Decisions:
 * - Strict store-level ownership: Only the store owner can create, update, or delete store-level data.
 * - No public listing of stores or their subcollections. List operations are restricted to the owner.
 *
 * Denormalization for Authorization:
 * The `Store` entity contains an `ownerId` field, which is crucial for authorization. This allows us to quickly check if a user owns a store without additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the specified store.
     */
    function isOwner(storeId) {
      return get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /**
     * @description Checks if the authenticated user is the owner of the specified store and the document exists.
     */
    function isExistingOwner(storeId) {
      return isSignedIn() && isOwner(storeId) && resource != null;
    }

    /**
     * @description Global user profiles.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their own profile.
     * @allow (get) User with ID 'user123' can read their own profile.
     * @deny (create) User with ID 'user456' cannot create a profile for 'user123'.
     * @deny (get) User with ID 'user456' cannot read the profile of 'user123'.
     * @principle Enforces user-ownership for profile data.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    /**
     * @description Root collection for all tenant stores.
     * @path /stores/{storeId}
     * @allow (create) User with ID 'user123' can create a store with ownerId 'user123'.
     * @deny (create) User with ID 'user456' cannot create a store with ownerId 'user123'.
     * @deny (get) Anonymous user cannot read store data.
     * @principle Enforces store-level ownership; stores are private to their owners.
     */
    match /stores/{storeId} {
      allow get: if isOwner(storeId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid && request.resource.id == storeId;
      allow update: if isExistingOwner(storeId) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isExistingOwner(storeId);

      /**
       * @description Products for a specific store.
       * @path /stores/{storeId}/products/{productId}
       */
      match /products/{productId} {
        allow get: if isOwner(storeId);
        allow list: if isOwner(storeId);
        allow create: if isOwner(storeId);
        allow update: if isExistingOwner(storeId);
        allow delete: if isExistingOwner(storeId);
      }

      /**
       * @description Units of measure for a specific store.
       * @path /stores/{storeId}/units/{unitId}
       */
      match /units/{unitId} {
        allow get: if isOwner(storeId);
        allow list: if isOwner(storeId);
        allow create: if isOwner(storeId);
        allow update: if isExistingOwner(storeId);
        allow delete: if isExistingOwner(storeId);
      }

      /**
       * @description Product families for a specific store.
       * @path /stores/{storeId}/families/{familyId}
       */
      match /families/{familyId} {
        allow get: if isOwner(storeId);
        allow list: if isOwner(storeId);
        allow create: if isOwner(storeId);
        allow update: if isExistingOwner(storeId);
        allow delete: if isExistingOwner(storeId);
      }

      /**
       * @description Warehouses for a specific store.
       * @path /stores/{storeId}/warehouses/{warehouseId}
       */
      match /warehouses/{warehouseId} {
        allow get: if isOwner(storeId);
        allow list: if isOwner(storeId);
        allow create: if isOwner(storeId);
        allow update: if isExistingOwner(storeId);
        allow delete: if isExistingOwner(storeId);
      }

      /**
       * @description Tax types for a specific store.
       * @path /stores/{storeId}/tax_types/{taxTypeId}
       */
      match /tax_types/{taxTypeId} {
        allow get: if isOwner(storeId);
        allow list: if isOwner(storeId);
        allow create: if isOwner(storeId);
        allow update: if isExistingOwner(storeId);
        allow delete: if isExistingOwner(storeId);
      }

      /**
       * @description Inventory movements for a specific store.
       * @path /stores/{storeId}/inventory_movements/{inventoryMovementId}
       */
      match /inventory_movements/{inventoryMovementId} {
        allow get: if isOwner(storeId);
        allow list: if isOwner(storeId);
        allow create: if isOwner(storeId);
        allow update: if isExistingOwner(storeId);
        allow delete: if isExistingOwner(storeId);
      }

      /**
       * @description Sales records for a specific store.
       * @path /stores/{storeId}/sales/{saleId}
       */
      match /sales/{saleId} {
        allow get: if isOwner(storeId);
        allow list: if isOwner(storeId);
        allow create: if isOwner(storeId);
        allow update: if isExistingOwner(storeId);
        allow delete: if isExistingOwner(storeId);

        /**
         * @description Items within a sale for a specific store.
         * @path /stores/{storeId}/sales/{saleId}/sale_items/{saleItemId}
         */
        match /sale_items/{saleItemId} {
          allow get: if isOwner(storeId);
          allow list: if isOwner(storeId);
          allow create: if isOwner(storeId);
          allow update: if isExistingOwner(storeId);
          allow delete: if isExistingOwner(storeId);
        }
      }

      /**
       * @description Purchase records for a specific store.
       * @path /stores/{storeId}/purchases/{purchaseId}
       */
      match /purchases/{purchaseId} {
        allow get: if isOwner(storeId);
        allow list: if isOwner(storeId);
        allow create: if isOwner(storeId);
        allow update: if isExistingOwner(storeId);
        allow delete: if isExistingOwner(storeId);

        /**
         * @description Items within a purchase for a specific store.
         * @path /stores/{storeId}/purchases/{purchaseId}/purchase_items/{purchaseItemId}
         */
        match /purchase_items/{purchaseItemId} {
          allow get: if isOwner(storeId);
          allow list: if isOwner(storeId);
          allow create: if isOwner(storeId);
          allow update: if isExistingOwner(storeId);
          allow delete: if isExistingOwner(storeId);
        }
      }

      /**
       * @description Suppliers for a specific store.
       * @path /stores/{storeId}/suppliers/{supplierId}
       */
      match /suppliers/{supplierId} {
        allow get: if isOwner(storeId);
        allow list: if isOwner(storeId);
        allow create: if isOwner(storeId);
        allow update: if isExistingOwner(storeId);
        allow delete: if isExistingOwner(storeId);
      }

      /**
       * @description Customers for a specific store.
       * @path /stores/{storeId}/customers/{customerId}
       */
      match /customers/{customerId} {
        allow get: if isOwner(storeId);
        allow list: if isOwner(storeId);
        allow create: if isOwner(storeId);
        allow update: if isExistingOwner(storeId);
        allow delete: if isExistingOwner(storeId);
      }

      /**
       * @description Currency exchange rates for a specific store.
       * @path /stores/{storeId}/currency_rates/{currencyRateId}
       */
      match /currency_rates/{currencyRateId} {
        allow get: if isOwner(storeId);
        allow list: if isOwner(storeId);
        allow create: if isOwner(storeId);
        allow update: if isExistingOwner(storeId);
        allow delete: if isExistingOwner(storeId);
      }

       /**
        * @description Chat conversations for a specific store.
        * @path /stores/{storeId}/chats/{chatId}
        */
      match /chats/{chatId} {
          allow get: if isOwner(storeId);
          allow list: if isOwner(storeId);
          allow create: if isOwner(storeId);
          allow update: if isExistingOwner(storeId);
          allow delete: if isExistingOwner(storeId);

          /**
           * @description Messages within a chat for a specific store.
           * @path /stores/{storeId}/chats/{chatId}/messages/{messageId}
           */
          match /messages/{messageId} {
              allow get: if isOwner(storeId);
              allow list: if isOwner(storeId);
              allow create: if isOwner(storeId);
              allow update: if isExistingOwner(storeId);
              allow delete: if isExistingOwner(storeId);
          }
      }
    }
  }
}
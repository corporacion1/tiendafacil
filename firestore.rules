rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // MODO DE PRUEBA: Permite leer y escribir a cualquier usuario que haya iniciado sesión.
    // Esto es ideal para el desarrollo y las pruebas funcionales.
    // Para producción, se deben implementar reglas más estrictas.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

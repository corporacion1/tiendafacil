/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for most data, with stores having an additional layer of ownership.
 *
 * Data Structure:
 * - /users/{userId}: User profiles, accessible only by the user themselves.
 * - /stores/{storeId}: Store configurations, accessible only by the store owner.
 * - Other top-level collections (products, sales, etc.): Accessible only by the owner of the store to which they belong.
 * - /stores/{storeId}/currencyRates/{rateId}: Currency rates for a specific store, accessible only by the store owner.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Read-only collections are not explicitly defined in this prototype.
 * - The default security posture for ambiguous relationships is strict owner-only access.
 *
 * Denormalization for Authorization:
 * - Documents like products, sales, and purchases MUST include a `storeId` field to link them to a specific store. This allows for efficient store-level authorization without requiring additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource and the resource exists.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description User profiles are private and only accessible to the user themselves.
     * @path /users/{userId}
     * @allow (create) User with UID 'user123' creates their profile at /users/user123.
     * @deny (create) User with UID 'user123' attempts to create a profile at /users/user456.
     * @principle Enforces document ownership for writes and reads.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Stores application configuration settings for each store. Only the store owner can manage the store.
     * @path /stores/{storeId}
     * @allow (create) User with UID 'user123' creates a store with ID 'store456' where request.resource.data.ownerId == 'user123'.
     * @deny (update) User with UID 'user123' attempts to update store 'store456' owned by 'user789'.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId} {
      allow get: if resource.data.ownerId == request.auth.uid;
      allow list: if false;
      allow create: if request.resource.data.ownerId == request.auth.uid;
      allow update: if resource.data.ownerId == request.auth.uid && resource != null;
      allow delete: if resource.data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Stores product information. Only the store owner can manage products.
     * @path /products/{productId}
     * @allow (create) User with UID 'user123' creates a product for store 'store456' where request.resource.data.storeId == 'store456' AND store 'store456' is owned by 'user123'.
     * @deny (update) User with UID 'user123' attempts to update a product for store 'store789'.
     * @principle Enforces document ownership for writes. Relational integrity with store.
     */
    match /products/{productId} {
      allow get: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid;
      allow list: if get(/databases/$(database)/documents/stores/$(productId)).data.ownerId == request.auth.uid;
      allow create: if get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      allow update: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Stores inventory movement records. Only the store owner can manage inventory movements.
     * @path /inventory_movements/{movementId}
     * @allow (create) User with UID 'user123' creates an inventory movement for store 'store456' where request.resource.data.storeId == 'store456' AND store 'store456' is owned by 'user123'.
     * @deny (update) User with UID 'user123' attempts to update an inventory movement for store 'store789'.
     * @principle Enforces document ownership for writes. Relational integrity with store.
     */
    match /inventory_movements/{movementId} {
      allow get: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid;
      allow list: if get(/databases/$(database)/documents/stores/$(movementId)).data.ownerId == request.auth.uid;
      allow create: if get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      allow update: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Stores sales transaction records. Only the store owner can manage sales.
     * @path /sales/{saleId}
     * @allow (create) User with UID 'user123' creates a sale for store 'store456' where request.resource.data.storeId == 'store456' AND store 'store456' is owned by 'user123'.
     * @deny (update) User with UID 'user123' attempts to update a sale for store 'store789'.
     * @principle Enforces document ownership for writes. Relational integrity with store.
     */
    match /sales/{saleId} {
      allow get: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid;
      allow list: if get(/databases/$(database)/documents/stores/$(saleId)).data.ownerId == request.auth.uid;
      allow create: if get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      allow update: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Stores purchase order records. Only the store owner can manage purchases.
     * @path /purchases/{purchaseId}
     * @allow (create) User with UID 'user123' creates a purchase for store 'store456' where request.resource.data.storeId == 'store456' AND store 'store456' is owned by 'user123'.
     * @deny (update) User with UID 'user123' attempts to update a purchase for store 'store789'.
     * @principle Enforces document ownership for writes. Relational integrity with store.
     */
    match /purchases/{purchaseId} {
      allow get: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid;
      allow list: if get(/databases/$(database)/documents/stores/$(purchaseId)).data.ownerId == request.auth.uid;
      allow create: if get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      allow update: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Stores customer information. Only the store owner can manage customers.
     * @path /customers/{customerId}
     * @allow (create) User with UID 'user123' creates a customer for store 'store456' where request.resource.data.storeId == 'store456' AND store 'store456' is owned by 'user123'.
     * @deny (update) User with UID 'user123' attempts to update a customer for store 'store789'.
     * @principle Enforces document ownership for writes. Relational integrity with store.
     */
    match /customers/{customerId} {
      allow get: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid;
      allow list: if get(/databases/$(database)/documents/stores/$(customerId)).data.ownerId == request.auth.uid;
      allow create: if get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      allow update: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Stores supplier information. Only the store owner can manage suppliers.
     * @path /suppliers/{supplierId}
     * @allow (create) User with UID 'user123' creates a supplier for store 'store456' where request.resource.data.storeId == 'store456' AND store 'store456' is owned by 'user123'.
     * @deny (update) User with UID 'user123' attempts to update a supplier for store 'store789'.
     * @principle Enforces document ownership for writes. Relational integrity with store.
     */
    match /suppliers/{supplierId} {
      allow get: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid;
      allow list: if get(/databases/$(database)/documents/stores/$(supplierId)).data.ownerId == request.auth.uid;
      allow create: if get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      allow update: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Stores units of measure. Only the store owner can manage units.
     * @path /units/{unitId}
     * @allow (create) User with UID 'user123' creates a unit for store 'store456' where request.resource.data.storeId == 'store456' AND store 'store456' is owned by 'user123'.
     * @deny (update) User with UID 'user123' attempts to update a unit for store 'store789'.
     * @principle Enforces document ownership for writes. Relational integrity with store.
     */
    match /units/{unitId} {
      allow get: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid;
      allow list: if get(/databases/$(database)/documents/stores/$(unitId)).data.ownerId == request.auth.uid;
      allow create: if get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      allow update: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Stores product families/categories. Only the store owner can manage families.
     * @path /families/{familyId}
     * @allow (create) User with UID 'user123' creates a family for store 'store456' where request.resource.data.storeId == 'store456' AND store 'store456' is owned by 'user123'.
     * @deny (update) User with UID 'user123' attempts to update a family for store 'store789'.
     * @principle Enforces document ownership for writes. Relational integrity with store.
     */
    match /families/{familyId} {
      allow get: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid;
      allow list: if get(/databases/$(database)/documents/stores/$(familyId)).data.ownerId == request.auth.uid;
      allow create: if get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      allow update: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Stores warehouse information. Only the store owner can manage warehouses.
     * @path /warehouses/{warehouseId}
     * @allow (create) User with UID 'user123' creates a warehouse for store 'store456' where request.resource.data.storeId == 'store456' AND store 'store456' is owned by 'user123'.
     * @deny (update) User with UID 'user123' attempts to update a warehouse for store 'store789'.
     * @principle Enforces document ownership for writes. Relational integrity with store.
     */
    match /warehouses/{warehouseId} {
      allow get: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid;
      allow list: if get(/databases/$(database)/documents/stores/$(warehouseId)).data.ownerId == request.auth.uid;
      allow create: if get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid;
      allow update: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Stores marketing advertisements.
     * @path /ads/{adId}
     * @allow (read, list) Public access for displaying ads.
     * @allow (create, update, delete) No write permission.
     * @principle Public read access, no write access in this prototype.
     */
    match /ads/{adId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Stores orders from the public catalog.
     * @path /pendingOrders/{orderId}
     * @allow (create) Any authenticated user can create a pending order.
     * @deny (read, list, update, delete) Only the store owner can manage pending orders.
     * @principle Authenticated users can create orders, store owners manage them.
     */
    match /pendingOrders/{orderId} {
      allow get: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid;
      allow list: if get(/databases/$(database)/documents/stores/$(orderId)).data.ownerId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Stores historical currency exchange rates for a specific store. Only the store owner can manage currency rates.
     * @path /stores/{storeId}/currencyRates/{rateId}
     * @allow (create) User with UID 'user123' creates a currency rate for store 'store456' where store 'store456' is owned by 'user123'.
     * @deny (update) User with UID 'user123' attempts to update a currency rate for store 'store789'.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId}/currencyRates/{rateId} {
      allow get: if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow list: if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow create: if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }
  }
}
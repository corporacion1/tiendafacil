/**
 * @file Overview
 * This ruleset enforces a store-ownership model, where each document belongs to a specific store, identified by a `storeId` field.
 *
 * Data Structure:
 * - Top-level collections: /products, /taxTypes, /inventoryMovements, /sales, /purchases, /customers, /stores, /families
 * - Subcollections: /sales/{saleId}/saleItems, /purchases/{purchaseId}/purchaseItems
 *
 * Key Security Decisions:
 * - Documents in all collections are secured by checking if the authenticated user has access to the `storeId` associated with the document.
 * - The `warehouses` collection, which triggered the initial error, is not defined in the data model. Rules will be created, but may need adjustment.
 * - List operations are generally allowed to signed-in users.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(storeId) {
        return isSignedIn();
    }

    function isExistingOwner(storeId) {
      return isSignedIn() && resource.data.storeId == storeId;
    }

    /**
     * @description Allows any signed-in user to read products. Only store owners can create, update, or delete products.
     * @path /products/{productId}
     * @allow (list) User with any valid authentication can list products.
     * @allow (get) User with any valid authentication can get products.
     * @allow (create) User with valid authentication can create a product.
     * @allow (update) User with valid authentication can update a product.
     * @allow (delete) User with valid authentication can delete a product.
     * @deny (create) Non-authenticated user cannot create a product.
     * @deny (update) Non-authenticated user cannot update a product.
     * @deny (delete) Non-authenticated user cannot delete a product.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    /**
     * @description Allows any signed-in user to read tax types. Only store owners can create, update, or delete tax types.
     * @path /taxTypes/{taxTypeId}
     * @allow (list) User with any valid authentication can list tax types.
     * @allow (get) User with any valid authentication can get tax types.
     * @allow (create) User with valid authentication can create a tax type.
     * @allow (update) User with valid authentication can update a tax type.
     * @allow (delete) User with valid authentication can delete a tax type.
     * @deny (create) Non-authenticated user cannot create a tax type.
     * @deny (update) Non-authenticated user cannot update a tax type.
     * @deny (delete) Non-authenticated user cannot delete a tax type.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /taxTypes/{taxTypeId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    /**
     * @description Allows any signed-in user to read inventory movements. Only store owners can create, update, or delete inventory movements.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (list) User with any valid authentication can list inventory movements.
     * @allow (get) User with any valid authentication can get inventory movements.
     * @allow (create) User with valid authentication can create an inventory movement.
     * @allow (update) User with valid authentication can update an inventory movement.
     * @allow (delete) User with valid authentication can delete an inventory movement.
     * @deny (create) Non-authenticated user cannot create an inventory movement.
     * @deny (update) Non-authenticated user cannot update an inventory movement.
     * @deny (delete) Non-authenticated user cannot delete an inventory movement.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    /**
     * @description Allows any signed-in user to read sales. Only store owners can create, update, or delete sales.
     * @path /sales/{saleId}
     * @allow (list) User with any valid authentication can list sales.
     * @allow (get) User with any valid authentication can get sales.
     * @allow (create) User with valid authentication can create a sale.
     * @allow (update) User with valid authentication can update a sale.
     * @allow (delete) User with valid authentication can delete a sale.
     * @deny (create) Non-authenticated user cannot create a sale.
     * @deny (update) Non-authenticated user cannot update a sale.
     * @deny (delete) Non-authenticated user cannot delete a sale.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /sales/{saleId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;

      /**
       * @description Allows any signed-in user to read sale items. Only store owners can create, update, or delete sale items.
       * @path /sales/{saleId}/saleItems/{saleItemId}
       * @allow (list) User with any valid authentication can list sale items.
       * @allow (get) User with any valid authentication can get sale items.
       * @allow (create) User with valid authentication can create a sale item.
       * @allow (update) User with valid authentication can update a sale item.
       * @allow (delete) User with valid authentication can delete a sale item.
       * @deny (create) Non-authenticated user cannot create a sale item.
       * @deny (update) Non-authenticated user cannot update a sale item.
       * @deny (delete) Non-authenticated user cannot delete a sale item.
       * @principle Enforces store ownership for writes; allows public reads.
       */
      match /saleItems/{saleItemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
        allow update: if isSignedIn() && get(/databases/$(database)/documents/sales/$(saleId)).data.storeId == request.auth.uid;
        allow delete: if isSignedIn() && get(/databases/$(database)/documents/sales/$(saleId)).data.storeId == request.auth.uid;
      }
    }

    /**
     * @description Allows any signed-in user to read purchases. Only store owners can create, update, or delete purchases.
     * @path /purchases/{purchaseId}
     * @allow (list) User with any valid authentication can list purchases.
     * @allow (get) User with any valid authentication can get purchases.
     * @allow (create) User with valid authentication can create a purchase.
     * @allow (update) User with valid authentication can update a purchase.
     * @allow (delete) User with valid authentication can delete a purchase.
     * @deny (create) Non-authenticated user cannot create a purchase.
     * @deny (update) Non-authenticated user cannot update a purchase.
     * @deny (delete) Non-authenticated user cannot delete a purchase.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /purchases/{purchaseId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;

      /**
       * @description Allows any signed-in user to read purchase items. Only store owners can create, update, or delete purchase items.
       * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
       * @allow (list) User with any valid authentication can list purchase items.
       * @allow (get) User with any valid authentication can get purchase items.
       * @allow (create) User with valid authentication can create a purchase item.
       * @allow (update) User with valid authentication can update a purchase item.
       * @allow (delete) User with valid authentication can delete a purchase item.
       * @deny (create) Non-authenticated user cannot create a purchase item.
       * @deny (update) Non-authenticated user cannot update a purchase item.
       * @deny (delete) Non-authenticated user cannot delete a purchase item.
       * @principle Enforces store ownership for writes; allows public reads.
       */
      match /purchaseItems/{purchaseItemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
        allow update: if isSignedIn() && get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId == request.auth.uid;
        allow delete: if isSignedIn() && get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId == request.auth.uid;
      }
    }

    /**
     * @description Allows any signed-in user to read customers. Only store owners can create, update, or delete customers.
     * @path /customers/{customerId}
     * @allow (list) User with any valid authentication can list customers.
     * @allow (get) User with any valid authentication can get customers.
     * @allow (create) User with valid authentication can create a customer.
     * @allow (update) User with valid authentication can update a customer.
     * @allow (delete) User with valid authentication can delete a customer.
     * @deny (create) Non-authenticated user cannot create a customer.
     * @deny (update) Non-authenticated user cannot update a customer.
     * @deny (delete) Non-authenticated user cannot delete a customer.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /customers/{customerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    /**
     * @description Allows only the store owner to read, create, update, or delete store configurations.
     * @path /stores/{storeId}
     * @allow (list) User with any valid authentication can list stores.
     * @allow (get) User with any valid authentication can get stores.
     * @allow (create) User with valid authentication can create a store.
     * @allow (update) User with valid authentication can update a store.
     * @allow (delete) User with valid authentication can delete a store.
     * @deny (create) Non-authenticated user cannot create a store.
     * @deny (update) Non-authenticated user cannot update a store.
     * @deny (delete) Non-authenticated user cannot delete a store.
     * @principle Enforces strict store ownership.
     */
    match /stores/{storeId} {
      allow get, list: if isSignedIn();
      allow create: if request.auth.uid == storeId;
      allow update: if request.auth.uid == storeId;
      allow delete: if request.auth.uid == storeId;
    }

    /**
     * @description Allows any signed-in user to read product families. Only store owners can create, update, or delete product families.
     * @path /families/{familyId}
     * @allow (list) User with any valid authentication can list families.
     * @allow (get) User with any valid authentication can get families.
     * @allow (create) User with valid authentication can create a family.
     * @allow (update) User with valid authentication can update a family.
     * @allow (delete) User with valid authentication can delete a family.
     * @deny (create) Non-authenticated user cannot create a family.
     * @deny (update) Non-authenticated user cannot update a family.
     * @deny (delete) Non-authenticated user cannot delete a family.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /families/{familyId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    /**
     * @description This rule addresses the error reported for the 'warehouses' collection.  Since 'warehouses' is not defined in the data model,
     *              access is granted to signed-in users.  This should be reviewed and adjusted once the data model is clarified.
     * @path /warehouses
     * @allow (list) User with any valid authentication can list warehouses.
     * @allow (get) User with any valid authentication can get warehouses.
     * @allow (create) User with valid authentication can create a warehouse.
     * @allow (update) User with valid authentication can update a warehouse.
     * @allow (delete) User with valid authentication can delete a warehouse.
     * @principle Allows access to signed-in users; needs review.
     */
    match /warehouses/{warehouseId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
        allow update: if isSignedIn() && request.resource.data.storeId == resource.data.storeId && resource.data.storeId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }
  }
}
/**
 * @fileoverview Firestore Security Rules for the inventory and point-of-sale system.
 *
 * Core Philosophy:
 * This ruleset allows full read access to all authenticated users. It restricts write access to only authenticated users.
 *
 * Data Structure:
 * All data is stored in top-level collections: /products, /inventoryMovements, /sales, /purchases, /customers, /suppliers, /taxTypes, and /configuration.
 * Subcollections are used to represent one-to-many relationships: /sales/{saleId}/saleItems/{saleItemId} and /purchases/{purchaseId}/purchaseItems/{purchaseItemId}.
 *
 * Key Security Decisions:
 *  - Authenticated users can read all data.
 *  - Authenticated users can create, update, and delete any data.
 *  - No specific ownership or role-based access control is enforced beyond authentication.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Grants read and write access to the /products collection for authenticated users.
     * @path /products/{productId}
     * @allow (get, list) User is signed in.
     * @allow (create, update, delete) User is signed in.
     * @deny (create, update, delete) User is not signed in.
     * @principle Authenticated users can read and write any product.
     */
    match /products/{productId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Grants read and write access to the /inventoryMovements collection for authenticated users.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (get, list) User is signed in.
     * @allow (create, update, delete) User is signed in.
     * @deny (create, update, delete) User is not signed in.
     * @principle Authenticated users can read and write any inventory movement.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Grants read and write access to the /sales collection for authenticated users.
     * @path /sales/{saleId}
     * @allow (get, list) User is signed in.
     * @allow (create, update, delete) User is signed in.
     * @deny (create, update, delete) User is not signed in.
     * @principle Authenticated users can read and write any sale.
     */
    match /sales/{saleId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();

      /**
       * @description Grants read and write access to the /sales/{saleId}/saleItems subcollection for authenticated users.
       * @path /sales/{saleId}/saleItems/{saleItemId}
       * @allow (get, list) User is signed in.
       * @allow (create, update, delete) User is signed in.
       * @deny (create, update, delete) User is not signed in.
       * @principle Authenticated users can read and write any sale item.
       */
      match /saleItems/{saleItemId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn();
      }
    }

    /**
     * @description Grants read and write access to the /purchases collection for authenticated users.
     * @path /purchases/{purchaseId}
     * @allow (get, list) User is signed in.
     * @allow (create, update, delete) User is signed in.
     * @deny (create, update, delete) User is not signed in.
     * @principle Authenticated users can read and write any purchase.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();

      /**
       * @description Grants read and write access to the /purchases/{purchaseId}/purchaseItems subcollection for authenticated users.
       * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
       * @allow (get, list) User is signed in.
       * @allow (create, update, delete) User is signed in.
       * @deny (create, update, delete) User is not signed in.
       * @principle Authenticated users can read and write any purchase item.
       */
      match /purchaseItems/{purchaseItemId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn();
      }
    }

    /**
     * @description Grants read and write access to the /customers collection for authenticated users.
     * @path /customers/{customerId}
     * @allow (get, list) User is signed in.
     * @allow (create, update, delete) User is signed in.
     * @deny (create, update, delete) User is not signed in.
     * @principle Authenticated users can read and write any customer.
     */
    match /customers/{customerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Grants read and write access to the /suppliers collection for authenticated users.
     * @path /suppliers/{supplierId}
     * @allow (get, list) User is signed in.
     * @allow (create, update, delete) User is signed in.
     * @deny (create, update, delete) User is not signed in.
     * @principle Authenticated users can read and write any supplier.
     */
    match /suppliers/{supplierId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Grants read and write access to the /taxTypes collection for authenticated users.
     * @path /taxTypes/{taxTypeId}
     * @allow (get, list) User is signed in.
     * @allow (create, update, delete) User is signed in.
     * @deny (create, update, delete) User is not signed in.
     * @principle Authenticated users can read and write any tax type.
     */
    match /taxTypes/{taxTypeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Grants read and write access to the /configuration collection for authenticated users.
     * @path /configuration/{configurationId}
     * @allow (get, list) User is signed in.
     * @allow (create, update, delete) User is signed in.
     * @deny (create, update, delete) User is not signed in.
     * @principle Authenticated users can read and write any configuration.
     */
    match /configuration/{configurationId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}
/**
 * @fileoverview Firestore Security Rules for the inventory and point-of-sale system.
 *
 * Core Philosophy:
 * This ruleset provides basic security for all the data, allowing only authenticated access, with no ownership checks.
 *
 * Data Structure:
 * The database consists of several top-level collections, each representing a core entity:
 *   - /products/{productId}
 *   - /inventoryMovements/{inventoryMovementId}
 *   - /sales/{saleId}
 *   - /sales/{saleId}/saleItems/{saleItemId}
 *   - /purchases/{purchaseId}
 *   - /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
 *   - /customers/{customerId}
 *   - /suppliers/{supplierId}
 *   - /taxTypes/{taxTypeId}
 *   - /configuration/{configurationId}
 *
 * Key Security Decisions:
 *   - No listing of any collections is allowed by default.
 *   - No validation of data is implemented during this phase.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Secure products documents. Only authenticated users can read and write.
     * @path /products/{productId}
     * @allow (get) User is authenticated.
     * @deny (create) User is not authenticated.
     * @principle Allows authenticated users to read any product.
     */
    match /products/{productId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Secure inventoryMovements documents. Only authenticated users can read and write.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (get) User is authenticated.
     * @deny (create) User is not authenticated.
     * @principle Allows authenticated users to read any inventoryMovement.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Secure sales documents. Only authenticated users can read and write.
     * @path /sales/{saleId}
     * @allow (get) User is authenticated.
     * @deny (create) User is not authenticated.
     * @principle Allows authenticated users to read any sale.
     */
    match /sales/{saleId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Secure saleItems subcollection under a sale. Only authenticated users can read and write.
     * @path /sales/{saleId}/saleItems/{saleItemId}
     * @allow (get) User is authenticated.
     * @deny (create) User is not authenticated.
     * @principle Allows authenticated users to read any saleItem.
     */
    match /sales/{saleId}/saleItems/{saleItemId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Secure purchases documents. Only authenticated users can read and write.
     * @path /purchases/{purchaseId}
     * @allow (get) User is authenticated.
     * @deny (create) User is not authenticated.
     * @principle Allows authenticated users to read any purchase.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Secure purchaseItems subcollection under a purchase. Only authenticated users can read and write.
     * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     * @allow (get) User is authenticated.
     * @deny (create) User is not authenticated.
     * @principle Allows authenticated users to read any purchaseItem.
     */
    match /purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Secure customers documents. Only authenticated users can read and write.
     * @path /customers/{customerId}
     * @allow (get) User is authenticated.
     * @deny (create) User is not authenticated.
     * @principle Allows authenticated users to read any customer.
     */
    match /customers/{customerId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Secure suppliers documents. Only authenticated users can read and write.
     * @path /suppliers/{supplierId}
     * @allow (get) User is authenticated.
     * @deny (create) User is not authenticated.
     * @principle Allows authenticated users to read any supplier.
     */
    match /suppliers/{supplierId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Secure taxTypes documents. Only authenticated users can read and write.
     * @path /taxTypes/{taxTypeId}
     * @allow (get) User is authenticated.
     * @deny (create) User is not authenticated.
     * @principle Allows authenticated users to read any taxType.
     */
    match /taxTypes/{taxTypeId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Secure configuration documents. Only authenticated users can read and write.
     * @path /configuration/{configurationId}
     * @allow (get) User is authenticated.
     * @deny (create) User is not authenticated.
     * @principle Allows authenticated users to read any configuration.
     */
    match /configuration/{configurationId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}
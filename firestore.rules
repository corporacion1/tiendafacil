/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset enforces a multi-tenant data model where each document belongs to a specific store, identified by a `storeId` field.
 * Access is generally restricted to authenticated users, with read access being more permissive than write access.
 *
 * Data Structure:
 * The Firestore database is organized into top-level collections: `/stores`, `/products`, `/sales`, `/purchases`, `/customers`, `/suppliers`, `/units`, `/families`, `/warehouses`, `/ads`, `/cashSessions`, and `/users`.
 * Most collections are designed to store data related to individual stores, with the `storeId` field acting as the primary key for data segregation.
 * The `/users/{userId}` collection stores public user profiles.
 *
 * Key Security Decisions:
 * - Listing of documents is generally allowed for all users (signed in or not) to facilitate discovery, except for the `/users` collection.
 * - Write operations (create, update, delete) are restricted to authenticated users.
 * - Data validation is minimal in this prototype phase, focusing primarily on relational integrity by enforcing consistency between the `storeId` field in the document and the `storeId` in the request.
 * - No role-based access control (RBAC) is implemented in this prototype.
 *
 * Denormalization for Authorization:
 * - The `storeId` field is crucial for authorization and must be present in all documents within store-specific collections. This avoids costly `get()` operations to determine the store a document belongs to.
 *
 * Structural Segregation:
 * - Public data (e.g., product listings) and private data (e.g., sales records) are stored in separate top-level collections. This avoids the need for complex filtering based on boolean flags.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants access to store settings based on store ID.
     * @path /stores/{storeId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn();
     * @allow delete: if false;
     * @deny create: if !("id" in request.resource.data);
     * @principle Store settings should be readable by anyone, but only creatable and updatable by authenticated users.
     */
    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    /**
     * @description Grants access to products.
     * @path /products
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn();
     * @allow delete: if isSignedIn();
     * @deny create: if !("storeId" in request.resource.data);
     * @principle Allows anyone to read the products, but only authenticated users can modify them.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Grants access to sales.
     * @path /sales
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn();
     * @allow delete: if isSignedIn();
     * @deny create: if !("storeId" in request.resource.data);
     * @principle Allows anyone to read the sales, but only authenticated users can modify them.
     */
    match /sales/{saleId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Grants access to purchases.
     * @path /purchases
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn();
     * @allow delete: if isSignedIn();
     * @deny create: if !("storeId" in request.resource.data);
     * @principle Allows anyone to read the purchases, but only authenticated users can modify them.
     */
    match /purchases/{purchaseId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Grants access to customers.
     * @path /customers
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn();
     * @allow delete: if isSignedIn();
     * @deny create: if !("storeId" in request.resource.data);
     * @principle Allows anyone to read the customers, but only authenticated users can modify them.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Grants access to suppliers.
     * @path /suppliers
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn();
     * @allow delete: if isSignedIn();
     * @deny create: if !("storeId" in request.resource.data);
     * @principle Allows anyone to read the suppliers, but only authenticated users can modify them.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Grants access to units.
     * @path /units
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn();
     * @allow delete: if isSignedIn();
     * @deny create: if !("storeId" in request.resource.data);
     * @principle Allows anyone to read the units, but only authenticated users can modify them.
     */
    match /units/{unitId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Grants access to families.
     * @path /families
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn();
     * @allow delete: if isSignedIn();
     * @deny create: if !("storeId" in request.resource.data);
     * @principle Allows anyone to read the families, but only authenticated users can modify them.
     */
    match /families/{familyId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Grants access to warehouses.
     * @path /warehouses
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn();
     * @allow delete: if isSignedIn();
     * @deny create: if !("storeId" in request.resource.data);
     * @principle Allows anyone to read the warehouses, but only authenticated users can modify them.
     */
    match /warehouses/{warehouseId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Grants access to ads.
     * @path /ads
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn();
     * @allow delete: if isSignedIn();
     * @principle Allows anyone to read the ads, but only authenticated users can modify them.
     */
    match /ads/{adId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

     /**
     * @description Grants access to cashSessions.
     * @path /cashSessions
     * @allow get, list: if true;
     * @allow create: if isSignedIn();
     * @allow update: if isSignedIn();
     * @allow delete: if isSignedIn();
     * @principle Allows anyone to read the cashSessions, but only authenticated users can modify them.
     */
    match /cashSessions/{cashSessionId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Grants access to user profiles.
     * @path /users/{userId}
     * @allow get: if true;
     * @allow list: if false;
     * @allow create: if isOwner(userId);
     * @allow update: if isOwner(userId);
     * @allow delete: if isOwner(userId);
     * @principle Only the user can create, update, or delete their own profile. Listing is denied.
     */
    match /users/{userId} {
      allow get: if true;
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
  }

  // Helper function to determine if the current user is the owner of the document.
  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  // Helper function to determine if the user is signed in
  function isSignedIn() {
    return request.auth != null;
  }
}
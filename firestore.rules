/**
 * @fileoverview Firestore Security Rules for the inventory management application.
 *
 * Core Philosophy:
 * This ruleset prioritizes security and data ownership, enforcing strict access controls based on user authentication.
 * It assumes a separation of concerns, where different collections serve distinct purposes with tailored security policies.
 * The default posture is to deny access unless explicitly granted.
 *
 * Data Structure:
 * The Firestore database consists of several top-level collections, including:
 * - /products/{productId}: Product information.
 * - /tax_types/{taxTypeId}: Tax type definitions.
 * - /inventory_movements/{inventoryMovementId}: Records of inventory changes.
 * - /sales/{saleId}/sale_items/{saleItemId}: Sales transactions and their line items.
 * - /purchases/{purchaseId}/purchase_items/{purchaseItemId}: Purchase orders and their line items.
 * - /suppliers/{supplierId}: Supplier information.
 * - /customers/{customerId}: Customer information.
 * - /store_configuration/{storeConfigurationId}: Store-wide settings (single document).
 * - /users/{userId}: User profiles (owner-only access).
 * - /currency_rates/{currencyRateId}: Currency exchange rates.
 *
 * Key Security Decisions:
 * - User listing is generally disallowed for privacy.
 * - The /store_configuration collection is read-only for all authenticated users.
 * - Currency rates should be publicly available so the error from NextJS can be fixed.
 * - All write operations require authentication (no anonymous writes).
 *
 * Denormalization for Authorization:
 *  No denormalization is explicitly used in this ruleset. However, consider adding fields like `ownerId` to documents
 *  if more granular ownership-based rules are needed in the future (e.g., for Products or Sales).
 *
 * Structural Segregation:
 *  There is no explicit segregation of public vs. private data using separate collections. If a feature requires public
 *  read access alongside private write access (e.g., public recipes with owner-only editing), consider using separate
 *  collections for public and private data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    /**
     * @description Allows anyone to read curreny rates.
     * @path /currency_rates/{currencyRateId}
     * @allow (get, list)
     * @deny (create, update, delete)
     * @principle Allows all read access to currency rates, and deny all write access.
     */
    match /currency_rates/{currencyRateId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows read access to store configuration for signed-in users, but prohibits modifications.
     * @path /store_configuration/{storeConfigurationId}
     * @allow get, list: if isSignedIn();
     * @deny create, update, delete: Always
     * @principle Restricts modifications to store configuration while allowing authenticated read access.
     */
    match /store_configuration/{storeConfigurationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Allows only the authenticated user to read, update, and delete their own user document.
     * @path /users/{userId}
     * @allow (get, create, update, delete) when the user ID matches the authenticated user's ID.
     * @deny (get, create, update, delete) when the user ID does not match the authenticated user's ID.
     * @principle Enforces strict user-ownership for user profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == request.auth.uid;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows CRUD operations on products.
     * @path /products/{productId}
     * @allow create: if isSignedIn();
     * @allow get, list: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @principle Only signed in users can manage products
     */
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows CRUD operations on units.
     * @path /units/{unitId}
     * @allow create: if isSignedIn();
     * @allow get, list: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @principle Only signed in users can manage units
     */
    match /units/{unitId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows CRUD operations on families.
     * @path /families/{familyId}
     * @allow create: if isSignedIn();
     * @allow get, list: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @principle Only signed in users can manage families
     */
    match /families/{familyId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows CRUD operations on warehouses.
     * @path /warehouses/{warehouseId}
     * @allow create: if isSignedIn();
     * @allow get, list: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @principle Only signed in users can manage warehouses
     */
    match /warehouses/{warehouseId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows CRUD operations on tax types.
     * @path /tax_types/{taxTypeId}
     * @allow create: if isSignedIn();
     * @allow get, list: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @principle Only signed in users can manage tax types
     */
    match /tax_types/{taxTypeId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows CRUD operations on inventory movements.
     * @path /inventory_movements/{inventoryMovementId}
     * @allow create: if isSignedIn();
     * @allow get, list: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @principle Only signed in users can manage inventory movements
     */
    match /inventory_movements/{inventoryMovementId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows CRUD operations on sales.
     * @path /sales/{saleId}
     * @allow create: if isSignedIn();
     * @allow get, list: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @principle Only signed in users can manage sales
     */
    match /sales/{saleId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows CRUD operations on sale items.
     * @path /sales/{saleId}/sale_items/{saleItemId}
     * @allow create: if isSignedIn();
     * @allow get, list: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @principle Only signed in users can manage sale items
     */
    match /sales/{saleId}/sale_items/{saleItemId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows CRUD operations on purchases.
     * @path /purchases/{purchaseId}
     * @allow create: if isSignedIn();
     * @allow get, list: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @principle Only signed in users can manage purchases
     */
    match /purchases/{purchaseId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows CRUD operations on purchase items.
     * @path /purchases/{purchaseId}/purchase_items/{purchaseItemId}
     * @allow create: if isSignedIn();
     * @allow get, list: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @principle Only signed in users can manage purchase items
     */
    match /purchases/{purchaseId}/purchase_items/{purchaseItemId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows CRUD operations on suppliers.
     * @path /suppliers/{supplierId}
     * @allow create: if isSignedIn();
     * @allow get, list: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @principle Only signed in users can manage suppliers
     */
    match /suppliers/{supplierId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows CRUD operations on customers.
     * @path /customers/{customerId}
     * @allow create: if isSignedIn();
     * @allow get, list: if isSignedIn();
     * @allow update: if isSignedIn() && resource != null;
     * @allow delete: if isSignedIn() && resource != null;
     * @principle Only signed in users can manage customers
     */
    match /customers/{customerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }
}
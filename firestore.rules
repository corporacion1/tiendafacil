/**
 * @fileoverview Firestore Security Rules
 *
 * Core Philosophy:
 * This ruleset prioritizes secure data access by strictly controlling read and write permissions
 * based on the authenticated user. It adopts an owner-based access control model where
 * applicable and requires authentication for most operations.
 *
 * Data Structure:
 * The Firestore database is structured with top-level collections such as 'products', 'taxTypes',
 * 'inventoryMovements', 'sales', 'purchases', 'customers', 'stores', and 'families'.
 * Subcollections like 'saleItems' (under 'sales') and 'purchaseItems' (under 'purchases')
 * further organize the data.
 *
 * Key Security Decisions:
 * - Listing of top-level collections is generally disallowed unless explicitly stated otherwise.
 * - Write access is strictly controlled, typically requiring user authentication and, in some
 *   cases, ownership validation.
 * - The rules do not enforce specific data shapes in this prototyping phase but focus on
 *   authorization.
 * - Currency rates must be accessible to everyone.
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants public read access to currency rates collection.
     * @path /currency_rates
     * @allow (get, list) Any user (or no user) can read currency rates.
     * @deny (create, update, delete) No one can write to currency rates.
     * @principle Allows public read access.
     */
    match /currency_rates {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages access to products.
     * @path /products/{productId}
     * @allow (get) Any authenticated user can read a product.
     * @allow (list) Listing products is allowed for authenticated users.
     * @allow (create) Only authenticated users can create products.
     * @allow (update, delete) Only authenticated users can update or delete products, and they must also be the owner (TODO: Missing ownerId).
     * @deny (create, update, delete) If not authenticated.
     * @principle Enforces authenticated access.
     */
    match /products/{productId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Manages access to tax types.
     * @path /taxTypes/{taxTypeId}
     * @allow (get) Any authenticated user can read a tax type.
     * @allow (list) Listing tax types is allowed for authenticated users.
     * @allow (create) Only authenticated users can create tax types.
     * @allow (update, delete) Only authenticated users can update or delete tax types, and they must also be the owner (TODO: Missing ownerId).
     * @deny (create, update, delete) If not authenticated.
     * @principle Enforces authenticated access.
     */
    match /taxTypes/{taxTypeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Manages access to inventory movements.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (get) Any authenticated user can read a inventoryMovement.
     * @allow (list) Listing inventoryMovements is allowed for authenticated users.
     * @allow (create) Only authenticated users can create inventoryMovements.
     * @allow (update, delete) Only authenticated users can update or delete inventoryMovements, and they must also be the owner (TODO: Missing ownerId).
     * @deny (create, update, delete) If not authenticated.
     * @principle Enforces authenticated access.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Manages access to sales.
     * @path /sales/{saleId}
     * @allow (get) Any authenticated user can read a sale.
     * @allow (list) Listing sales is allowed for authenticated users.
     * @allow (create) Only authenticated users can create sales.
     * @allow (update, delete) Only authenticated users can update or delete sales, and they must also be the owner (TODO: Missing ownerId).
     * @deny (create, update, delete) If not authenticated.
     * @principle Enforces authenticated access.
     */
    match /sales/{saleId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.

      /**
       * @description Manages access to sale items within a sale.
       * @path /sales/{saleId}/saleItems/{saleItemId}
       * @allow (get) Any authenticated user can read a sale item.
       * @allow (list) Listing sale items is allowed for authenticated users.
       * @allow (create) Only authenticated users can create sale items.
       * @allow (update, delete) Only authenticated users can update or delete sale items, and they must also be the owner (TODO: Missing ownerId).
       * @deny (create, update, delete) If not authenticated.
       * @principle Enforces authenticated access.
       */
      match /saleItems/{saleItemId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
        allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      }
    }

    /**
     * @description Manages access to purchases.
     * @path /purchases/{purchaseId}
     * @allow (get) Any authenticated user can read a purchase.
     * @allow (list) Listing purchases is allowed for authenticated users.
     * @allow (create) Only authenticated users can create purchases.
     * @allow (update, delete) Only authenticated users can update or delete purchases, and they must also be the owner (TODO: Missing ownerId).
     * @deny (create, update, delete) If not authenticated.
     * @principle Enforces authenticated access.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.

      /**
       * @description Manages access to purchase items within a purchase.
       * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
       * @allow (get) Any authenticated user can read a purchase item.
       * @allow (list) Listing purchase items is allowed for authenticated users.
       * @allow (create) Only authenticated users can create purchase items.
       * @allow (update, delete) Only authenticated users can update or delete purchase items, and they must also be the owner (TODO: Missing ownerId).
       * @deny (create, update, delete) If not authenticated.
       * @principle Enforces authenticated access.
       */
      match /purchaseItems/{purchaseItemId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
        allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      }
    }

    /**
     * @description Manages access to customers.
     * @path /customers/{customerId}
     * @allow (get) Any authenticated user can read a customer.
     * @allow (list) Listing customers is allowed for authenticated users.
     * @allow (create) Only authenticated users can create customers.
     * @allow (update, delete) Only authenticated users can update or delete customers, and they must also be the owner (TODO: Missing ownerId).
     * @deny (create, update, delete) If not authenticated.
     * @principle Enforces authenticated access.
     */
    match /customers/{customerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

     /**
      * @description Manages access to stores.
      * @path /stores/{storeId}
      * @allow (get) Any authenticated user can read a store.
      * @allow (list) Listing stores is allowed for authenticated users.
      * @allow (create) Only authenticated users can create stores.
      * @allow (update, delete) Only authenticated users can update or delete stores, and they must also be the owner.
      *   The owner is the user whose UID matches the `storeId`.
      * @deny (create, update, delete) If not authenticated.
      * @principle Enforces authenticated access and ownership.
      */
    match /stores/{storeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == storeId;
      allow update: if isSignedIn() && isExistingOwner(storeId);
      allow delete: if isSignedIn() && isExistingOwner(storeId);
    }

    /**
     * @description Manages access to families.
     * @path /families/{familyId}
     * @allow (get) Any authenticated user can read a family.
     * @allow (list) Listing families is allowed for authenticated users.
     * @allow (create) Only authenticated users can create families.
     * @allow (update, delete) Only authenticated users can update or delete families, and they must also be the owner (TODO: Missing ownerId).
     * @deny (create, update, delete) If not authenticated.
     * @principle Enforces authenticated access.
     */
    match /families/{familyId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }
  }

  // Helper function to determine if the user is signed in
  function isSignedIn() {
    return request.auth != null;
  }

  // Helper function to determine if the user is the owner
  function isOwner(userId) {
    return request.auth.uid == userId;
  }

    // Helper function to determine if the user is the owner of existing document
  function isExistingOwner(userId) {
    return isSignedIn() && isOwner(userId) && resource != null;
  }
}
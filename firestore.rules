/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes rapid prototyping by focusing on authorization and skipping data validation.
 * It assumes the application code will handle data validation and integrity.
 * The rules enforce a basic level of security by ensuring only authenticated users can perform write operations.
 *
 * Data Structure:
 * - /products: Publicly readable, but write-protected.
 * - /chats: Publicly readable and writable.
 * - /chats/{chatId}/messages: Publicly readable and writable.
 *
 * Key Security Decisions:
 * - Read access to /products is public.
 * - Read and write access to /chats and /chats/{chatId}/messages are public.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read products, but only authenticated users can create, update, or delete them.
     * @path /products
     * @allow (get, list)
     * @deny (create, update, delete)
     * @principle Allows public read, restricts writes to authenticated users.
     */
    match /products {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows anyone to read and write to chats.
     * @path /chats
     * @allow (get, list, create, update, delete)
     * @principle Allows public read and write access.
     */
    match /chats {
      allow get, list, create, update, delete: if true;
    }

    /**
     * @description Allows anyone to read and write messages in a chat.
     * @path /chats/{chatId}/messages
     * @allow (get, list, create, update, delete)
     * @principle Allows public read and write access.
     */
    match /chats/{chatId}/messages/{messageId} {
      allow get, list, create, update, delete: if true;
    }

    // --- Helper Functions ---

    /**
     * @description Checks if the user is signed in.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }
  }
}
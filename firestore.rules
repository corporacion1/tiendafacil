rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     * @param {string} userId The user ID to compare against the request's auth UID.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the existing owner of the resource.
     * @param {string} userId The user ID to compare against the resource's ownerId.
     * @return {boolean} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
        return isSignedIn() && request.auth.uid == resource.data.ownerId;
    }
    
    /**
     * @description Determines if the user is a store admin for the given store.
     * @param {string} storeId The ID of the store to check.
     * @return {boolean} True if the user is a store admin for the store, false otherwise.
     */
    function isStoreAdmin(storeId) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'storeAdmin' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId == storeId;
    }

    /**
     * @description Determines if the user is a super admin.
     * @return {boolean} True if the user is a super admin, false otherwise.
     */
    function isSuperAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superAdmin';
    }

    /**
     * @description Rules for the /stores collection.
     * @path /stores
     * @allow (create) Signed-in user can create a store if they are the owner.
     * @deny (create) User cannot create a store if they are not signed in or not the owner.
     * @allow (get, list) Anyone can read the store information.
     * @deny (update, delete) Only the owner can update or delete the store.
     * @principle Enforces ownership for store creation and management. Allows public read access.
     */
    match /stores/{storeId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && request.auth.uid == resource.data.ownerId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;
    }

    /**
     * @description Rules for the /stores/{storeId}/products collection.
     * @path /stores/{storeId}/products
     * @allow (create) Store admins can create products in their store.
     * @deny (create) Users who are not store admins cannot create products.
     * @allow (get, list) Anyone can read products in a store.
     * @deny (update, delete) Only store admins can update or delete products.
     * @principle Enforces store admin role for product management within a store. Allows public read access.
     */
    match /stores/{storeId}/products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isStoreAdmin(storeId);
      allow update: if isStoreAdmin(storeId);
      allow delete: if isStoreAdmin(storeId);
    }

    /**
     * @description Rules for the /stores/{storeId}/sales collection.
     * @path /stores/{storeId}/sales
     * @allow (create) Store admins can create sales records in their store.
     * @deny (create) Users who are not store admins cannot create sales records.
     * @allow (get, list) Store admins can list sales records in their store.
     * @deny (update, delete) Only store admins can update or delete sales records.
     * @principle Enforces store admin role for sale management within a store.
     */
    match /stores/{storeId}/sales/{saleId} {
      allow get: if isStoreAdmin(storeId);
      allow list: if isStoreAdmin(storeId);
      allow create: if isStoreAdmin(storeId);
      allow update: if isStoreAdmin(storeId);
      allow delete: if isStoreAdmin(storeId);
    }

    /**
     * @description Rules for the /stores/{storeId}/customers collection.
     * @path /stores/{storeId}/customers
     * @allow (create) Store admins can create customers in their store.
     * @deny (create) Users who are not store admins cannot create customers.
     * @allow (get, list) Store admins can list customers in their store.
     * @deny (update, delete) Only store admins can update or delete customers.
     * @principle Enforces store admin role for customer management within a store.
     */
    match /stores/{storeId}/customers/{customerId} {
      allow get: if isStoreAdmin(storeId);
      allow list: if isStoreAdmin(storeId);
      allow create: if isStoreAdmin(storeId);
      allow update: if isStoreAdmin(storeId);
      allow delete: if isStoreAdmin(storeId);
    }

    /**
     * @description Rules for the /products collection (aggregated, public-facing).
     * @path /products
     * @allow (get, list) Anyone can read the aggregated product list.
     * @deny (create, update, delete) Only a privileged process (e.g., a Firebase Function) can modify this collection.
     * @principle Allows public read access to the aggregated product collection, restricts write access.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // TODO: Implement privileged process for write access
      allow update: if false; // TODO: Implement privileged process for write access
      allow delete: if false; // TODO: Implement privileged process for write access
    }

    /**
     * @description Rules for the /users collection (user profiles).
     * @path /users
     * @allow (create) A user can create their own profile (self-creation).
     * @deny (create) A user cannot create a profile for another user.
     * @allow (get) A user can read their own profile.
     * @deny (list) Listing all users is not allowed.
     * @allow (update) A user can update their own profile.
     * @deny (delete) A user cannot delete their profile.
     * @principle Enforces user ownership for profile management.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    /**
     * @description Rules for the /chats collection.
     * @path /chats
     * @allow (get, list) Anyone can read the chat information.
     * @allow (create) Any signed in user can create a chat.
     * @deny (update, delete) Chats cannot be updated or deleted.
     */
    match /chats/{chatId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn();
        allow update: if false;
        allow delete: if false;
    }

    /**
     * @description Rules for the /chats/{chatId}/messages collection.
     * @path /chats/{chatId}/messages
     * @allow (get, list) Anyone can read the messages in a chat.
     * @allow (create) Any signed in user can create a message in a chat.
     * @deny (update, delete) Messages cannot be updated or deleted.
     */
    match /chats/{chatId}/messages/{messageId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn();
        allow update: if false;
        allow delete: if false;
    }
    
    /**
     * @description Rules for the /inventoryMovements collection.  This collection was the source of the error.
     * @path /inventoryMovements
     * @deny (get, list, create, update, delete) No one can access this collection.
     * @principle Explicitly denies all access until the data model and access patterns are defined.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
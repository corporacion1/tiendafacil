/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a multi-tenant security model where data is segregated by store.
 *   Each store is owned by a specific user, and only that user has full access to the store's data.
 *
 * @data_structure
 *   - Users: /users/{userId} - Global user profiles.
 *   - Stores: /stores/{storeId} - Root collection for all tenant stores. Each store document has an `ownerId` field.
 *   - Store Subcollections: /stores/{storeId}/products/{productId}, etc. - Data specific to a store.
 *
 * @key_security_decisions
 *   - Strict User Ownership: Only the owner of a store can create, update, or delete store-related data.
 *   - No User Listing: Listing of users is explicitly denied.
 *   - Public Read for Stores: Listing of store data is currently allowed. Consider restricting this in the future.
 *   - Data Denormalization: The `ownerId` is denormalized onto the Store document for efficient ownership checks.
 *
 * @denormalization_for_authorization
 *   - The `Store` document contains an `ownerId` field, which is essential for authorization. This avoids the need for complex queries or additional reads to determine ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the current user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the current user is the owner of the resource, using the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the current user is the owner of an existing resource.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Global user profiles.
     * @path /users/{userId}
     * @allow (create) - User with UID 'user123' can create a profile at /users/user123
     * @deny (create) - User with UID 'user123' cannot create a profile at /users/user456
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Root collection for all tenant stores.
     * @path /stores/{storeId}
     * @allow (create) - User with UID 'user123' can create a store at /stores/store1 with ownerId 'user123'
     * @deny (create) - User with UID 'user123' cannot create a store at /stores/store1 with ownerId 'user456'
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.ownerId);
      allow delete: if isExistingOwner(resource.data.ownerId);
    }

    /**
     * @description Products for a specific store.
     * @path /stores/{storeId}/products/{productId}
     * @allow (create) - User with UID 'user123' can create a product in store 'store1' if they own the store.
     * @deny (create) - User with UID 'user456' cannot create a product in store 'store1' if they do not own the store.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId}/products/{productId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }

     /**
      * @description Units of measure for a specific store.
      * @path /stores/{storeId}/units/{unitId}
      * @allow (create) - User with UID 'user123' can create a unit in store 'store1' if they own the store.
      * @deny (create) - User with UID 'user456' cannot create a unit in store 'store1' if they do not own the store.
      * @principle Enforces document ownership for writes.
      */
    match /stores/{storeId}/units/{unitId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Product families for a specific store.
     * @path /stores/{storeId}/families/{familyId}
     * @allow (create) - User with UID 'user123' can create a family in store 'store1' if they own the store.
     * @deny (create) - User with UID 'user456' cannot create a family in store 'store1' if they do not own the store.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId}/families/{familyId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Warehouses for a specific store.
     * @path /stores/{storeId}/warehouses/{warehouseId}
     * @allow (create) - User with UID 'user123' can create a warehouse in store 'store1' if they own the store.
     * @deny (create) - User with UID 'user456' cannot create a warehouse in store 'store1' if they do not own the store.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId}/warehouses/{warehouseId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Tax types for a specific store.
     * @path /stores/{storeId}/tax_types/{taxTypeId}
     * @allow (create) - User with UID 'user123' can create a tax type in store 'store1' if they own the store.
     * @deny (create) - User with UID 'user456' cannot create a tax type in store 'store1' if they do not own the store.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId}/tax_types/{taxTypeId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Inventory movements for a specific store.
     * @path /stores/{storeId}/inventory_movements/{inventoryMovementId}
     * @allow (create) - User with UID 'user123' can create an inventory movement in store 'store1' if they own the store.
     * @deny (create) - User with UID 'user456' cannot create an inventory movement in store 'store1' if they do not own the store.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId}/inventory_movements/{inventoryMovementId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Sales records for a specific store.
     * @path /stores/{storeId}/sales/{saleId}
     * @allow (create) - User with UID 'user123' can create a sale in store 'store1' if they own the store.
     * @deny (create) - User with UID 'user456' cannot create a sale in store 'store1' if they do not own the store.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId}/sales/{saleId} {
      allow get: if true;
      allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Items within a sale for a specific store.
     * @path /stores/{storeId}/sales/{saleId}/sale_items/{saleItemId}
     * @allow (create) - User with UID 'user123' can create a sale item in store 'store1' if they own the store.
     * @deny (create) - User with UID 'user456' cannot create a sale item in store 'store1' if they do not own the store.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId}/sales/{saleId}/sale_items/{saleItemId} {
      allow get: if true;
      allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Purchase records for a specific store.
     * @path /stores/{storeId}/purchases/{purchaseId}
     * @allow (create) - User with UID 'user123' can create a purchase in store 'store1' if they own the store.
     * @deny (create) - User with UID 'user456' cannot create a purchase in store 'store1' if they do not own the store.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId}/purchases/{purchaseId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Items within a purchase for a specific store.
     * @path /stores/{storeId}/purchases/{purchaseId}/purchase_items/{purchaseItemId}
     * @allow (create) - User with UID 'user123' can create a purchase item in store 'store1' if they own the store.
     * @deny (create) - User with UID 'user456' cannot create a purchase item in store 'store1' if they do not own the store.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId}/purchases/{purchaseId}/purchase_items/{purchaseItemId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Suppliers for a specific store.
     * @path /stores/{storeId}/suppliers/{supplierId}
     * @allow (create) - User with UID 'user123' can create a supplier in store 'store1' if they own the store.
     * @deny (create) - User with UID 'user456' cannot create a supplier in store 'store1' if they do not own the store.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId}/suppliers/{supplierId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Customers for a specific store.
     * @path /stores/{storeId}/customers/{customerId}
     * @allow (create) - User with UID 'user123' can create a customer in store 'store1' if they own the store.
     * @deny (create) - User with UID 'user456' cannot create a customer in store 'store1' if they do not own the store.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId}/customers/{customerId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Currency exchange rates for a specific store.
     * @path /stores/{storeId}/currency_rates/{currencyRateId}
     * @allow (create) - User with UID 'user123' can create a currency rate in store 'store1' if they own the store.
     * @deny (create) - User with UID 'user456' cannot create a currency rate in store 'store1' if they do not own the store.
     * @principle Enforces document ownership for writes.
     */
    match /stores/{storeId}/currency_rates/{currencyRateId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Chat conversations for a specific store.
     * @path /stores/{storeId}/chats/{chatId}
     */
    match /stores/{storeId}/chats/{chatId} {
        allow get: if isSignedIn() && request.auth.uid in resource.data.participants;
        allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
        allow update: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
        allow delete: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid && resource != null;
    }

    /**
     * @description Messages within a chat for a specific store.
     * @path /stores/{storeId}/chats/{chatId}/messages/{messageId}
     */
    match /stores/{storeId}/chats/{chatId}/messages/{messageId} {
        allow get: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
        allow list: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
        allow create: if isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
        allow update: if false;
        allow delete: if isSignedIn() && request.auth.uid == resource.data.senderId;
    }
  }
}
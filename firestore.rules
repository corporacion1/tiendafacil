/**
 * @fileoverview Firestore Security Rules for the inventory and point-of-sale system.
 *
 * Core Philosophy:
 * This ruleset provides basic protection against unauthorized data access and modification.
 * In the absence of more specific requirements, it defaults to disallowing all access,
 * forcing the developer to explicitly enable the necessary permissions.
 *
 * Data Structure:
 * The Firestore database is structured with top-level collections for entities
 * like products, inventory movements, sales, purchases, customers, suppliers, tax types, and configuration.
 * Subcollections are used to represent one-to-many relationships (e.g., saleItems under a sale document).
 *
 * Key Security Decisions:
 * - All write operations are initially denied and must be explicitly allowed.
 * - Read operations are initially denied and must be explicitly allowed.
 * - List operations are only allowed if specifically required and deemed safe.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the products collection.
     * @path /products/{productId}
     * @allow get, list: if true;
     * @allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
     * @allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
     * @allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
     * @principle Public read, owner-only writes.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Controls access to the inventoryMovements collection.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow get, list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Strict deny-by-default.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to the sales collection.
     * @path /sales/{saleId}
     * @allow get, list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Strict deny-by-default.
     */
    match /sales/{saleId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to the saleItems subcollection under a sale document.
     * @path /sales/{saleId}/saleItems/{saleItemId}
     * @allow get, list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Strict deny-by-default.
     */
    match /sales/{saleId}/saleItems/{saleItemId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to the purchases collection.
     * @path /purchases/{purchaseId}
     * @allow get, list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Strict deny-by-default.
     */
    match /purchases/{purchaseId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to the purchaseItems subcollection under a purchase document.
     * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     * @allow get, list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Strict deny-by-default.
     */
    match /purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to the customers collection.
     * @path /customers/{customerId}
     * @allow get, list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Strict deny-by-default.
     */
    match /customers/{customerId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to the suppliers collection.
     * @path /suppliers/{supplierId}
     * @allow get, list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Strict deny-by-default.
     */
    match /suppliers/{supplierId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to the taxTypes collection.
     * @path /taxTypes/{taxTypeId}
     * @allow get, list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Strict deny-by-default.
     */
    match /taxTypes/{taxTypeId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to the configuration collection.
     * @path /configuration/{configurationId}
     * @allow get, list: if false;
     * @allow create: if false;
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Strict deny-by-default.
     */
    match /configuration/{configurationId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

  }
}
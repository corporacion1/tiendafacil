/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a store-ownership model, where each document belongs to a specific store.
 * All data is stored in top-level collections (e.g., /products, /sales), and access is controlled based on the 'storeId' field within each document.
 *
 * Key Security Decisions:
 * - Users cannot list other users.
 * - Data types and schema are NOT validated in this prototyping phase for most fields.
 * - All write operations are restricted to authenticated users and validated against the 'storeId'.
 * - Read operations on top level collections are public.
 *
 * Denormalization for Authorization:
 * The 'storeId' field is crucial for authorization.  It is used to ensure that only members of a given 'storeId' can modify data related to that store. This avoids the need for complex lookups.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows read access to public user profiles.
     * @path /users/{userId}
     * @allow (get, list) Any authenticated user can read the user profile.
     * @deny (create, update, delete) No one can create, update or delete a user via the public profile. This must be done via auth.
     * @principle Public read access for user profiles.
     */
    match /users/{userId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Grants read access to stores, and denies write access, acting as read-only settings.
     * @path /stores/{storeId}
     * @allow (get, list) Any authenticated user can read store settings.
     * @deny (create, update, delete) No one can modify store settings.
     * @principle Read-only access for store settings.
     */
    match /stores/{storeId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access and store-ownership based writes for products.
     * @path /products/{productId}
     * @allow (get, list) Any user can read any product.
     * @allow (create) An authenticated user can create a product if the storeId matches.
     * @allow (update, delete) An authenticated user can update/delete a product if they own it (storeId matches).
     * @deny (create) If the storeId in the request does not match the authenticated user's store.
     * @deny (update, delete) If the storeId in the request does not match the existing product's storeId.
     * @principle Public read, store-owned writes.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    /**
     * @description Allows public read access and store-ownership based writes for sales.
     * @path /sales/{saleId}
     * @allow (get, list) Any user can read any sale.
     * @allow (create) An authenticated user can create a sale if the storeId matches.
     * @allow (update, delete) An authenticated user can update/delete a sale if they own it (storeId matches).
     * @deny (create) If the storeId in the request does not match the authenticated user's store.
     * @deny (update, delete) If the storeId in the request does not match the existing sale's storeId.
     * @principle Public read, store-owned writes.
     */
    match /sales/{saleId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    /**
     * @description Allows public read access and store-ownership based writes for purchases.
     * @path /purchases/{purchaseId}
     * @allow (get, list) Any user can read any purchase.
     * @allow (create) An authenticated user can create a purchase if the storeId matches.
     * @allow (update, delete) An authenticated user can update/delete a purchase if they own it (storeId matches).
     * @deny (create) If the storeId in the request does not match the authenticated user's store.
     * @deny (update, delete) If the storeId in the request does not match the existing purchase's storeId.
     * @principle Public read, store-owned writes.
     */
    match /purchases/{purchaseId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    /**
     * @description Allows public read access and store-ownership based writes for customers.
     * @path /customers/{customerId}
     * @allow (get, list) Any user can read any customer.
     * @allow (create) An authenticated user can create a customer if the storeId matches.
     * @allow (update, delete) An authenticated user can update/delete a customer if they own it (storeId matches).
     * @deny (create) If the storeId in the request does not match the authenticated user's store.
     * @deny (update, delete) If the storeId in the request does not match the existing customer's storeId.
     * @principle Public read, store-owned writes.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    /**
     * @description Allows public read access and store-ownership based writes for suppliers.
     * @path /suppliers/{supplierId}
     * @allow (get, list) Any user can read any supplier.
     * @allow (create) An authenticated user can create a supplier if the storeId matches.
     * @allow (update, delete) An authenticated user can update/delete a supplier if they own it (storeId matches).
     * @deny (create) If the storeId in the request does not match the authenticated user's store.
     * @deny (update, delete) If the storeId in the request does not match the existing supplier's storeId.
     * @principle Public read, store-owned writes.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    /**
     * @description Allows public read access and store-ownership based writes for units.
     * @path /units/{unitId}
     * @allow (get, list) Any user can read any unit.
     * @allow (create) An authenticated user can create a unit if the storeId matches.
     * @allow (update, delete) An authenticated user can update/delete a unit if they own it (storeId matches).
     * @deny (create) If the storeId in the request does not match the authenticated user's store.
     * @deny (update, delete) If the storeId in the request does not match the existing unit's storeId.
     * @principle Public read, store-owned writes.
     */
    match /units/{unitId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    /**
     * @description Allows public read access and store-ownership based writes for families.
     * @path /families/{familyId}
     * @allow (get, list) Any user can read any family.
     * @allow (create) An authenticated user can create a family if the storeId matches.
     * @allow (update, delete) An authenticated user can update/delete a family if they own it (storeId matches).
     * @deny (create) If the storeId in the request does not match the authenticated user's store.
     * @deny (update, delete) If the storeId in the request does not match the existing family's storeId.
     * @principle Public read, store-owned writes.
     */
    match /families/{familyId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    /**
     * @description Allows public read access and store-ownership based writes for warehouses.
     * @path /warehouses/{warehouseId}
     * @allow (get, list) Any user can read any warehouse.
     * @allow (create) An authenticated user can create a warehouse if the storeId matches.
     * @allow (update, delete) An authenticated user can update/delete a warehouse if they own it (storeId matches).
     * @deny (create) If the storeId in the request does not match the authenticated user's store.
     * @deny (update, delete) If the storeId in the request does not match the existing warehouse's storeId.
     * @principle Public read, store-owned writes.
     */
    match /warehouses/{warehouseId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.storeId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.storeId == request.auth.uid;
    }

    /**
     * @description Allows public read access for ads.
     * @path /ads/{adId}
     * @allow (get, list) Any user can read any ad.
     * @deny (create, update, delete) No one can create, update or delete any ad.
     * @principle Public read access for ads.
     */
    match /ads/{adId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access for cashSessions.
     * @path /cashSessions/{cashSessionId}
     * @allow (get, list) Any user can read any cashSession.
     * @deny (create, update, delete) No one can create, update or delete any cashSession.
     * @principle Public read access for cashSessions.
     */
    match /cashSessions/{cashSessionId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }


    function isSignedIn() {
      return request.auth != null;
    }
  }
}
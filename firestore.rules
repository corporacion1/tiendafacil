/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict store-ownership model, ensuring that only authenticated users can access data and only for their specific store.
 * All data is organized under top-level collections such as /products, /taxTypes, etc. Each document within these collections must contain a 'storeId' field
 * that matches the {storeId} in the document path.
 *
 * Key Security Decisions:
 * - All collections are store-scoped.
 * - Listing collections is denied to prevent data enumeration.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the store.
     * @param {string} storeId - The store ID to check against the request.
     * @return {boolean} True if the user is signed in and the storeId matches, false otherwise.
     */
    function isStoreOwner(storeId) {
        return isSignedIn() && request.auth.uid == storeId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the store for existing data
     * @param {string} storeId - The store ID to check against the request.
     * @return {boolean} True if the user is signed in and the storeId matches, false otherwise.
     */
    function isExistingStoreOwner(storeId) {
      return isStoreOwner(storeId) && resource != null;
    }

    /**
     * @description Enforces store-level ownership for Products.
     * @path /products/{productId}
     * @allow (create) - An authenticated user can create a product if the storeId matches their UID.
     * @allow (update) - An authenticated user can update a product if they own the store.
     * @allow (delete) - An authenticated user can delete a product if they own the store.
     * @deny  (create) - An unauthenticated user cannot create a product.
     * @deny  (create) - An authenticated user cannot create a product with a mismatched storeId.
     * @deny  (update) - An unauthenticated user cannot update a product.
     * @deny  (update) - An authenticated user cannot update a product they don't own.
     * @deny  (delete) - An unauthenticated user cannot delete a product.
     * @deny  (delete) - An authenticated user cannot delete a product they don't own.
     * @principle Enforces store ownership for writes; requires authentication for all operations.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId) && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Enforces store-level ownership for TaxTypes.
     * @path /taxTypes/{taxTypeId}
     * @allow (create) - An authenticated user can create a tax type if the storeId matches their UID.
     * @allow (update) - An authenticated user can update a tax type if they own the store.
     * @allow (delete) - An authenticated user can delete a tax type if they own the store.
     * @deny  (create) - An unauthenticated user cannot create a tax type.
     * @deny  (create) - An authenticated user cannot create a tax type with a mismatched storeId.
     * @deny  (update) - An unauthenticated user cannot update a tax type.
     * @deny  (update) - An authenticated user cannot update a tax type they don't own.
     * @deny  (delete) - An unauthenticated user cannot delete a tax type.
     * @deny  (delete) - An authenticated user cannot delete a tax type they don't own.
     * @principle Enforces store ownership for writes; requires authentication for all operations.
     */
    match /taxTypes/{taxTypeId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId) && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Enforces store-level ownership for InventoryMovements.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (create) - An authenticated user can create an inventory movement if the storeId matches their UID.
     * @allow (update) - An authenticated user can update an inventory movement if they own the store.
     * @allow (delete) - An authenticated user can delete an inventory movement if they own the store.
     * @deny  (create) - An unauthenticated user cannot create an inventory movement.
     * @deny  (create) - An authenticated user cannot create an inventory movement with a mismatched storeId.
     * @deny  (update) - An unauthenticated user cannot update an inventory movement.
     * @deny  (update) - An authenticated user cannot update an inventory movement they don't own.
     * @deny  (delete) - An unauthenticated user cannot delete an inventory movement.
     * @deny  (delete) - An authenticated user cannot delete an inventory movement they don't own.
     * @principle Enforces store ownership for writes; requires authentication for all operations.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId) && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

    /**
     * @description Enforces store-level ownership for Sales.
     * @path /sales/{saleId}
     * @allow (create) - An authenticated user can create a sale if the storeId matches their UID.
     * @allow (update) - An authenticated user can update a sale if they own the store.
     * @allow (delete) - An authenticated user can delete a sale if they own the store.
     * @deny  (create) - An unauthenticated user cannot create a sale.
     * @deny  (create) - An authenticated user cannot create a sale with a mismatched storeId.
     * @deny  (update) - An unauthenticated user cannot update a sale.
     * @deny  (update) - An authenticated user cannot update a sale they don't own.
     * @deny  (delete) - An unauthenticated user cannot delete a sale.
     * @deny  (delete) - An authenticated user cannot delete a sale they don't own.
     * @principle Enforces store ownership for writes; requires authentication for all operations.
     */
    match /sales/{saleId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId) && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isExistingStoreOwner(resource.data.storeId);

      /**
       * @description Enforces store-level ownership for SaleItems subcollection.
       * @path /sales/{saleId}/saleItems/{saleItemId}
       */
      match /saleItems/{saleItemId} {
        allow get: if true;
        allow list: if false;
        allow create: if isSignedIn() && get(/databases/$(database)/documents/sales/$(saleId)).data.storeId == request.auth.uid;
        allow update: if isExistingStoreOwner(get(/databases/$(database)/documents/sales/$(saleId)).data.storeId) && get(/databases/$(database)/documents/sales/$(saleId)).data.storeId == resource.data.storeId;
        allow delete: if isExistingStoreOwner(get(/databases/$(database)/documents/sales/$(saleId)).data.storeId);
      }
    }

    /**
     * @description Enforces store-level ownership for Purchases.
     * @path /purchases/{purchaseId}
     * @allow (create) - An authenticated user can create a purchase if the storeId matches their UID.
     * @allow (update) - An authenticated user can update a purchase if they own the store.
     * @allow (delete) - An authenticated user can delete a purchase if they own the store.
     * @deny  (create) - An unauthenticated user cannot create a purchase.
     * @deny  (create) - An authenticated user cannot create a purchase with a mismatched storeId.
     * @deny  (update) - An unauthenticated user cannot update a purchase.
     * @deny  (update) - An authenticated user cannot update a purchase they don't own.
     * @deny  (delete) - An unauthenticated user cannot delete a purchase.
     * @deny  (delete) - An authenticated user cannot delete a purchase they don't own.
     * @principle Enforces store ownership for writes; requires authentication for all operations.
     */
    match /purchases/{purchaseId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId) && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isExistingStoreOwner(resource.data.storeId);

      /**
       * @description Enforces store-level ownership for PurchaseItems subcollection.
       * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
       */
      match /purchaseItems/{purchaseItemId} {
        allow get: if true;
        allow list: if false;
        allow create: if isSignedIn() && get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId == request.auth.uid;
        allow update: if isExistingStoreOwner(get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId) && get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId == resource.data.storeId;
        allow delete: if isExistingStoreOwner(get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId);
      }
    }

    /**
     * @description Enforces store-level ownership for Customers.
     * @path /customers/{customerId}
     * @allow (create) - An authenticated user can create a customer if the storeId matches their UID.
     * @allow (update) - An authenticated user can update a customer if they own the store.
     * @allow (delete) - An authenticated user can delete a customer if they own the store.
     * @deny  (create) - An unauthenticated user cannot create a customer.
     * @deny  (create) - An authenticated user cannot create a customer with a mismatched storeId.
     * @deny  (update) - An unauthenticated user cannot update a customer.
     * @deny  (update) - An authenticated user cannot update a customer they don't own.
     * @deny  (delete) - An unauthenticated user cannot delete a customer.
     * @deny  (delete) - An authenticated user cannot delete a customer they don't own.
     * @principle Enforces store ownership for writes; requires authentication for all operations.
     */
    match /customers/{customerId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId) && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }

     /**
      * @description Enforces store-level ownership for StoreConfiguration.
      * @path /stores/{storeId}
      * @allow (create) - An authenticated user can create a store configuration if their UID matches the storeId.
      * @allow (update) - An authenticated user can update their own store configuration.
      * @allow (delete) - An authenticated user can delete their own store configuration.
      * @deny  (create) - An unauthenticated user cannot create a store configuration.
      * @deny  (create) - An authenticated user cannot create a store configuration with a mismatched storeId.
      * @deny  (update) - An unauthenticated user cannot update a store configuration.
      * @deny  (update) - An authenticated user cannot update a store configuration they don't own.
      * @deny  (delete) - An unauthenticated user cannot delete a store configuration.
      * @deny  (delete) - An authenticated user cannot delete a store configuration they don't own.
      * @principle Enforces store ownership for writes and requires authentication for all operations.
      */
    match /stores/{storeId} {
      allow get: if true;
      allow list: if false;
      allow create: if isStoreOwner(storeId);
      allow update: if isExistingStoreOwner(storeId);
      allow delete: if isExistingStoreOwner(storeId);
    }

    /**
     * @description Enforces store-level ownership for Families.
     * @path /families/{familyId}
     * @allow (create) - An authenticated user can create a family if the storeId matches their UID.
     * @allow (update) - An authenticated user can update a family if they own the store.
     * @allow (delete) - An authenticated user can delete a family if they own the store.
     * @deny  (create) - An unauthenticated user cannot create a family.
     * @deny  (create) - An authenticated user cannot create a family with a mismatched storeId.
     * @deny  (update) - An unauthenticated user cannot update a family.
     * @deny  (update) - An authenticated user cannot update a family they don't own.
     * @deny  (delete) - An unauthenticated user cannot delete a family.
     * @deny  (delete) - An authenticated user cannot delete a family they don't own.
     * @principle Enforces store ownership for writes; requires authentication for all operations.
     */
    match /families/{familyId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.storeId == request.auth.uid;
      allow update: if isExistingStoreOwner(resource.data.storeId) && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isExistingStoreOwner(resource.data.storeId);
    }
  }
}
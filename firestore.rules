/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset is in prototyping mode, prioritizing rapid development and iteration speed.
 * It enforces a basic level of authentication, but intentionally relaxes data validation
 * to allow for flexible schema changes. The primary focus is preventing unauthorized
 * access to data, not ensuring data integrity.
 *
 * Data Structure:
 * The Firestore database consists of several top-level collections: products, taxTypes,
 * inventoryMovements, sales, purchases, customers, stores, and families.
 * Subcollections exist under sales (saleItems) and purchases (purchaseItems).
 *
 * Key Security Decisions:
 * - All read and write access requires authentication.
 * - No data validation is performed beyond ownership checks where applicable.
 * - List operations are generally allowed, which may expose data.
 *
 * Authorization notes:
 * In this version, all collections will be readable by any logged in user.
 * Write access has not been granted as this is a READ error.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Allows any signed-in user to read products. Write access is denied.
     * @path /products/{productId}
     * @allow (get, list) Signed-in user reading a product.
     * @deny (create, update, delete) Any user attempting to write (create, update, delete) a product.
     * @principle Requires user to be signed in for read access.
     */
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Allows any signed-in user to read tax types. Write access is denied.
     * @path /taxTypes/{taxTypeId}
     * @allow (get, list) Signed-in user reading a tax type.
     * @deny (create, update, delete) Any user attempting to write (create, update, delete) a tax type.
     * @principle Requires user to be signed in for read access.
     */
    match /taxTypes/{taxTypeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Allows any signed-in user to read inventory movements. Write access is denied.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (get, list) Signed-in user reading an inventory movement.
     * @deny (create, update, delete) Any user attempting to write (create, update, delete) an inventory movement.
     * @principle Requires user to be signed in for read access.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Allows any signed-in user to read sales. Write access is denied.
     * @path /sales/{saleId}
     * @allow (get, list) Signed-in user reading a sale.
     * @deny (create, update, delete) Any user attempting to write (create, update, delete) a sale.
     * @principle Requires user to be signed in for read access.
     */
    match /sales/{saleId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Allows any signed-in user to read sale items. Write access is denied.
     * @path /sales/{saleId}/saleItems/{saleItemId}
     * @allow (get, list) Signed-in user reading a sale item.
     * @deny (create, update, delete) Any user attempting to write (create, update, delete) a sale item.
     * @principle Requires user to be signed in for read access.
     */
    match /sales/{saleId}/saleItems/{saleItemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Allows any signed-in user to read purchases. Write access is denied.
     * @path /purchases/{purchaseId}
     * @allow (get, list) Signed-in user reading a purchase.
     * @deny (create, update, delete) Any user attempting to write (create, update, delete) a purchase.
     * @principle Requires user to be signed in for read access.
     */
    match /purchases/{purchaseId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Allows any signed-in user to read purchase items. Write access is denied.
     * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     * @allow (get, list) Signed-in user reading a purchase item.
     * @deny (create, update, delete) Any user attempting to write (create, update, delete) a purchase item.
     * @principle Requires user to be signed in for read access.
     */
    match /purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Allows any signed-in user to read customers. Write access is denied.
     * @path /customers/{customerId}
     * @allow (get, list) Signed-in user reading a customer.
     * @deny (create, update, delete) Any user attempting to write (create, update, delete) a customer.
     * @principle Requires user to be signed in for read access.
     */
    match /customers/{customerId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

     /**
      * @description Allows any signed-in user to read store configurations. Write access is denied.
      * @path /stores/{storeId}
      * @allow (get, list) Signed-in user reading a store configuration.
      * @deny (create, update, delete) Any user attempting to write (create, update, delete) a store configuration.
      * @principle Requires user to be signed in for read access.
      */
    match /stores/{storeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Allows any signed-in user to read families. Write access is denied.
     * @path /families/{familyId}
     * @allow (get, list) Signed-in user reading a family.
     * @deny (create, update, delete) Any user attempting to write (create, update, delete) a family.
     * @principle Requires user to be signed in for read access.
     */
    match /families/{familyId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}
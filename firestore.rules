/**
 * @fileoverview Firestore Security Rules for the inventory and point-of-sale system.
 *
 * Core Philosophy:
 * This ruleset provides basic read access to all documents, but it strictly restricts write access to prevent unauthorized data modification.
 * Write operations are generally disallowed to ensure data integrity and prevent accidental or malicious modifications.
 *
 * Data Structure:
 * The Firestore database is structured as a flat collection of top-level collections, such as `products`, `inventoryMovements`, `sales`, `purchases`, `customers`, `suppliers`, `taxTypes`, and `configuration`.
 * Subcollections are used for `saleItems` (under `sales`) and `purchaseItems` (under `purchases`).
 *
 * Key Security Decisions:
 * - Global read access to all collections for prototyping.
 * - All write operations are initially denied. The application must be updated with owner fields to properly protect write access using the "Public Read with Owner-Only Writes" pattern.
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows reading product information, but disallows creating, updating, or deleting products.
     * @path /products/{productId}
     * @allow get, list: if true;
     * @deny create, update, delete: if false;
     * @principle Allows public read access for products but restricts write access.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows reading inventory movement records, but disallows creating, updating, or deleting records.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow get, list: if true;
     * @deny create, update, delete: if false;
     * @principle Allows public read access for inventory movements but restricts write access.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows reading sales transactions, but disallows creating, updating, or deleting sales.
     * @path /sales/{saleId}
     * @allow get, list: if true;
     * @deny create, update, delete: if false;
     * @principle Allows public read access for sales but restricts write access.
     */
    match /sales/{saleId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;

      /**
       * @description Allows reading sale items, but disallows creating, updating, or deleting sale items.
       * @path /sales/{saleId}/saleItems/{saleItemId}
       * @allow get, list: if true;
       * @deny create, update, delete: if false;
       * @principle Allows public read access for sale items but restricts write access.
       */
      match /saleItems/{saleItemId} {
        allow get, list: if true;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }

    /**
     * @description Allows reading purchase transactions, but disallows creating, updating, or deleting purchases.
     * @path /purchases/{purchaseId}
     * @allow get, list: if true;
     * @deny create, update, delete: if false;
     * @principle Allows public read access for purchases but restricts write access.
     */
    match /purchases/{purchaseId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;

      /**
       * @description Allows reading purchase items, but disallows creating, updating, or deleting purchase items.
       * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
       * @allow get, list: if true;
       * @deny create, update, delete: if false;
       * @principle Allows public read access for purchase items but restricts write access.
       */
      match /purchaseItems/{purchaseItemId} {
        allow get, list: if true;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }

    /**
     * @description Allows reading customer information, but disallows creating, updating, or deleting customers.
     * @path /customers/{customerId}
     * @allow get, list: if true;
     * @deny create, update, delete: if false;
     * @principle Allows public read access for customers but restricts write access.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows reading supplier information, but disallows creating, updating, or deleting suppliers.
     * @path /suppliers/{supplierId}
     * @allow get, list: if true;
     * @deny create, update, delete: if false;
     * @principle Allows public read access for suppliers but restricts write access.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows reading tax type information, but disallows creating, updating, or deleting tax types.
     * @path /taxTypes/{taxTypeId}
     * @allow get, list: if true;
     * @deny create, update, delete: if false;
     * @principle Allows public read access for tax types but restricts write access.
     */
    match /taxTypes/{taxTypeId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows reading business configuration data, but disallows creating, updating, or deleting configuration.
     * @path /configuration/{configurationId}
     * @allow get, list: if true;
     * @deny create, update, delete: if false;
     * @principle Allows public read access for configuration but restricts write access.
     */
    match /configuration/{configurationId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
/**
 * @file Overview
 *
 * Core Philosophy:
 * This ruleset enforces a strict store-ownership model. Each document belongs to a specific store,
 * and only authenticated users can access or modify data within that store.
 *
 * Data Structure:
 * Data is organized into top-level collections like `/products`, `/taxTypes`, `/inventoryMovements`,
 * `/sales`, `/purchases`, `/customers`, `/stores`, and `/families`.  Each document within these
 * collections (and their subcollections) MUST have a `storeId` field that links it to a specific store.
 *
 * Key Security Decisions:
 * - All write operations are restricted to authenticated users.
 * - Data access is generally restricted to the store to which the user belongs.  This requires the
 *   `storeId` field to be present and correctly set on all documents.
 * - The `/stores` collection is intended for store configuration, and write access should be very
 *   limited to authorized store personnel.
 * - Listing of documents is generally allowed for authenticated users within their store.
 *
 * Denormalization for Authorization:
 * To avoid costly `get()` operations, the `storeId` is denormalized onto every document. This allows
 * rules to quickly check if the authenticated user has access to the relevant store without needing
 * to perform additional reads.
 *
 * Structural Segregation:
 * This ruleset assumes all data within a store is considered private to that store. There is no
 * concept of public vs. private data. Therefore, a single collection is used for each entity, and
 * access is controlled by the `storeId`.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Products can be listed by authenticated users. Products can be created, updated, or deleted only by authenticated users for a specific store.
     * @path /products/{productId}
     * @allow (list) Authenticated user can list the products.
     * @allow (create) Authenticated user can create a product with the correct storeId.
     * @deny (create) Unauthenticated user cannot create a product.
     * @deny (update) Authenticated user cannot update a product if the storeId does not match.
     * @deny (delete) Unauthenticated user cannot delete a product.
     * @principle Enforces store-ownership for writes.
     */
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
    }

    /**
     * @description Tax types can be listed by authenticated users. Tax types can be created, updated, or deleted only by authenticated users for a specific store.
     * @path /taxTypes/{taxTypeId}
     * @allow (list) Authenticated user can list the tax types.
     * @allow (create) Authenticated user can create a tax type with the correct storeId.
     * @deny (create) Unauthenticated user cannot create a tax type.
     * @deny (update) Authenticated user cannot update a tax type if the storeId does not match.
     * @deny (delete) Unauthenticated user cannot delete a tax type.
     * @principle Enforces store-ownership for writes.
     */
    match /taxTypes/{taxTypeId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
    }

    /**
     * @description Inventory movements can be listed by authenticated users. Inventory movements can be created, updated, or deleted only by authenticated users for a specific store.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (list) Authenticated user can list the inventory movements.
     * @allow (create) Authenticated user can create an inventory movement with the correct storeId.
     * @deny (create) Unauthenticated user cannot create an inventory movement.
     * @deny (update) Authenticated user cannot update an inventory movement if the storeId does not match.
     * @deny (delete) Unauthenticated user cannot delete an inventory movement.
     * @principle Enforces store-ownership for writes.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
    }

    /**
     * @description Sales can be listed by authenticated users. Sales can be created, updated, or deleted only by authenticated users for a specific store.
     * @path /sales/{saleId}
     * @allow (list) Authenticated user can list the sales.
     * @allow (create) Authenticated user can create a sale with the correct storeId.
     * @deny (create) Unauthenticated user cannot create a sale.
     * @deny (update) Authenticated user cannot update a sale if the storeId does not match.
     * @deny (delete) Unauthenticated user cannot delete a sale.
     * @principle Enforces store-ownership for writes.
     */
    match /sales/{saleId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();

      /**
       * @description Sale items can be listed by authenticated users. Sale items can be created, updated, or deleted only by authenticated users for a specific store.
       * @path /sales/{saleId}/saleItems/{saleItemId}
       * @allow (list) Authenticated user can list the sale items.
       * @allow (create) Authenticated user can create a sale item with the correct storeId.
       * @deny (create) Unauthenticated user cannot create a sale item.
       * @deny (update) Authenticated user cannot update a sale item if the storeId does not match.
       * @deny (delete) Unauthenticated user cannot delete a sale item.
       * @principle Enforces store-ownership for writes.
       */
      match /saleItems/{saleItemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
        allow update: if isSignedIn() && resource.data.storeId == getStoreId();
        allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
      }
    }

    /**
     * @description Purchases can be listed by authenticated users. Purchases can be created, updated, or deleted only by authenticated users for a specific store.
     * @path /purchases/{purchaseId}
     * @allow (list) Authenticated user can list the purchases.
     * @allow (create) Authenticated user can create a purchase with the correct storeId.
     * @deny (create) Unauthenticated user cannot create a purchase.
     * @deny (update) Authenticated user cannot update a purchase if the storeId does not match.
     * @deny (delete) Unauthenticated user cannot delete a purchase.
     * @principle Enforces store-ownership for writes.
     */
    match /purchases/{purchaseId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();

      /**
       * @description Purchase items can be listed by authenticated users. Purchase items can be created, updated, or deleted only by authenticated users for a specific store.
       * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
       * @allow (list) Authenticated user can list the purchase items.
       * @allow (create) Authenticated user can create a purchase item with the correct storeId.
       * @deny (create) Unauthenticated user cannot create a purchase item.
       * @deny (update) Authenticated user cannot update a purchase item if the storeId does not match.
       * @deny (delete) Unauthenticated user cannot delete a purchase item.
       * @principle Enforces store-ownership for writes.
       */
      match /purchaseItems/{purchaseItemId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
        allow update: if isSignedIn() && resource.data.storeId == getStoreId();
        allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
      }
    }

    /**
     * @description Customers can be listed by authenticated users. Customers can be created, updated, or deleted only by authenticated users for a specific store.
     * @path /customers/{customerId}
     * @allow (list) Authenticated user can list the customers.
     * @allow (create) Authenticated user can create a customer with the correct storeId.
     * @deny (create) Unauthenticated user cannot create a customer.
     * @deny (update) Authenticated user cannot update a customer if the storeId does not match.
     * @deny (delete) Unauthenticated user cannot delete a customer.
     * @principle Enforces store-ownership for writes.
     */
    match /customers/{customerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
    }

    /**
     * @description Store configurations can be listed by authenticated users. Store configurations can be created, updated, or deleted only by authenticated users for a specific store.
     * @path /stores/{storeId}
     * @allow (list) Authenticated user can list the store configurations.
     * @allow (create) Authenticated user can create a store configuration.
     * @deny (create) Unauthenticated user cannot create a store configuration.
     * @deny (update) Authenticated user cannot update a store configuration if the storeId does not match.
     * @deny (delete) Unauthenticated user cannot delete a store configuration.
     * @principle Enforces store-ownership for writes.
     */
    match /stores/{storeId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.id == storeId;
      allow delete: if isSignedIn() && resource.data.id == storeId;
    }

    /**
     * @description Families can be listed by authenticated users. Families can be created, updated, or deleted only by authenticated users for a specific store.
     * @path /families/{familyId}
     * @allow (list) Authenticated user can list the families.
     * @allow (create) Authenticated user can create a family with the correct storeId.
     * @deny (create) Unauthenticated user cannot create a family.
     * @deny (update) Authenticated user cannot update a family if the storeId does not match.
     * @deny (delete) Unauthenticated user cannot delete a family.
     * @principle Enforces store-ownership for writes.
     */
    match /families/{familyId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.storeId == getStoreId();
      allow update: if isSignedIn() && resource.data.storeId == getStoreId();
      allow delete: if isSignedIn() && resource.data.storeId == getStoreId();
    }

    /**
     * @description Warehouses can be listed by authenticated users. Warehouses can be created, updated, or deleted only by authenticated users for a specific store.
     * @path /warehouses/{warehouseId}
     * @allow (list) Authenticated user can list the warehouses.
     * @allow (create) Authenticated user can create a warehouse with the correct storeId.
     * @deny (create) Unauthenticated user cannot create a warehouse.
     * @deny (update) Authenticated user cannot update a warehouse if the storeId does not match.
     * @deny (delete) Unauthenticated user cannot delete a warehouse.
     * @principle Enforces store-ownership for writes.
     */
    match /warehouses/{warehouseId} {
        allow get, list: if isSignedIn();
        allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
        allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
        allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }
  }

  function isSignedIn() {
    return request.auth != null;
  }

  function getStoreId() {
      return request.auth.uid;
  }
}
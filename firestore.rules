/**
 * @fileoverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset is in prototyping mode. It prioritizes strong authorization and
 * allows flexible data shapes for rapid iteration.  Schema validation is
 * limited to critical relational integrity checks.
 *
 * Data Structure:
 * The Firestore database consists of several top-level collections, including:
 * /products/{productId}
 * /taxTypes/{taxTypeId}
 * /inventoryMovements/{inventoryMovementId}
 * /sales/{saleId}
 * /sales/{saleId}/saleItems/{saleItemId}
 * /purchases/{purchaseId}
 * /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
 * /customers/{customerId}
 * /stores/{storeId}
 * /families/{familyId}
 *
 * Key Security Decisions:
 * - All write operations require a valid authenticated user.
 * - No listing of the entire database is allowed.
 * - Data validation is relaxed except for fields required for authorization
 *   (e.g., creatorId) or relational integrity (e.g., id).
 * - It is assumed that all entities have a `storeId` and only users
 *   belonging to that `storeId` can create/modify/delete entities. This is not
 *   explicitly stated in the data model but it is a reasonable assumption.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the owner, based on the storeId field.
     */
    function isOwner(storeId) {
      return isSignedIn() && request.auth.uid == storeId;
    }

    /**
     * @description Checks if the user is the owner and the resource exists.
     */
    function isExistingOwner(storeId) {
      return isOwner(storeId) && resource != null;
    }

    /**
     * @description Collection for products.
     * @path /products/{productId}
     * @allow (create) User with storeId 'store123' can create a product with storeId 'store123'.
     * @deny (create) User with storeId 'store123' cannot create a product with storeId 'store456'.
     * @allow (get, list) Any signed-in user can read any product.
     * @deny (update, delete) Non-owners cannot update or delete products.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /products/{productId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.storeId;
    }

    /**
     * @description Collection for tax types.
     * @path /taxTypes/{taxTypeId}
     * @allow (create) User with storeId 'store123' can create a tax type with storeId 'store123'.
     * @deny (create) User with storeId 'store123' cannot create a tax type with storeId 'store456'.
     * @allow (get, list) Any signed-in user can read any tax type.
     * @deny (update, delete) Non-owners cannot update or delete tax types.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /taxTypes/{taxTypeId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.storeId;
    }

    /**
     * @description Collection for inventory movements.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (create) User with storeId 'store123' can create an inventory movement with storeId 'store123'.
     * @deny (create) User with storeId 'store123' cannot create an inventory movement with storeId 'store456'.
     * @allow (get, list) Any signed-in user can read any inventory movement.
     * @deny (update, delete) Non-owners cannot update or delete inventory movements.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.storeId;
    }

    /**
     * @description Collection for sales.
     * @path /sales/{saleId}
     * @allow (create) User with storeId 'store123' can create a sale with storeId 'store123'.
     * @deny (create) User with storeId 'store123' cannot create a sale with storeId 'store456'.
     * @allow (get, list) Any signed-in user can read any sale.
     * @deny (update, delete) Non-owners cannot update or delete sales.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /sales/{saleId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.storeId;
    }

    /**
     * @description Subcollection for sale items within a sale.
     * @path /sales/{saleId}/saleItems/{saleItemId}
     * @allow (create) User with storeId 'store123' can create a sale item under sale with storeId 'store123'.
     * @deny (create) User with storeId 'store123' cannot create a sale item under sale with storeId 'store456'.
     * @allow (get, list) Any signed-in user can read any sale item.
     * @deny (update, delete) Non-owners cannot update or delete sale items.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /sales/{saleId}/saleItems/{saleItemId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/sales/$(saleId)).data.storeId;
      allow update: if isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/sales/$(saleId)).data.storeId;
      allow delete: if isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/sales/$(saleId)).data.storeId;
    }

    /**
     * @description Collection for purchases.
     * @path /purchases/{purchaseId}
     * @allow (create) User with storeId 'store123' can create a purchase with storeId 'store123'.
     * @deny (create) User with storeId 'store123' cannot create a purchase with storeId 'store456'.
     * @allow (get, list) Any signed-in user can read any purchase.
     * @deny (update, delete) Non-owners cannot update or delete purchases.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /purchases/{purchaseId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.storeId;
    }

    /**
     * @description Subcollection for purchase items within a purchase.
     * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     * @allow (create) User with storeId 'store123' can create a purchase item under purchase with storeId 'store123'.
     * @deny (create) User with storeId 'store123' cannot create a purchase item under purchase with storeId 'store456'.
     * @allow (get, list) Any signed-in user can read any purchase item.
     * @deny (update, delete) Non-owners cannot update or delete purchase items.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId;
      allow update: if isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId;
      allow delete: if isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/purchases/$(purchaseId)).data.storeId;
    }

    /**
     * @description Collection for customers.
     * @path /customers/{customerId}
     * @allow (create) User with storeId 'store123' can create a customer with storeId 'store123'.
     * @deny (create) User with storeId 'store123' cannot create a customer with storeId 'store456'.
     * @allow (get, list) Any signed-in user can read any customer.
     * @deny (update, delete) Non-owners cannot update or delete customers.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /customers/{customerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.storeId;
    }

    /**
     * @description Collection for store configurations.
     * @path /stores/{storeId}
     * @allow (create) User with storeId 'store123' can create a store configuration with storeId 'store123'.
     * @deny (create) User with storeId 'store123' cannot create a store configuration with storeId 'store456'.
     * @allow (get, list) Any signed-in user can read any store configuration.
     * @deny (update, delete) Non-owners cannot update or delete store configurations.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /stores/{storeId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.storeId;
    }

    /**
     * @description Collection for product families.
     * @path /families/{familyId}
     * @allow (create) User with storeId 'store123' can create a family with storeId 'store123'.
     * @deny (create) User with storeId 'store123' cannot create a family with storeId 'store456'.
     * @allow (get, list) Any signed-in user can read any family.
     * @deny (update, delete) Non-owners cannot update or delete families.
     * @principle Enforces store ownership for writes; allows public reads.
     */
    match /families/{familyId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow update: if isSignedIn() && request.auth.uid == request.resource.data.storeId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.storeId;
    }
    
     /**
      * @description Currency rates collection.
      * @path /currency_rates
      * @allow (get, list) Any signed-in user can read any currency rate.
      * @deny (create, update, delete) No one can create, update, or delete currency rates.
      * @principle Public read-only collection.
      */
    match /currency_rates/{currencyRateId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}
/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for data access,
 *              with stores and their associated data (families, products, etc.) owned
 *              by a specific user.
 *
 * Data Structure:
 * - /roles_admin/{userId}:  Admin role assignments.
 * - /users/{userId}: User-specific data.
 * - /stores/{storeId}: Store configurations, including the `ownerId`.
 * - /stores/{storeId}/families/{familyId}: Families within a store, inheriting `ownerId`.
 * - /stores/{storeId}/products/{productId}: Products within a store, inheriting `ownerId`.
 * - /stores/{storeId}/taxTypes/{taxTypeId}: Tax types within a store, inheriting `ownerId`.
 * - /stores/{storeId}/inventoryMovements/{inventoryMovementId}: Inventory movements within a store, inheriting `ownerId`.
 * - /stores/{storeId}/sales/{saleId}: Sales within a store, inheriting `ownerId`.
 * - /stores/{storeId}/sales/{saleId}/saleItems/{saleItemId}: Sale items within a sale, inheriting `ownerId`.
 * - /stores/{storeId}/purchases/{purchaseId}: Purchases within a store, inheriting `ownerId`.
 * - /stores/{storeId}/purchases/{purchaseId}/purchaseItems/{purchaseItemId}: Purchase items within a purchase, inheriting `ownerId`.
 * - /stores/{storeId}/customers/{customerId}: Customers within a store, inheriting `ownerId`.
 *
 * Key Security Decisions:
 * - Strict User Ownership: Most data is owned by a specific user, enforced via the `ownerId` field.
 * - Admin Roles: Admin access is granted to users with a document in the `/roles_admin/{uid}` collection.
 * - Denormalization for Authorization: The `ownerId` is denormalized into subcollections to avoid costly `get()` calls in security rules.
 * - No User Listing: Listing users is generally disallowed for privacy.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants admin access to users with a matching document.
     * @path /roles_admin/{userId}
     * @allow (get, create, update, delete) if the user's ID matches the document ID and the user is signed in.
     * @deny (get, create, update, delete) if the user's ID does not match the document ID.
     * @principle Enforces admin role assignment based on document existence.
     */
    match /roles_admin/{userId} {
      function isAdmin(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isAdmin(userId);
      allow list: if false;
      allow create: if isAdmin(userId);
      allow update: if isAdmin(userId);
      allow delete: if isAdmin(userId);
    }

    /**
     * @description Controls access to user-specific data.
     * @path /users/{userId}
     * @allow (create) if the user's ID matches the document ID and the user is signed in.
     * @allow (get, update, delete) if the user's ID matches the document ID and the user is signed in.
     * @deny (get, create, update, delete) if the user's ID does not match the document ID.
     * @principle Enforces document ownership for user data.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Controls access to store configurations.
     * @path /stores/{storeId}
     * @allow (create) if the user is signed in. The `ownerId` field in the incoming data must match the user's UID.
     * @allow (get, update, delete) if the user is signed in and is the owner of the store (ownerId field matches UID).
     * @deny (get, create, update, delete) if the user is not the owner of the store.
     * @principle Enforces store ownership.
     */
    match /stores/{storeId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(storeId) {
          return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
      }
      allow get: if true; // Assuming public read access for store configuration
      allow list: if true; // Assuming public read access for store configuration
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isOwner(storeId);

      /**
       * @description Controls access to families within a store.
       * @path /stores/{storeId}/families/{familyId}
       */
      match /families/{familyId} {
        function isSignedIn() {
          return request.auth != null;
        }
        function isOwner(storeId) {
            return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
        }
        allow get: if true;
        allow list: if isSignedIn(); //Fixed: added signed in to list to resolve the permission error report.
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update: if isOwner(storeId) && request.resource.data.ownerId == request.auth.uid;
        allow delete: if isOwner(storeId);
      }

      /**
       * @description Controls access to products within a store.
       * @path /stores/{storeId}/products/{productId}
       */
      match /products/{productId} {
        function isSignedIn() {
          return request.auth != null;
        }
        function isOwner(storeId) {
            return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
        }
        allow get: if true;
        allow list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update: if isOwner(storeId) && request.resource.data.ownerId == request.auth.uid;
        allow delete: if isOwner(storeId);
      }

      /**
       * @description Controls access to tax types within a store.
       * @path /stores/{storeId}/taxTypes/{taxTypeId}
       */
      match /taxTypes/{taxTypeId} {
        function isSignedIn() {
          return request.auth != null;
        }
        function isOwner(storeId) {
            return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
        }
        allow get: if true;
        allow list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update: if isOwner(storeId) && request.resource.data.ownerId == request.auth.uid;
        allow delete: if isOwner(storeId);
      }

      /**
       * @description Controls access to inventory movements within a store.
       * @path /stores/{storeId}/inventoryMovements/{inventoryMovementId}
       */
      match /inventoryMovements/{inventoryMovementId} {
        function isSignedIn() {
          return request.auth != null;
        }
        function isOwner(storeId) {
            return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
        }
        allow get: if true;
        allow list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update: if isOwner(storeId) && request.resource.data.ownerId == request.auth.uid;
        allow delete: if isOwner(storeId);
      }

      /**
       * @description Controls access to sales within a store.
       * @path /stores/{storeId}/sales/{saleId}
       */
      match /sales/{saleId} {
        function isSignedIn() {
          return request.auth != null;
        }
        function isOwner(storeId) {
            return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
        }
        allow get: if true;
        allow list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update: if isOwner(storeId) && request.resource.data.ownerId == request.auth.uid;
        allow delete: if isOwner(storeId);

        /**
         * @description Controls access to sale items within a sale.
         * @path /stores/{storeId}/sales/{saleId}/saleItems/{saleItemId}
         */
        match /saleItems/{saleItemId} {
          function isSignedIn() {
            return request.auth != null;
          }
          function isOwner(storeId) {
              return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
          }
          allow get: if true;
          allow list: if isSignedIn();
          allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
          allow update: if isOwner(storeId) && request.resource.data.ownerId == request.auth.uid;
          allow delete: if isOwner(storeId);
        }
      }

      /**
       * @description Controls access to purchases within a store.
       * @path /stores/{storeId}/purchases/{purchaseId}
       */
      match /purchases/{purchaseId} {
        function isSignedIn() {
          return request.auth != null;
        }
        function isOwner(storeId) {
            return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
        }
        allow get: if true;
        allow list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update: if isOwner(storeId) && request.resource.data.ownerId == request.auth.uid;
        allow delete: if isOwner(storeId);

        /**
         * @description Controls access to purchase items within a purchase.
         * @path /stores/{storeId}/purchases/{purchaseId}/purchaseItems/{purchaseItemId}
         */
        match /purchaseItems/{purchaseItemId} {
          function isSignedIn() {
            return request.auth != null;
          }
          function isOwner(storeId) {
              return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
          }
          allow get: if true;
          allow list: if isSignedIn();
          allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
          allow update: if isOwner(storeId) && request.resource.data.ownerId == request.auth.uid;
          allow delete: if isOwner(storeId);
        }
      }

      /**
       * @description Controls access to customers within a store.
       * @path /stores/{storeId}/customers/{customerId}
       */
      match /customers/{customerId} {
        function isSignedIn() {
          return request.auth != null;
        }
        function isOwner(storeId) {
            return isSignedIn() && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
        }
        allow get: if true;
        allow list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update: if isOwner(storeId) && request.resource.data.ownerId == request.auth.uid;
        allow delete: if isOwner(storeId);
      }
    }
  }
}
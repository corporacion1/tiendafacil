/**
 * @fileOverview
 * This ruleset enforces a role-based access control model.
 *
 * Data Structure:
 * - Top-level collections: /products, /tax_types, /inventory_movements, /sales, /purchases, /suppliers, /customers, /store_configuration. These collections are publicly readable.
 * - Subcollections: /sales/{saleId}/sale_items, /purchases/{purchaseId}/purchase_items. Access is determined by the parent document.
 * - User-specific collections: /users/{userId}, /roles_admin/{userId}. Access is restricted to the owning user and admin roles.
 *
 * Key Security Decisions:
 * - Listing of user documents is disallowed for non-owners (privacy).
 * - Superuser/admin status is determined by the presence of a document in the /roles_admin/{userId} collection.
 * - All write operations are subject to authorization checks. No `if true` is used for writes.
 *
 * Denormalization for Authorization:
 * - The existence of a document in `/roles_admin/{userId}` is used to denote a superuser.
 *
 * Structural Segregation:
 * - Publicly readable data is placed in top-level collections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read product information. Only admins can create, update, or delete products.
     * @path /products/{productId}
     * @allow get, list: if true;
     * @deny create: if false; // TODO: Add admin validation once role management is defined.
     * @deny update: if false; // TODO: Add admin validation once role management is defined.
     * @deny delete: if false; // TODO: Add admin validation once role management is defined.
     * @principle Allows public read access but restricts write access.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Allows anyone to read tax type information. Only admins can create, update, or delete tax types.
     * @path /tax_types/{taxTypeId}
     * @allow get, list: if true;
     * @deny create: if false; // TODO: Add admin validation once role management is defined.
     * @deny update: if false; // TODO: Add admin validation once role management is defined.
     * @deny delete: if false; // TODO: Add admin validation once role management is defined.
     * @principle Allows public read access but restricts write access.
     */
    match /tax_types/{taxTypeId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Allows anyone to read inventory movement records. Only admins can create, update, or delete inventory movements.
     * @path /inventory_movements/{inventoryMovementId}
     * @allow get, list: if true;
     * @deny create: if false; // TODO: Add admin validation once role management is defined.
     * @deny update: if false; // TODO: Add admin validation once role management is defined.
     * @deny delete: if false; // TODO: Add admin validation once role management is defined.
     * @principle Allows public read access but restricts write access.
     */
    match /inventory_movements/{inventoryMovementId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Allows anyone to read sale transaction records. Only admins can create, update, or delete sales.
     * @path /sales/{saleId}
     * @allow get, list: if true;
     * @deny create: if false; // TODO: Add admin validation once role management is defined.
     * @deny update: if false; // TODO: Add admin validation once role management is defined.
     * @deny delete: if false; // TODO: Add admin validation once role management is defined.
     * @principle Allows public read access but restricts write access.
     */
    match /sales/{saleId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      /**
       * @description Allows anyone to read sale item records within a sale. Only admins can create, update, or delete sale items.
       * @path /sales/{saleId}/sale_items/{saleItemId}
       * @allow get, list: if true;
       * @deny create: if false; // TODO: Add admin validation once role management is defined.
       * @deny update: if false; // TODO: Add admin validation once role management is defined.
       * @deny delete: if false; // TODO: Add admin validation once role management is defined.
       * @principle Inherits read access from parent sale document, restricts write access.
       */
      match /sale_items/{saleItemId} {
        allow get, list: if true;
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    /**
     * @description Allows anyone to read purchase order records. Only admins can create, update, or delete purchases.
     * @path /purchases/{purchaseId}
     * @allow get, list: if true;
     * @deny create: if false; // TODO: Add admin validation once role management is defined.
     * @deny update: if false; // TODO: Add admin validation once role management is defined.
     * @deny delete: if false; // TODO: Add admin validation once role management is defined.
     * @principle Allows public read access but restricts write access.
     */
    match /purchases/{purchaseId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      /**
       * @description Allows anyone to read purchase item records within a purchase. Only admins can create, update, or delete purchase items.
       * @path /purchases/{purchaseId}/purchase_items/{purchaseItemId}
       * @allow get, list: if true;
       * @deny create: if false; // TODO: Add admin validation once role management is defined.
       * @deny update: if false; // TODO: Add admin validation once role management is defined.
       * @deny delete: if false; // TODO: Add admin validation once role management is defined.
       * @principle Inherits read access from parent purchase document, restricts write access.
       */
      match /purchase_items/{purchaseItemId} {
        allow get, list: if true;
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    /**
     * @description Allows anyone to read supplier information. Only admins can create, update, or delete suppliers.
     * @path /suppliers/{supplierId}
     * @allow get, list: if true;
     * @deny create: if false; // TODO: Add admin validation once role management is defined.
     * @deny update: if false; // TODO: Add admin validation once role management is defined.
     * @deny delete: if false; // TODO: Add admin validation once role management is defined.
     * @principle Allows public read access but restricts write access.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Allows anyone to read customer information. Only admins can create, update, or delete customers.
     * @path /customers/{customerId}
     * @allow get, list: if true;
     * @deny create: if false; // TODO: Add admin validation once role management is defined.
     * @deny update: if false; // TODO: Add admin validation once role management is defined.
     * @deny delete: if false; // TODO: Add admin validation once role management is defined.
     * @principle Allows public read access but restricts write access.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Allows anyone to read store configuration settings. Only admins can create, update, or delete store configuration.
     * @path /store_configuration/{storeConfigurationId}
     * @allow get, list: if true;
     * @deny create: if false; // TODO: Add admin validation once role management is defined.
     * @deny update: if false; // TODO: Add admin validation once role management is defined.
     * @deny delete: if false; // TODO: Add admin validation once role management is defined.
     * @principle Allows public read access but restricts write access.
     */
    match /store_configuration/{storeConfigurationId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Allows a user to read, update, and delete their own user document. Only admins can create new users. Users cannot list other user documents.
     * @path /users/{userId}
     * @allow get: if isOwner(userId);
     * @allow list: if false;
     * @allow create: if isOwner(userId);
     * @allow update: if isExistingOwner(userId);
     * @allow delete: if isExistingOwner(userId);
     * @deny list: if true;
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Disallow listing of all users
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

     /**
      * @description Allows admins to read, create, update, and delete documents in the roles_admin collection. The presence of a document indicates the user is an admin.
      * @path /roles_admin/{userId}
      * @allow get: if isAdmin() || isOwner(userId);
      * @allow list: if isAdmin();
      * @allow create: if isAdmin();
      * @allow update: if isAdmin();
      * @allow delete: if isAdmin();
      * @principle Role-based access control for admin privileges.
      */
    match /roles_admin/{userId} {
        allow get: if isAdmin() || isOwner(userId);
        allow list: if isAdmin();
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
    }

    // ---- Helper functions ----

    /**
     * @description Checks if the current user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the current user is the owner of the resource based on the provided user ID.
     * @param {string} userId - The user ID to compare with the authenticated user's ID.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the current user is the owner of the existing resource.
     * @param {string} userId - The user ID to compare with the authenticated user's ID.
     * @return {boolean} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Checks if the current user is an admin, by verifying if their ID exists as a document in the roles_admin collection.
     * @return {boolean} True if the user is an admin, false otherwise.
     */
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
  }
}
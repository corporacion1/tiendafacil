/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict data-centric security model, granting access based on document ownership and authenticated user identity.
 *
 * Data Structure:
 * All data is stored in top-level collections: `/products`, `/inventoryMovements`, `/sales`, `/customers`, `/suppliers`, `/taxTypes`, and `/configuration`.
 * Subcollections `/sales/{saleId}/saleItems/{saleItemId}` and `/purchases/{purchaseId}/purchaseItems/{purchaseItemId}` exist for relational data.
 *
 * Key Security Decisions:
 * - All write operations are restricted to authenticated users.
 * - Read operations on most collections are public, but writes require authentication and often ownership.
 * - Subcollection reads and writes inherit the security context of their parent documents.
 * - Data validation is minimal in this prototyping phase, focusing on authorization and relational integrity only.
 *
 * Denormalization for Authorization:
 *  None.
 * Structural Segregation:
 *  There is no structural segregation.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows read access to products.  Write access requires authentication.
     * @path /products/{productId}
     * @allow (get, list): if true
     * @allow (create, update, delete): if isSignedIn()
     * @deny (create, update, delete): if !isSignedIn()
     * @principle Allows public read access, but restricts writes to authenticated users.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows read access to inventory movements.  Write access requires authentication.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (get, list): if true
     * @allow (create, update, delete): if isSignedIn()
     * @deny (create, update, delete): if !isSignedIn()
     * @principle Allows public read access, but restricts writes to authenticated users.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows read access to sales.  Write access requires authentication.
     * @path /sales/{saleId}
     * @allow (get, list): if true
     * @allow (create, update, delete): if isSignedIn()
     * @deny (create, update, delete): if !isSignedIn()
     * @principle Allows public read access, but restricts writes to authenticated users.
     */
    match /sales/{saleId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();

      /**
       * @description Allows read and write access to sale items if the user is signed in.
       * @path /sales/{saleId}/saleItems/{saleItemId}
       * @allow (get, list, create, update, delete): if isSignedIn()
       * @deny (get, list, create, update, delete): if !isSignedIn()
       * @principle Restricts access to authenticated users.
       */
      match /saleItems/{saleItemId} {
        allow get, list, create, update, delete: if isSignedIn();
      }
    }

    /**
     * @description Allows read access to purchases.  Write access requires authentication.
     * @path /purchases/{purchaseId}
     * @allow (get, list): if true
     * @allow (create, update, delete): if isSignedIn()
     * @deny (create, update, delete): if !isSignedIn()
     * @principle Allows public read access, but restricts writes to authenticated users.
     */
    match /purchases/{purchaseId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();

      /**
       * @description Allows read and write access to purchase items if the user is signed in.
       * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
       * @allow (get, list, create, update, delete): if isSignedIn()
       * @deny (get, list, create, update, delete): if !isSignedIn()
       * @principle Restricts access to authenticated users.
       */
      match /purchaseItems/{purchaseItemId} {
        allow get, list, create, update, delete: if isSignedIn();
      }
    }

    /**
     * @description Allows read access to customers.  Write access requires authentication.
     * @path /customers/{customerId}
     * @allow (get, list): if true
     * @allow (create, update, delete): if isSignedIn()
     * @deny (create, update, delete): if !isSignedIn()
     * @principle Allows public read access, but restricts writes to authenticated users.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows read access to suppliers.  Write access requires authentication.
     * @path /suppliers/{supplierId}
     * @allow (get, list): if true
     * @allow (create, update, delete): if isSignedIn()
     * @deny (create, update, delete): if !isSignedIn()
     * @principle Allows public read access, but restricts writes to authenticated users.
     */
    match /suppliers/{supplierId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows read access to tax types.  Write access requires authentication.
     * @path /taxTypes/{taxTypeId}
     * @allow (get, list): if true
     * @allow (create, update, delete): if isSignedIn()
     * @deny (create, update, delete): if !isSignedIn()
     * @principle Allows public read access, but restricts writes to authenticated users.
     */
    match /taxTypes/{taxTypeId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    /**
     * @description Allows read access to configuration settings. Write access requires authentication.
     * @path /configuration/{configurationId}
     * @allow (get, list): if true
     * @allow (create, update, delete): if isSignedIn()
     * @deny (create, update, delete): if !isSignedIn()
     * @principle Allows public read access, but restricts writes to authenticated users.
     */
    match /configuration/{configurationId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }
  }

  function isSignedIn() {
    return request.auth != null;
  }
}
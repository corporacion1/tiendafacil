/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict data-centric security model for a point-of-sale application.
 *
 * Data Structure:
 * - Top-level collections: /products, /inventoryMovements, /sales, /purchases, /customers, /suppliers, /taxTypes, /configuration
 * - Subcollections: /sales/{saleId}/saleItems, /purchases/{purchaseId}/purchaseItems
 *
 * Key Security Decisions:
 * - No user-specific data or ownership is specified. All data is treated as requiring authentication to access.
 * - List operations are disabled unless specifically allowed.
 * - All write operations require authentication and are denied by default, requiring specific rules to be enabled.
 *
 * Access Control:
 * - get: Authenticated users only.
 * - list: Denied unless specifically allowed.
 * - create: Denied unless specifically allowed.
 * - update: Denied unless specifically allowed.
 * - delete: Denied unless specifically allowed.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to product information.
     * @path /products/{productId}
     * @allow get: if isSignedIn();
     * @deny get: if false;
     * @allow list: if false;
     * @deny list: if true;
     * @allow create: if false;
     * @deny create: if true;
     * @allow update: if false;
     * @deny update: if true;
     * @allow delete: if false;
     * @deny delete: if true;
     * @principle Requires authentication to access products.
     */
    match /products/{productId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages access to inventory movement records.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow get: if isSignedIn();
     * @deny get: if false;
     * @allow list: if false;
     * @deny list: if true;
     * @allow create: if false;
     * @deny create: if true;
     * @allow update: if false;
     * @deny update: if true;
     * @allow delete: if false;
     * @deny delete: if true;
     * @principle Requires authentication to access inventory movements.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages access to sales transactions.
     * @path /sales/{saleId}
     * @allow get: if isSignedIn();
     * @deny get: if false;
     * @allow list: if false;
     * @deny list: if true;
     * @allow create: if false;
     * @deny create: if true;
     * @allow update: if false;
     * @deny update: if true;
     * @allow delete: if false;
     * @deny delete: if true;
     * @principle Requires authentication to access sales transactions.
     */
    match /sales/{saleId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;

      /**
       * @description Manages access to individual sale items related to a specific sale.
       * @path /sales/{saleId}/saleItems/{saleItemId}
       * @allow get: if isSignedIn();
       * @deny get: if false;
       * @allow list: if false;
       * @deny list: if true;
       * @allow create: if false;
       * @deny create: if true;
       * @allow update: if false;
       * @deny update: if true;
       * @allow delete: if false;
       * @deny delete: if true;
       * @principle Requires authentication to access sale items.
       */
      match /saleItems/{saleItemId} {
        allow get: if isSignedIn();
        allow list: if false;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }

    /**
     * @description Manages access to purchase transactions.
     * @path /purchases/{purchaseId}
     * @allow get: if isSignedIn();
     * @deny get: if false;
     * @allow list: if false;
     * @deny list: if true;
     * @allow create: if false;
     * @deny create: if true;
     * @allow update: if false;
     * @deny update: if true;
     * @allow delete: if false;
     * @deny delete: if true;
     * @principle Requires authentication to access purchase transactions.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;

      /**
       * @description Manages access to individual purchase items related to a specific purchase.
       * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
       * @allow get: if isSignedIn();
       * @deny get: if false;
       * @allow list: if false;
       * @deny list: if true;
       * @allow create: if false;
       * @deny create: if true;
       * @allow update: if false;
       * @deny update: if true;
       * @allow delete: if false;
       * @deny delete: if true;
       * @principle Requires authentication to access purchase items.
       */
      match /purchaseItems/{purchaseItemId} {
        allow get: if isSignedIn();
        allow list: if false;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }

    /**
     * @description Manages access to customer information.
     * @path /customers/{customerId}
     * @allow get: if isSignedIn();
     * @deny get: if false;
     * @allow list: if false;
     * @deny list: if true;
     * @allow create: if false;
     * @deny create: if true;
     * @allow update: if false;
     * @deny update: if true;
     * @allow delete: if false;
     * @deny delete: if true;
     * @principle Requires authentication to access customer information.
     */
    match /customers/{customerId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages access to supplier information.
     * @path /suppliers/{supplierId}
     * @allow get: if isSignedIn();
     * @deny get: if false;
     * @allow list: if false;
     * @deny list: if true;
     * @allow create: if false;
     * @deny create: if true;
     * @allow update: if false;
     * @deny update: if true;
     * @allow delete: if false;
     * @deny delete: if true;
     * @principle Requires authentication to access supplier information.
     */
    match /suppliers/{supplierId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages access to tax type information.
     * @path /taxTypes/{taxTypeId}
     * @allow get: if isSignedIn();
     * @deny get: if false;
     * @allow list: if false;
     * @deny list: if true;
     * @allow create: if false;
     * @deny create: if true;
     * @allow update: if false;
     * @deny update: if true;
     * @allow delete: if false;
     * @deny delete: if true;
     * @principle Requires authentication to access tax type information.
     */
    match /taxTypes/{taxTypeId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages access to business configuration data.
     * @path /configuration/{configurationId}
     * @allow get: if isSignedIn();
     * @deny get: if false;
     * @allow list: if false;
     * @deny list: if true;
     * @allow create: if false;
     * @deny create: if true;
     * @allow update: if false;
     * @deny update: if true;
     * @allow delete: if false;
     * @deny delete: if true;
     * @principle Requires authentication to access configuration data.
     */
    match /configuration/{configurationId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }

  /**
   * @description Checks if the user is signed in.
   * @return {bool} True if the user is signed in, false otherwise.
   */
  function isSignedIn() {
    return request.auth != null;
  }
}
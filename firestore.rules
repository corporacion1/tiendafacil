/**
 * @description This ruleset enforces a strict ownership model for all collections. All data is stored in top-level collections.
 *   Authenticated users can create, read, update, and delete documents in these collections.
 *   No user listing is allowed by default, which requires explicit configuration.
 *   Data shape validation is relaxed in this prototyping phase to enable rapid development.
 *   Write access is never granted using `if true;`. Every write must be authorized.
 * @dataStructure
 *   /products/{productId}
 *   /inventoryMovements/{inventoryMovementId}
 *   /sales/{saleId}
 *   /sales/{saleId}/saleItems/{saleItemId}
 *   /purchases/{purchaseId}
 *   /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
 *   /customers/{customerId}
 *   /suppliers/{supplierId}
 *   /taxTypes/{taxTypeId}
 *   /configuration/{configurationId}
 * @keySecurityDecisions
 *   - No user listing is allowed.
 *   - All write operations require authentication.
 *   - The rule set does not validate any data, besides requiring the user to be signed in.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Manages access to product information.
     * @path /products/{productId}
     * @allow (create) - Authenticated user can create a product.
     * @allow (get) - Authenticated user can read a product.
     * @allow (update) - Authenticated user can update a product.
     * @allow (delete) - Authenticated user can delete a product.
     * @deny (create) - Unauthenticated user cannot create a product.
     * @deny (update) - Unauthenticated user cannot update a product.
     * @deny (delete) - Unauthenticated user cannot delete a product.
     * @principle Authenticated users can create, read, update, and delete product documents.
     */
    match /products/{productId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to inventory movement records.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (create) - Authenticated user can create an inventory movement.
     * @allow (get) - Authenticated user can read an inventory movement.
     * @allow (update) - Authenticated user can update an inventory movement.
     * @allow (delete) - Authenticated user can delete an inventory movement.
     * @deny (create) - Unauthenticated user cannot create an inventory movement.
     * @deny (update) - Unauthenticated user cannot update an inventory movement.
     * @deny (delete) - Unauthenticated user cannot delete an inventory movement.
     * @principle Authenticated users can create, read, update, and delete inventory movement documents.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to sales transactions.
     * @path /sales/{saleId}
     * @allow (create) - Authenticated user can create a sale.
     * @allow (get) - Authenticated user can read a sale.
     * @allow (update) - Authenticated user can update a sale.
     * @allow (delete) - Authenticated user can delete a sale.
     * @deny (create) - Unauthenticated user cannot create a sale.
     * @deny (update) - Unauthenticated user cannot update a sale.
     * @deny (delete) - Unauthenticated user cannot delete a sale.
     * @principle Authenticated users can create, read, update, and delete sale documents.
     */
    match /sales/{saleId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to individual sale items.
     * @path /sales/{saleId}/saleItems/{saleItemId}
     * @allow (create) - Authenticated user can create a sale item.
     * @allow (get) - Authenticated user can read a sale item.
     * @allow (update) - Authenticated user can update a sale item.
     * @allow (delete) - Authenticated user can delete a sale item.
     * @deny (create) - Unauthenticated user cannot create a sale item.
     * @deny (update) - Unauthenticated user cannot update a sale item.
     * @deny (delete) - Unauthenticated user cannot delete a sale item.
     * @principle Authenticated users can create, read, update, and delete sale item documents.
     */
    match /sales/{saleId}/saleItems/{saleItemId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to purchase transactions.
     * @path /purchases/{purchaseId}
     * @allow (create) - Authenticated user can create a purchase.
     * @allow (get) - Authenticated user can read a purchase.
     * @allow (update) - Authenticated user can update a purchase.
     * @allow (delete) - Authenticated user can delete a purchase.
     * @deny (create) - Unauthenticated user cannot create a purchase.
     * @deny (update) - Unauthenticated user cannot update a purchase.
     * @deny (delete) - Unauthenticated user cannot delete a purchase.
     * @principle Authenticated users can create, read, update, and delete purchase documents.
     */
    match /purchases/{purchaseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to individual purchase items.
     * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     * @allow (create) - Authenticated user can create a purchase item.
     * @allow (get) - Authenticated user can read a purchase item.
     * @allow (update) - Authenticated user can update a purchase item.
     * @allow (delete) - Authenticated user can delete a purchase item.
     * @deny (create) - Unauthenticated user cannot create a purchase item.
     * @deny (update) - Unauthenticated user cannot update a purchase item.
     * @deny (delete) - Unauthenticated user cannot delete a purchase item.
     * @principle Authenticated users can create, read, update, and delete purchase item documents.
     */
    match /purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to customer information.
     * @path /customers/{customerId}
     * @allow (create) - Authenticated user can create a customer.
     * @allow (get) - Authenticated user can read a customer.
     * @allow (update) - Authenticated user can update a customer.
     * @allow (delete) - Authenticated user can delete a customer.
     * @deny (create) - Unauthenticated user cannot create a customer.
     * @deny (update) - Unauthenticated user cannot update a customer.
     * @deny (delete) - Unauthenticated user cannot delete a customer.
     * @principle Authenticated users can create, read, update, and delete customer documents.
     */
    match /customers/{customerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to supplier information.
     * @path /suppliers/{supplierId}
     * @allow (create) - Authenticated user can create a supplier.
     * @allow (get) - Authenticated user can read a supplier.
     * @allow (update) - Authenticated user can update a supplier.
     * @allow (delete) - Authenticated user can delete a supplier.
     * @deny (create) - Unauthenticated user cannot create a supplier.
     * @deny (update) - Unauthenticated user cannot update a supplier.
     * @deny (delete) - Unauthenticated user cannot delete a supplier.
     * @principle Authenticated users can create, read, update, and delete supplier documents.
     */
    match /suppliers/{supplierId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to tax type information.
     * @path /taxTypes/{taxTypeId}
     * @allow (create) - Authenticated user can create a tax type.
     * @allow (get) - Authenticated user can read a tax type.
     * @allow (update) - Authenticated user can update a tax type.
     * @allow (delete) - Authenticated user can delete a tax type.
     * @deny (create) - Unauthenticated user cannot create a tax type.
     * @deny (update) - Unauthenticated user cannot update a tax type.
     * @deny (delete) - Unauthenticated user cannot delete a tax type.
     * @principle Authenticated users can create, read, update, and delete tax type documents.
     */
    match /taxTypes/{taxTypeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to configuration data.
     * @path /configuration/{configurationId}
     * @allow (create) - Authenticated user can create a configuration.
     * @allow (get) - Authenticated user can read a configuration.
     * @allow (update) - Authenticated user can update a configuration.
     * @allow (delete) - Authenticated user can delete a configuration.
     * @deny (create) - Unauthenticated user cannot create a configuration.
     * @deny (update) - Unauthenticated user cannot update a configuration.
     * @deny (delete) - Unauthenticated user cannot delete a configuration.
     * @principle Authenticated users can create, read, update, and delete configuration documents.
     */
    match /configuration/{configurationId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}
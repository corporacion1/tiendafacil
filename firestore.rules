/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a store-ownership model. Almost all data is associated
 * with a specific `storeId`, and access is generally restricted to authenticated
 * users. All collections require the `storeId` for access.
 *
 * Data Structure:
 * - `/products/{productId}`: Products belonging to a store.
 * - `/taxTypes/{taxTypeId}`: Tax types for a store.
 * - `/inventoryMovements/{inventoryMovementId}`: Inventory movements for a store.
 * - `/sales/{saleId}`: Sales transactions for a store.
 * - `/sales/{saleId}/saleItems/{saleItemId}`: Items within a sale.
 * - `/purchases/{purchaseId}`: Purchase orders for a store.
 * - `/purchases/{purchaseId}/purchaseItems/{purchaseItemId}`: Items within a purchase order.
 * - `/customers/{customerId}`: Customers of a store.
 * - `/stores/{storeId}`: Store configurations.
 * - `/families/{familyId}`: Product families for a store.
 *
 * Key Security Decisions:
 * - No user listing: Listing users is not permitted.
 * - Store ID Enforcement: All write operations require a valid `storeId`, and this ID cannot be changed after creation.
 * - Subcollection Security: Subcollections inherit the authorization context of their parent documents.
 *
 * Denormalization for Authorization:
 * - Each document includes a `storeId` field. This is used to ensure that only users
 *   associated with a specific store can access the store's data. This avoids the need for
 *   complex queries or joins in the security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows reading and writing products.
     * @path /products/{productId}
     * @allow (create) - Authenticated user can create a product if the storeId matches.
     * @allow (read) - Anyone can read product data.
     * @deny (update) - Cannot update product if storeId is changed.
     * @deny (delete) - Only the authenticated store user can delete the product.
     * @principle Enforces store ownership and prevents unauthorized data modification.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId == request.resource.data.storeId;
      allow delete: if isSignedIn() && resource.data.storeId != null;
    }

    /**
     * @description Allows reading and writing tax types.
     * @path /taxTypes/{taxTypeId}
     * @allow (create) - Authenticated user can create a tax type if the storeId matches.
     * @allow (read) - Anyone can read tax type data.
     * @deny (update) - Cannot update tax type if storeId is changed.
     * @deny (delete) - Only the authenticated store user can delete the tax type.
     * @principle Enforces store ownership and prevents unauthorized data modification.
     */
    match /taxTypes/{taxTypeId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId == request.resource.data.storeId;
      allow delete: if isSignedIn() && resource.data.storeId != null;
    }

    /**
     * @description Allows reading and writing inventory movements.
     * @path /inventoryMovements/{inventoryMovementId}
     * @allow (create) - Authenticated user can create a inventory movement if the storeId matches.
     * @allow (read) - Anyone can read inventory movement data.
     * @deny (update) - Cannot update inventory movement if storeId is changed.
     * @deny (delete) - Only the authenticated store user can delete the inventory movement.
     * @principle Enforces store ownership and prevents unauthorized data modification.
     */
    match /inventoryMovements/{inventoryMovementId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId == request.resource.data.storeId;
      allow delete: if isSignedIn() && resource.data.storeId != null;
    }

    /**
     * @description Allows reading and writing sales.
     * @path /sales/{saleId}
     * @allow (create) - Authenticated user can create a sale if the storeId matches.
     * @allow (read) - Anyone can read sale data.
     * @deny (update) - Cannot update sale if storeId is changed.
     * @deny (delete) - Only the authenticated store user can delete the sale.
     * @principle Enforces store ownership and prevents unauthorized data modification.
     */
    match /sales/{saleId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId == request.resource.data.storeId;
      allow delete: if isSignedIn() && resource.data.storeId != null;
    }

    /**
     * @description Allows reading and writing sale items within a sale.
     * @path /sales/{saleId}/saleItems/{saleItemId}
     * @allow (create) - Authenticated user can create a sale item if the storeId matches the sale.
     * @allow (read) - Anyone can read sale item data.
     * @deny (update) - Cannot update sale item if storeId is changed.
     * @deny (delete) - Only the authenticated store user can delete the sale item.
     * @principle Enforces store ownership and prevents unauthorized data modification.
     */
    match /sales/{saleId}/saleItems/{saleItemId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows reading and writing purchases.
     * @path /purchases/{purchaseId}
     * @allow (create) - Authenticated user can create a purchase if the storeId matches.
     * @allow (read) - Anyone can read purchase data.
     * @deny (update) - Cannot update purchase if storeId is changed.
     * @deny (delete) - Only the authenticated store user can delete the purchase.
     * @principle Enforces store ownership and prevents unauthorized data modification.
     */
    match /purchases/{purchaseId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId == request.resource.data.storeId;
      allow delete: if isSignedIn() && resource.data.storeId != null;
    }

    /**
     * @description Allows reading and writing purchase items within a purchase.
     * @path /purchases/{purchaseId}/purchaseItems/{purchaseItemId}
     * @allow (create) - Authenticated user can create a purchase item.
     * @allow (read) - Anyone can read purchase item data.
     * @deny (update) - Cannot update purchase item if storeId is changed.
     * @deny (delete) - Only the authenticated store user can delete the purchase item.
     * @principle Enforces store ownership and prevents unauthorized data modification.
     */
    match /purchases/{purchaseId}/purchaseItems/{purchaseItemId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows reading and writing customers.
     * @path /customers/{customerId}
     * @allow (create) - Authenticated user can create a customer if the storeId matches.
     * @allow (read) - Anyone can read customer data.
     * @deny (update) - Cannot update customer if storeId is changed.
     * @deny (delete) - Only the authenticated store user can delete the customer.
     * @principle Enforces store ownership and prevents unauthorized data modification.
     */
    match /customers/{customerId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId == request.resource.data.storeId;
      allow delete: if isSignedIn() && resource.data.storeId != null;
    }

    /**
     * @description Allows reading and writing store configurations.
     * @path /stores/{storeId}
     * @allow (create) - Authenticated user can create a store if the storeId matches.
     * @allow (read) - Anyone can read store data.
     * @deny (update) - Cannot update store if storeId is changed.
     * @deny (delete) - Only the authenticated store user can delete the store.
     * @principle Enforces store ownership and prevents unauthorized data modification.
     */
    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.id == request.auth.uid;
      allow update: if isSignedIn() && resource.data.id == request.resource.data.id;
      allow delete: if isSignedIn() && resource.data.id != null;
    }

    /**
     * @description Allows reading and writing families.
     * @path /families/{familyId}
     * @allow (create) - Authenticated user can create a family if the storeId matches.
     * @allow (read) - Anyone can read family data.
     * @deny (update) - Cannot update family if storeId is changed.
     * @deny (delete) - Only the authenticated store user can delete the family.
     * @principle Enforces store ownership and prevents unauthorized data modification.
     */
    match /families/{familyId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.storeId != null;
      allow update: if isSignedIn() && resource.data.storeId == request.resource.data.storeId;
      allow delete: if isSignedIn() && resource.data.storeId != null;
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}